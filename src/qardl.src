/*
**> qardl
**
**  Purpose:    Perform QARDL estimation
**
**  Format:     qOut = qardl(data, ppp, qqq);
**              qOut = qardl(data, ppp, qqq, tau);
**              qOut = qardl(data, ppp, qqq, tau, cov_type, hac_lags, print_results);
**
**  Input:
**              data:   (n *(1+k)) matrix, where the 1st column is the dependent variable,
**                      and the last k columns are explanatory variables.
**
**              ppp     p value of QARDL(p, q) model;
**
**
**              qqq     q value of QARDL(p, q) model;
**
**              tau     (s * 1) vector of quantiles, which is sorted
**                      from the smallest to the largest.
**
**              cov_type string, covariance estimator: "iid" (default),
**                      "robust", or "hac".
**
**              hac_lags scalar, non-negative HAC lag truncation. If cov_type
**                      is "hac" and hac_lags = 0, a Newey-West automatic
**                      bandwidth floor(4*(T/100)^(2/9)) is used.

**  Output:     qOut            An instance of the qardlOut structure. The structure qOut contains
**                              the following members:
**
**                  qOut.bigbt           Matrix, long-run parameter.
**
**                  qOut.bigbt_cov       Matrix, covariance of the long-run parameter.
**
**                  qOut.phi             Matrix, short-run parameter.
**
**                  qOut.phi_cov         Matrix, covariance of the short-run parameter.
**
**                  qOut.gamma           Matrix, short-run parameter.
**
**                  qOut.gamma_cov       Matrix, covariance of the short-run parameter.
**
**    Developed:    October 10, 2013
**                  Jin Seo Cho
*/

#include qardl.sdf

proc (struct qardlOut) = qardl(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, cov_type = "iid", hac_lags = 0, print_results = 1);

    local za, nn, yy, xx, mm, ee, Y, X, ONEX, bigbt, psu, midbt,
        tw, bb, qq, eei, xxi, yyi, ii, yyj, xxj, wwj, kk, kkk, tilw, lll,
        bbt, cc, bigpi, bigphi, midphi, jj, bigam, bilam, k0, ss, hb, hs,
        bt, fh, uu, midgam, bigff, bigbtmm, barw, mtau, mbb, mfh,
        Y_qr, ONEX_qr,
        cov_lags, full_cov, D_qr, D_inv_qr;
    
    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "qardl");
    cov_type = lower(cov_type);
    call _qardlValidateECMCovType(cov_type, "qardl");
    call _qardlValidateHACLags(hac_lags, "qardl");

    // Number of observations
    nn = rows(data);
    
    // Number of variables
    k0 = cols(data)-1;
    
    // Number of quantiles
    ss = rows(tau);
    
    // Sort tau values
    tau = sortc(tau,1);
    
    za = cdfni(0.975);
    hb = zeros(ss,1);
    hs = zeros(ss,1);
    
    jj = 1;
    do until jj > ss;
        hb[jj, 1] = (4.5*pdfn(cdfni(tau[jj,1]))^4/(nn*(2*cdfni(tau[jj,1])^2+1)^2))^0.2;
        hs[jj, 1] = za^(2/3)*(1.5*pdfn(cdfni(tau[jj,1]))^2/(nn*(2*cdfni(tau[jj,1])^2+1)))^(1/3);
        jj = jj + 1;
    endo;
    
    // Separate independent and dependent data
    yy = data[., 1];
    xx = data[., 2:cols(data)];
    
    // First difference of xx
    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;
    
    if qqq > 0;
        eei = zeros(nn-qqq, qqq*k0);
        xxi = xx[qqq+1:nn, .];
    else;
        xxi = xx;
    endif;
    yyi = zeros(nn-ppp, ppp);
    
    // Create lagged differences of
    // independent variables
    // Variable counter
    if qqq > 0;
        jj = 1;
        do until jj > k0;
            
            // Forward lags of first differences
            // of independent variables
            eei[., 1+(jj-1)*qqq:(jj-1)*qqq+qqq] = packr(lagn(ee[.,jj], seqa(-qqq, 1, qqq)));
            
            jj = jj+1;
        endo;
    endif;
    
    yyi = packr(lagn(yy, seqa(-ppp+1, 1, ppp)));
    yyi = yyi[1:rows(yyi)-1, .];
    
    // Build independent variables
    // First differences of x~foward lagged xx~ forward lagged yy
    //  adjusted for appropriate lag length
    if qqq == 0;
        X = xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    elseif ppp .> qqq;
        X  = eei[(rows(eei)+1-rows(yyi)):rows(eei), .]~xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    else;
        X  = eei~xxi~yyi[(rows(yyi)+1-rows(xxi)):rows(yyi), .];
    endif;
    
    // Parameter estimation
    // Add constant to x
    ONEX = ones(rows(X), 1)~X;
    
    // Adjust y for length of x
    Y  = yy[(nn-rows(X)+1):nn, 1];
    Y_qr = Y;
    ONEX_qr = ONEX;
    call _qardlCheckFullColumnRank(ONEX, "qardl", "levels design matrix");
    
    // Storage for bt
    bt = zeros(cols(ONEX), ss);
    fh = zeros(ss, 1);
    
    // Turn off constant
    struct qfitControl qCtl;
    qctl = qfitControlCreate();
    qCtl.const = 0;
    qCtl.verbose = 0;
    
    struct qfitOut qOut;
    qOut = quantileFit(Y, ONEX, tau, 0, qCtl);
    bt = qOut.beta;
    
    //  Loop through all specified
    //  tau values
    jj = 1;
    do until jj > ss;
        
        // Residuals from estimation
        uu = Y - ONEX*bt[.,jj];
        fh[jj, 1] = meanc(pdfn(-uu/hb[jj, 1]))/hb[jj, 1];
        
        jj = jj + 1;
    endo;
    
    if qqq == 0;
        midbt = zeros(k0, ss);
        jj = 1;
        do until jj > ss;
            midbt[., jj] = bt[2:1+k0, jj]/(1-sumc(bt[2+k0:1+k0+ppp, jj]));
            jj = jj + 1;
        endo;
        bigbt = vec(midbt);

        midphi = zeros(ppp, ss);
        jj = 1;
        do until jj > ss;
            midphi[., jj] = bt[2+k0:1+k0+ppp, jj];
            jj = jj + 1;
        endo;
        bigphi = vec(midphi);

        midgam = zeros(k0, ss);
        jj = 1;
        do until jj > ss;
            midgam[., jj] = bt[2:1+k0, jj];
            jj = jj + 1;
        endo;
        bigam = vec(midgam);

        D_qr = ONEX_qr'*ONEX_qr / rows(Y_qr);
        D_inv_qr = _qardlSafeInv(D_qr, "qardl", "QR moment matrix");
        cov_lags = 0;
        if cov_type $== "hac";
            cov_lags = hac_lags;
            if cov_lags == 0;
                cov_lags = _qardlAutomaticHACLags(rows(Y_qr));
            endif;
        endif;
        full_cov = _qardlQRCovSandwich(ONEX_qr, Y_qr, bt, tau, fh, D_inv_qr, cov_lags);
        { bigbtmm, bigpi, bigff } = _qardlLevelsCovFromFull(full_cov, bt, ppp, qqq, k0, ss);

        struct qardlOut qaOutQ0;
        qaOutQ0.tau = tau;
        qaOutQ0.p = ppp;
        qaOutQ0.q = qqq;
        qaOutQ0.nobs = rows(Y_qr);
        qaOutQ0.k = k0;
        qaOutQ0.bigbt = bigbt;
        qaOutQ0.bigbt_cov = bigbtmm;
        qaOutQ0.phi = bigphi;
        qaOutQ0.phi_cov = bigpi;
        qaOutQ0.gamma = bigam;
        qaOutQ0.gamma_cov = bigff;
        qaOutQ0.alpha = bt[1, .]';
        qaOutQ0.rho = -(1 - sumc(bt[2+k0:1+k0+ppp, .]));
        qaOutQ0.bt = bt;

        if print_results;
            call printQARDL(qaOutQ0, tau);
        endif;

        retp(qaOutQ0);
    endif;

    // Testing long-run parameter: beta
    barw = zeros(nn-1, qqq*k0);
    
    jj = 1;
    do until jj > qqq;
        barw[jj:(nn-1), (k0*(jj-1)+1):(k0*jj)] = ee[2:(nn-jj+1), .];
        jj = jj + 1;
    endo;
    
    //    tw = ones(nn-1,1)~ee[2:nn,.];
    tw = ones(nn-1, 1)~barw;
    mm = (xx[(qqq+1):nn, .]'*xx[(qqq+1):nn, .] - xx[(qqq+1):nn, .]'*tw[qqq:(nn-1), .]*inv(tw[qqq:(nn-1), .]'*tw[qqq:(nn-1), .])*tw[qqq:(nn-1), .]'*xx[(qqq+1):nn, .])/(nn-qqq)^2;
    
    bb = 1/((1-sumc(bt[2+(qqq+1)*k0:1+(qqq+1)*k0+ppp, .])).*fh);
    
    qq = zeros(ss, ss);
    jj = 1;
    
    mtau = tau.*tau';
    mbb = bb.*bb';
    do until jj > ss;
        ii = 1;
        do until ii > ss;
            
            psu = zeros(2, 1);
            psu[1, 1] = tau[jj, 1];
            psu[2, 1] = tau[ii, 1];
            qq[jj, ii] = (minc(psu) - mtau[jj, ii])*mbb[jj, ii];
            
            ii = ii + 1;
        endo;
        
        jj = jj + 1;
    endo;
    
    midbt = zeros(k0, ss);
    jj = 1;
    do until jj > ss;
        midbt[., jj] = bt[2+qqq*k0:1+(qqq+1)*k0, jj]/(1-sumc(bt[2+(qqq+1)*k0:1+(qqq+1)*k0+ppp, jj]));
        jj = jj + 1;
    endo;
    bigbt = vec(midbt);
    bigbtmm = (qq.*. inv(mm));
    
    // Testing short-run parameters: phi
    if ppp .> qqq;
        xxj = zeros(nn-ppp, k0);
        wwj = zeros(nn-ppp, qqq*k0);
        
        yyj = yyi;
        
        ii = 1;
        do until ii > k0;
            jj = 1;
            do until jj > qqq;
                wwj[., jj+(ii-1)*qqq] = ee[(ppp-jj+2):(nn-jj+1), ii];
                jj = jj + 1;
            endo;
            ii = ii + 1;
        endo;
        
        xxj = xx[(ppp+1):nn, .];
        kk = zeros(nn-ppp, ss*ppp);
        
        jj = 1;
        do until jj > ppp;
            Y = yyj[., jj];
            ONEX = ones(nn-ppp, 1)~xxj~wwj;
            struct qfitOut qOut2;
            
            qOut2 = quantileFit(Y, ONEX, tau, 0, qCtl);
            bbt = qOut2.beta;
            
            ii = 1;
            do until ii > ss;
                kkk = Y - ONEX*bbt[., ii];
                kk[., jj+(ii-1)*ppp] = kkk;
                ii = ii + 1;
            endo;
            jj = jj + 1;
        endo;
        tilw = tw[ppp:(nn-1), .];
        lll = (kk'*kk - kk'*tilw*inv(tilw'*tilw)*tilw'*kk)/(nn-ppp);
    else;
        yyj = zeros(nn-qqq, ppp);
        xxj = zeros(nn-qqq, k0);
        wwj = zeros(nn-qqq, qqq*k0);
        jj = 1;
        do until jj > ppp;
            yyj[., jj] = yy[(qqq+1-jj):(nn-jj), 1];
            jj = jj + 1;
        endo;
        ii = 1;
        do until ii > k0;
            jj = 1;
            do until jj > qqq;
                wwj[., jj+(ii-1)*qqq] = ee[(qqq-jj+2):(nn-jj+1), ii];
                jj = jj + 1;
            endo;
            ii = ii + 1;
        endo;
        xxj = xx[(qqq+1):nn, .];
        kk = zeros(nn-qqq, ss*ppp);
        jj = 1;
        do until jj > ppp;
            Y = yyj[., jj];
            ONEX = ones(nn-qqq, 1)~xxj~wwj;
            struct qfitOut qOut3;
            qOut3 = quantileFit(Y, ONEX, tau, 0, qCtl);
            bbt = qOut3.beta;
            
            ii = 1;
            do until ii > ss;
                kkk = Y - ONEX*bbt[.,ii];
                kk[.,jj+(ii-1)*ppp] = kkk;
                ii = ii + 1;
            endo;
            jj = jj + 1;
        endo;
        tilw = tw[qqq:(nn-1),.];
        lll = (kk'*kk - kk'*tilw*inv(tilw'*tilw)*tilw'*kk)/(nn-qqq);
    endif;
    
    mfh = fh.*fh';
    cc = zeros(ss,ss);
    jj = 1;
    
    do until jj > ss;
        ii = 1;
        do until ii > ss;
            psu = zeros(2,1);
            psu[1,1] = tau[jj,1];
            psu[2,1] = tau[ii,1];
            cc[jj,ii] = (minc(psu) - mtau[jj, ii])/(mfh[jj, ii]);
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;
    
    bigpi = zeros(ss*ppp,ss*ppp);
    jj = 1;
    do until jj > ss;
        ii = 1;
        do until ii > ss;
            psu = inv(lll[(jj-1)*ppp+1:jj*ppp,(jj-1)*ppp+1:jj*ppp])*lll[(jj-1)*ppp+1:jj*ppp,(ii-1)*ppp+1:ii*ppp]*inv(lll[(ii-1)*ppp+1:ii*ppp,(ii-1)*ppp+1:ii*ppp]);
            bigpi[(jj-1)*ppp+1:jj*ppp,(ii-1)*ppp+1:ii*ppp] = cc[jj,ii]*psu;
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;
    
    midphi = zeros(ppp,ss);
    jj = 1;
    do until jj > ss;
        midphi[.,jj] = bt[2+(qqq+1)*k0:1+(qqq+1)*k0+ppp,jj];
        jj = jj + 1;
    endo;
    bigphi = vec(midphi);
    
    /* testing short-run parameters: gamma */
    
    midgam = zeros(k0,ss);
    jj = 1;
    do until jj > ss;
        midgam[.,jj] = bt[2+qqq*k0:1+(qqq+1)*k0,jj];
        jj = jj + 1;
    endo;
    bigam = vec(midgam);
    bilam = zeros(k0*ss,ss*ppp);
    
    jj = 1;
    do until jj > ss;
        bilam[((jj-1)*k0+1):(jj*k0),(jj-1)*ppp+1:(jj*ppp)] = midbt[.,jj]*ones(1,ppp);
        jj = jj + 1;
    endo;
    
    bigff = bilam*bigpi*bilam';

    if not (cov_type $== "iid");
        cov_lags = hac_lags;
        if cov_type $== "robust";
            cov_lags = 0;
        elseif cov_lags == 0;
            cov_lags = _qardlAutomaticHACLags(rows(Y));
        endif;

        D_qr = ONEX_qr'*ONEX_qr / rows(Y_qr);
        D_inv_qr = _qardlSafeInv(D_qr, "qardl", "QR moment matrix");
        full_cov = _qardlQRCovSandwich(ONEX_qr, Y_qr, bt, tau, fh, D_inv_qr, cov_lags);
        { bigbtmm, bigpi, bigff } = _qardlLevelsCovFromFull(full_cov, bt, ppp, qqq, k0, ss);
    endif;
    
    struct qardlOut qaOut;
    
    qaOut.tau = tau;
    qaOut.p = ppp;
    qaOut.q = qqq;
    qaOut.nobs = rows(Y);
    qaOut.k = k0;
    qaOut.bigbt = bigbt;
    qaOut.bigbt_cov = bigbtmm;
    qaOut.phi = bigphi;
    qaOut.phi_cov = bigpi;
    qaOut.gamma = bigam;
    qaOut.gamma_cov = bigff;

    // Intercept: alpha(tau) = bt[1, .], transposed to (ss x 1)
    qaOut.alpha = bt[1, .]';

    // ECM adjustment coefficient: rho(tau) = -(1 - sum_j phi_j(tau))
    // sumc over (ppp x ss) matrix gives (ss x 1) column vector directly
    qaOut.rho = -(1 - sumc(bt[2+(qqq+1)*k0:1+(qqq+1)*k0+ppp, .]));

    // Full coefficient matrix for downstream use (e.g., QIRF)
    qaOut.bt = bt;

    if print_results;
        call printQARDL(qaOut, tau);
    endif;

    retp(qaOut);
endp;

/*
**> qardlRobust
**
**  Purpose:    Levels-form QARDL with heteroskedasticity-robust QR sandwich
**              covariance for beta, gamma/theta, and phi.
*/
proc (struct qardlOut) = qardlRobust(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, print_results = 1);
    struct qardlOut qaOut;
    qaOut = qardl(data, ppp, qqq, tau, "robust", 0, print_results);
    retp(qaOut);
endp;

/*
**> qardlHAC
**
**  Purpose:    Levels-form QARDL with Newey-West/Bartlett HAC QR sandwich
**              covariance for beta, gamma/theta, and phi.
**
**  Input:      hac_lags    scalar non-negative lag truncation. Use 0 for the
**                          automatic Newey-West bandwidth.
*/
proc (struct qardlOut) = qardlHAC(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, hac_lags = 0, print_results = 1);
    struct qardlOut qaOut;
    qaOut = qardl(data, ppp, qqq, tau, "hac", hac_lags, print_results);
    retp(qaOut);
endp;

/*
**> qardlX
**
**  Purpose:    Levels-form QARDL with a separate distributed-lag order for
**              each regressor. qvec is k x 1 or 1 x k and contains
**              non-negative integer q_i values.
**
**  Format:     qaOut = qardlX(data, ppp, qvec);
**              qaOut = qardlX(data, ppp, qvec, tau, cov_type, hac_lags, print_results);
**
**  Notes:      Uses the QR sandwich covariance path for all covariance types.
**              `qaOut.q` stores max(qvec); keep qvec with your model spec.
*/
proc (struct qardlOut) = qardlX(data, ppp, qvec, tau = { 0.25, 0.5, 0.75 }, cov_type = "robust", hac_lags = 0, print_results = 1);
    local nn, k0, ss, za, hb, hs, jj, yy, Y, ONEX, bt, fh, uu;
    local qmax, theta_start, phi_start, D_qr, D_inv_qr, cov_lags, full_cov;
    local midbt, bigbt, midphi, bigphi, midgam, bigam, bigbtmm, bigpi, bigff;

    call _qardlValidateEstimatorInputs(data, ppp, 0, tau, "qardlX");
    k0 = cols(data) - 1;
    qvec = _qardlNormalizeQVector(qvec, k0, "qardlX: qvec");
    cov_type = lower(cov_type);
    call _qardlValidateECMCovType(cov_type, "qardlX");
    call _qardlValidateHACLags(hac_lags, "qardlX");

    nn = rows(data);
    ss = rows(tau);
    tau = sortc(tau, 1);
    yy = data[., 1];
    qmax = maxc(qvec);

    { Y, ONEX, theta_start, phi_start } = _qardlBuildLevelsDesignX(data, ppp, qvec);
    call _qardlCheckFullColumnRank(ONEX, "qardlX", "levels design matrix");

    za = cdfni(0.975);
    hb = zeros(ss, 1);
    hs = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        hb[jj] = (4.5*pdfn(cdfni(tau[jj]))^4/(nn*(2*cdfni(tau[jj])^2+1)^2))^0.2;
        hs[jj] = za^(2/3)*(1.5*pdfn(cdfni(tau[jj]))^2/(nn*(2*cdfni(tau[jj])^2+1)))^(1/3);
        jj = jj + 1;
    endo;

    struct qfitControl qCtl;
    qCtl = qfitControlCreate();
    qCtl.const = 0;
    qCtl.verbose = 0;

    struct qfitOut qOut;
    qOut = quantileFit(Y, ONEX, tau, 0, qCtl);
    bt = qOut.beta;

    fh = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        uu = Y - ONEX*bt[., jj];
        fh[jj] = meanc(pdfn(-uu/hb[jj]))/hb[jj];
        jj = jj + 1;
    endo;

    midbt = zeros(k0, ss);
    midphi = zeros(ppp, ss);
    midgam = zeros(k0, ss);
    jj = 1;
    do until jj > ss;
        midbt[., jj] = bt[theta_start:theta_start+k0-1, jj] /
                       (1 - sumc(bt[phi_start:phi_start+ppp-1, jj]));
        midphi[., jj] = bt[phi_start:phi_start+ppp-1, jj];
        midgam[., jj] = bt[theta_start:theta_start+k0-1, jj];
        jj = jj + 1;
    endo;
    bigbt = vec(midbt);
    bigphi = vec(midphi);
    bigam = vec(midgam);

    cov_lags = 0;
    if cov_type $== "hac";
        cov_lags = hac_lags;
        if cov_lags == 0;
            cov_lags = _qardlAutomaticHACLags(rows(Y));
        endif;
    endif;

    D_qr = ONEX'*ONEX / rows(Y);
    D_inv_qr = _qardlSafeInv(D_qr, "qardlX", "QR moment matrix");
    full_cov = _qardlQRCovSandwich(ONEX, Y, bt, tau, fh, D_inv_qr, cov_lags);
    { bigbtmm, bigpi, bigff } =
        _qardlLevelsCovFromFullPositions(full_cov, bt, theta_start, phi_start, k0, ppp, ss);

    struct qardlOut qaOut;
    qaOut.tau = tau;
    qaOut.p = ppp;
    qaOut.q = qmax;
    qaOut.nobs = rows(Y);
    qaOut.k = k0;
    qaOut.bigbt = bigbt;
    qaOut.bigbt_cov = bigbtmm;
    qaOut.phi = bigphi;
    qaOut.phi_cov = bigpi;
    qaOut.gamma = bigam;
    qaOut.gamma_cov = bigff;
    qaOut.alpha = bt[1, .]';
    qaOut.rho = -(1 - sumc(bt[phi_start:phi_start+ppp-1, .]));
    qaOut.bt = bt;

    if print_results;
        call printQARDL(qaOut, tau);
    endif;

    retp(qaOut);
endp;

/*
**> qardlECM
**
**  Purpose:    Perform two-step QARDL-ECM estimation.
**
**              Step 1: Estimate the ARDL model by OLS to obtain consistent
**                      long-run coefficient estimates (beta_lr) and the OLS
**                      speed of adjustment (rho_ols).
**              Step 2: Form the error correction term EC_{t-1} = y_{t-1} - beta_lr'*x_{t-1}
**                      and estimate the ECM by quantile regression:
**                        Dy_t = alpha(tau) + rho(tau)*EC_{t-1}
**                               + sum_j psi_j(tau)*Dy_{t-j}      [j=1,...,p-1]
**                               + sum_j delta_j(tau)*Dx_{t-j}    [j=0,...,q-1]
**                               + u_t(tau)
**
**  Format:     qECMOut = qardlECM(data, ppp, qqq);
**              qECMOut = qardlECM(data, ppp, qqq, tau);
**              qECMOut = qardlECM(data, ppp, qqq, tau, cov_type, hac_lags, print_results);
**
**  Input:      data        (n x (1+k)) matrix. Column 1 is the dependent variable;
**                          columns 2:(1+k) are the k regressors.
**
**              ppp         scalar, AR lag order p >= 1.
**
**              qqq         scalar, distributed-lag order q >= 1.
**
**              tau         (s x 1) vector of quantile levels, sorted ascending.
**
**              cov_type    string, covariance estimator: "iid" (default),
**                          "robust", or "hac".
**
**              hac_lags    scalar, non-negative HAC lag truncation. If cov_type
**                          is "hac" and hac_lags = 0, a Newey-West automatic
**                          bandwidth floor(4*(T/100)^(2/9)) is used.
**
**  Output:     qECMOut     instance of qardlECMOut. Members:
**
**                  qECMOut.beta_lr     (k x 1) OLS long-run coefficients used
**                                      to construct the error correction term.
**
**                  qECMOut.rho_ols     scalar (1x1 matrix), OLS speed of adjustment
**                                      rho_OLS = -(1 - sum_j phi_j^OLS).
**
**                  qECMOut.alpha       (s x 1) ECM intercept at each quantile.
**
**                  qECMOut.rho         (s x 1) speed of adjustment at each quantile.
**
**                  qECMOut.rho_cov     (s x s) asymptotic covariance of rho across
**                                      quantiles.
**
**  Notes:      Requires cointegration between y_t and x_t. The two-step
**              approach avoids nonlinear QR by using OLS for the long-run
**              relationship (Cho, Kim & Shin 2015; Aptech GAUSS forum).
**
**  Developed:  March 2026
*/

proc (struct qardlECMOut) = qardlECM(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, cov_type = "iid", hac_lags = 0, print_results = 1);
    local nn, k0, ss, jj, ii, j;
    local yy, xx, ee;
    local eei, xxi, yyi, X_ols, ONEX_ols, Y_ols;
    local bt_ols, rho_ols, beta_lr_ols;
    local N, T0, N_ecm;
    local ec_lag, dy_lags, dx_ecm, ONEX_ecm, Y_ecm;
    local bt_ecm, fh_ecm, uu_ecm, hb;
    local za, cc, mfh, mtau, psu;
    local D_ecm, D_inv_ecm, rho_cov, alpha_cov, cov_lags;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "qardlECM");
    cov_type = lower(cov_type);
    call _qardlValidateECMCovType(cov_type, "qardlECM");
    call _qardlValidateHACLags(hac_lags, "qardlECM");

    nn = rows(data);
    k0 = cols(data) - 1;
    ss = rows(tau);
    tau = sortc(tau, 1);

    // Bandwidth for density estimation at each quantile
    za = cdfni(0.975);
    hb = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        hb[jj] = (4.5*pdfn(cdfni(tau[jj]))^4/(nn*(2*cdfni(tau[jj])^2+1)^2))^0.2;
        jj = jj + 1;
    endo;

    yy = data[., 1];
    xx = data[., 2:cols(data)];

    // First differences of x (prepend zero row for alignment)
    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;

    // ---- Step 1: OLS ARDL (identical regressor construction to qardl) ----
    if qqq > 0;
        eei = zeros(nn-qqq, qqq*k0);
        xxi = xx[qqq+1:nn, .];
    else;
        xxi = xx;
    endif;
    yyi = zeros(nn-ppp, ppp);

    if qqq > 0;
        jj = 1;
        do until jj > k0;
            eei[., 1+(jj-1)*qqq:(jj-1)*qqq+qqq] = packr(lagn(ee[., jj], seqa(-qqq, 1, qqq)));
            jj = jj + 1;
        endo;
    endif;

    yyi = packr(lagn(yy, seqa(-ppp+1, 1, ppp)));
    yyi = yyi[1:rows(yyi)-1, .];

    if qqq == 0;
        X_ols = xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    elseif ppp .> qqq;
        X_ols = eei[(rows(eei)+1-rows(yyi)):rows(eei), .]~xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    else;
        X_ols = eei~xxi~yyi[(rows(yyi)+1-rows(xxi)):rows(yyi), .];
    endif;

    ONEX_ols = ones(rows(X_ols), 1)~X_ols;
    Y_ols = yy[(nn-rows(X_ols)+1):nn, 1];
    N = rows(Y_ols);
    T0 = nn - N;
    call _qardlCheckFullColumnRank(ONEX_ols, "qardlECM", "levels OLS design matrix");

    // OLS ARDL coefficient vector
    bt_ols = _qardlSafeInv(ONEX_ols'*ONEX_ols, "qardlECM", "levels OLS moment matrix")*ONEX_ols'*Y_ols;

    // OLS speed of adjustment: rho_ols = -(1 - sum_j phi_j)
    rho_ols = -(1 - sumc(bt_ols[2+(qqq+1)*k0:1+(qqq+1)*k0+ppp]));

    // OLS long-run coefficient: beta_lr = theta / (-rho_ols)
    // where theta = bt_ols[2+qqq*k0:1+(qqq+1)*k0] are the x-level coefficients
    beta_lr_ols = bt_ols[2+qqq*k0:1+(qqq+1)*k0] ./ (-rho_ols);

    // ---- Step 2: Build ECM regressors (N_ecm = N-1 usable observations) ----
    // t runs from T0+2 to nn; the extra lag consumed by first-differencing y
    N_ecm = N - 1;

    // Dependent variable: Dy_t = y_t - y_{t-1} for t = T0+2,...,nn
    Y_ecm = yy[(T0+2):nn] - yy[(T0+1):(nn-1)];

    // Error correction term (lagged): EC_{t-1} = y_{t-1} - beta_lr' * x_{t-1}
    ec_lag = yy[(T0+1):(nn-1)] - xx[(T0+1):(nn-1), .]*beta_lr_ols;

    // Start with constant and EC term
    ONEX_ecm = ones(N_ecm, 1)~ec_lag;

    // Lagged first-differences of y: Dy_{t-j} for j = 1,...,ppp-1
    if ppp > 1;
        dy_lags = zeros(N_ecm, ppp-1);
        for j(1, ppp-1, 1);
            dy_lags[., j] = yy[(T0+2-j):(nn-j)] - yy[(T0+1-j):(nn-j-1)];
        endfor;
        ONEX_ecm = ONEX_ecm~dy_lags;
    endif;

    // First-differences of x: Dx_{t-j} for j = 0,...,qqq-1
    // j=0 is contemporaneous Dx_t; j=qqq-1 is Dx_{t-q+1}
    if qqq > 0;
        dx_ecm = zeros(N_ecm, qqq*k0);
        for ii(1, k0, 1);
            for j(0, qqq-1, 1);
                dx_ecm[., j+1+(ii-1)*qqq] = xx[(T0+2-j):(nn-j), ii] - xx[(T0+1-j):(nn-j-1), ii];
            endfor;
        endfor;
        ONEX_ecm = ONEX_ecm~dx_ecm;
    endif;
    call _qardlCheckFullColumnRank(ONEX_ecm, "qardlECM", "ECM design matrix");

    // ---- Step 3: Quantile regression of ECM ----
    struct qfitControl qCtl;
    qCtl = qfitControlCreate();
    qCtl.const = 0;
    qCtl.verbose = 0;

    struct qfitOut qOutECM;
    qOutECM = quantileFit(Y_ecm, ONEX_ecm, tau, 0, qCtl);
    bt_ecm = qOutECM.beta;

    // Density estimates at quantile residuals (for covariance computation)
    fh_ecm = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        uu_ecm = Y_ecm - ONEX_ecm*bt_ecm[., jj];
        fh_ecm[jj] = meanc(pdfn(-uu_ecm/hb[jj]))/hb[jj];
        jj = jj + 1;
    endo;

    // ---- Asymptotic covariance of rho estimates ----
    // For stationary ECM regressors, Cov(rho(tau_i), rho(tau_j)) = cc[i,j]*D_inv[2,2]/N_ecm
    // where cc[i,j] = (min(tau_i, tau_j) - tau_i*tau_j) / (fh_i * fh_j)
    // and D = ONEX_ecm'*ONEX_ecm / N_ecm
    mtau = tau.*tau';
    mfh = fh_ecm.*fh_ecm';

    cc = zeros(ss, ss);
    jj = 1;
    do until jj > ss;
        ii = 1;
        do until ii > ss;
            psu = zeros(2, 1);
            psu[1] = tau[jj];
            psu[2] = tau[ii];
            cc[jj, ii] = (minc(psu) - mtau[jj, ii]) / mfh[jj, ii];
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;

    D_ecm = ONEX_ecm'*ONEX_ecm / N_ecm;
    D_inv_ecm = _qardlSafeInv(D_ecm, "qardlECM", "ECM moment matrix");

    if cov_type $== "iid";
        // Extract variance contributions: row 1 = alpha, row 2 = rho
        rho_cov   = cc * D_inv_ecm[2, 2] / N_ecm;
        alpha_cov = cc * D_inv_ecm[1, 1] / N_ecm;
    else;
        cov_lags = hac_lags;
        if cov_type $== "robust";
            cov_lags = 0;
        elseif cov_lags == 0;
            cov_lags = _qardlAutomaticHACLags(N_ecm);
        endif;
        { alpha_cov, rho_cov } = _qardlECMCovSandwich(ONEX_ecm, Y_ecm, bt_ecm, tau,
                                                      fh_ecm, D_inv_ecm, cov_lags);
    endif;

    // ---- Package results ----
    struct qardlECMOut qECMOut;
    qECMOut.tau       = tau;
    qECMOut.p         = ppp;
    qECMOut.q         = qqq;
    qECMOut.nobs      = N_ecm;
    qECMOut.k         = k0;
    qECMOut.beta_lr   = beta_lr_ols;
    qECMOut.rho_ols   = rho_ols;
    qECMOut.alpha     = bt_ecm[1, .]';
    qECMOut.rho       = bt_ecm[2, .]';
    qECMOut.rho_cov   = rho_cov;
    qECMOut.alpha_cov = alpha_cov;

    if print_results;
        call printQARDLECM(qECMOut, tau);
    endif;

    retp(qECMOut);
endp;

/*
**> qardlECMRobust
**
**  Purpose:    Two-step QARDL-ECM estimation with heteroskedasticity-robust
**              quantile-regression sandwich covariance for alpha and rho.
*/
proc (struct qardlECMOut) = qardlECMRobust(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, print_results = 1);
    struct qardlECMOut qECMOut;
    qECMOut = qardlECM(data, ppp, qqq, tau, "robust", 0, print_results);
    retp(qECMOut);
endp;

/*
**> qardlECMHAC
**
**  Purpose:    Two-step QARDL-ECM estimation with Newey-West/Bartlett HAC
**              quantile-regression sandwich covariance for alpha and rho.
**
**  Input:      hac_lags    scalar non-negative lag truncation. Use 0 for the
**                          automatic Newey-West bandwidth.
*/
proc (struct qardlECMOut) = qardlECMHAC(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, hac_lags = 0, print_results = 1);
    struct qardlECMOut qECMOut;
    qECMOut = qardlECM(data, ppp, qqq, tau, "hac", hac_lags, print_results);
    retp(qECMOut);
endp;

/*
**> qardlECMX
**
**  Purpose:    Two-step QARDL-ECM with a separate distributed-lag order for
**              each regressor.
*/
proc (struct qardlECMOut) = qardlECMX(data, ppp, qvec, tau = { 0.25, 0.5, 0.75 }, cov_type = "robust", hac_lags = 0, print_results = 1);
    local nn, k0, ss, yy, xx, Y_ols, ONEX_ols, theta_start, phi_start;
    local bt_ols, rho_ols, beta_lr_ols, qmax, T0, N, N_ecm, Y_ecm, ec_lag;
    local ONEX_ecm, dy_lags, dx_ecm, ii, jj, j, bt_ecm, fh_ecm, uu_ecm;
    local za, hb, D_ecm, D_inv_ecm, rho_cov, alpha_cov, cov_lags, cc, mtau, mfh, psu;

    call _qardlValidateEstimatorInputs(data, ppp, 0, tau, "qardlECMX");
    k0 = cols(data) - 1;
    qvec = _qardlNormalizeQVector(qvec, k0, "qardlECMX: qvec");
    cov_type = lower(cov_type);
    call _qardlValidateECMCovType(cov_type, "qardlECMX");
    call _qardlValidateHACLags(hac_lags, "qardlECMX");

    nn = rows(data);
    ss = rows(tau);
    tau = sortc(tau, 1);
    yy = data[., 1];
    xx = data[., 2:cols(data)];
    qmax = maxc(qvec);

    { Y_ols, ONEX_ols, theta_start, phi_start } = _qardlBuildLevelsDesignX(data, ppp, qvec);
    call _qardlCheckFullColumnRank(ONEX_ols, "qardlECMX", "levels OLS design matrix");
    bt_ols = _qardlSafeInv(ONEX_ols'*ONEX_ols, "qardlECMX", "levels OLS moment matrix")*ONEX_ols'*Y_ols;
    rho_ols = -(1 - sumc(bt_ols[phi_start:phi_start+ppp-1]));
    beta_lr_ols = bt_ols[theta_start:theta_start+k0-1] ./ (-rho_ols);

    T0 = maxc(ppp|qmax);
    N = rows(Y_ols);
    N_ecm = N - 1;
    Y_ecm = yy[(T0+2):nn] - yy[(T0+1):(nn-1)];
    ec_lag = yy[(T0+1):(nn-1)] - xx[(T0+1):(nn-1), .]*beta_lr_ols;
    ONEX_ecm = ones(N_ecm, 1)~ec_lag;

    if ppp > 1;
        dy_lags = zeros(N_ecm, ppp-1);
        for j(1, ppp-1, 1);
            dy_lags[., j] = yy[(T0+2-j):(nn-j)] - yy[(T0+1-j):(nn-j-1)];
        endfor;
        ONEX_ecm = ONEX_ecm~dy_lags;
    endif;

    if sumc(qvec) > 0;
        dx_ecm = zeros(N_ecm, sumc(qvec));
        jj = 1;
        ii = 1;
        do until ii > k0;
            if qvec[ii] > 0;
                for j(0, qvec[ii]-1, 1);
                    dx_ecm[., jj] = xx[(T0+2-j):(nn-j), ii] - xx[(T0+1-j):(nn-j-1), ii];
                    jj = jj + 1;
                endfor;
            endif;
            ii = ii + 1;
        endo;
        ONEX_ecm = ONEX_ecm~dx_ecm;
    endif;
    call _qardlCheckFullColumnRank(ONEX_ecm, "qardlECMX", "ECM design matrix");

    za = cdfni(0.975);
    hb = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        hb[jj] = (4.5*pdfn(cdfni(tau[jj]))^4/(nn*(2*cdfni(tau[jj])^2+1)^2))^0.2;
        jj = jj + 1;
    endo;

    struct qfitControl qCtl;
    qCtl = qfitControlCreate();
    qCtl.const = 0;
    qCtl.verbose = 0;

    struct qfitOut qOutECM;
    qOutECM = quantileFit(Y_ecm, ONEX_ecm, tau, 0, qCtl);
    bt_ecm = qOutECM.beta;

    fh_ecm = zeros(ss, 1);
    jj = 1;
    do until jj > ss;
        uu_ecm = Y_ecm - ONEX_ecm*bt_ecm[., jj];
        fh_ecm[jj] = meanc(pdfn(-uu_ecm/hb[jj]))/hb[jj];
        jj = jj + 1;
    endo;

    D_ecm = ONEX_ecm'*ONEX_ecm / N_ecm;
    D_inv_ecm = _qardlSafeInv(D_ecm, "qardlECMX", "ECM moment matrix");

    if cov_type $== "iid";
        mtau = tau.*tau';
        mfh = fh_ecm.*fh_ecm';
        cc = zeros(ss, ss);
        jj = 1;
        do until jj > ss;
            ii = 1;
            do until ii > ss;
                psu = zeros(2, 1);
                psu[1] = tau[jj];
                psu[2] = tau[ii];
                cc[jj, ii] = (minc(psu) - mtau[jj, ii]) / mfh[jj, ii];
                ii = ii + 1;
            endo;
            jj = jj + 1;
        endo;
        rho_cov = cc * D_inv_ecm[2, 2] / N_ecm;
        alpha_cov = cc * D_inv_ecm[1, 1] / N_ecm;
    else;
        cov_lags = hac_lags;
        if cov_type $== "robust";
            cov_lags = 0;
        elseif cov_lags == 0;
            cov_lags = _qardlAutomaticHACLags(N_ecm);
        endif;
        { alpha_cov, rho_cov } = _qardlECMCovSandwich(ONEX_ecm, Y_ecm, bt_ecm, tau,
                                                      fh_ecm, D_inv_ecm, cov_lags);
    endif;

    struct qardlECMOut qECMOut;
    qECMOut.tau = tau;
    qECMOut.p = ppp;
    qECMOut.q = qmax;
    qECMOut.nobs = N_ecm;
    qECMOut.k = k0;
    qECMOut.beta_lr = beta_lr_ols;
    qECMOut.rho_ols = rho_ols;
    qECMOut.alpha = bt_ecm[1, .]';
    qECMOut.rho = bt_ecm[2, .]';
    qECMOut.rho_cov = rho_cov;
    qECMOut.alpha_cov = alpha_cov;

    if print_results;
        call printQARDLECM(qECMOut, tau);
    endif;

    retp(qECMOut);
endp;

proc (2) = qardlAR2Sim(nnn, alpha, phi, rho, the0, the1);
    local gam, bes, eee1, eee2, eee, xxx, yyy, uuu, jjj;
    
    gam = the0 + the1;
    bes = gam/(1 - phi);
    
    // Generate data
    eee1= rndn(nnn+1, 1);
    eee2 = rndn(nnn, 1);
    eee = eee1[1:nnn];
    xxx = cumsumc(eee)~cumsumc(eee2);
    uuu = rndn(nnn, 1);
    yyy = zeros(nnn, 1);
    jjj = 2;
    
    do until jjj > nnn;
        yyy[jjj] = alpha + phi*yyy[jjj-1] + the0*xxx[jjj, 1] + the1*xxx[jjj-1, 1]
            + the0*xxx[jjj, 2] + the1*xxx[jjj-1, 2] + uuu[jjj];
        jjj = jjj + 1;
    endo;
    
    retp(yyy, xxx);
endp;

proc (0) = plotQARDL(struct qardlOut qaOut, tau = { 0.25, 0.5, 0.75 });
    local _beta, _gamma, _phi, _alpha, _rho, ntau, k, p, nCols;

    call _qardlValidateTau(tau, "plotQARDL");

    ntau = rows(tau);

    _beta  = qaOut.bigbt;
    _gamma = qaOut.gamma;
    _phi   = qaOut.phi;
    _alpha = qaOut.alpha;
    _rho   = qaOut.rho;

    // Get dimensions of model
    k = rows(_beta) / ntau;
    p = rows(_phi)  / ntau;

    if round(k) /= k or round(p) /= p;
        errorlog "plotQARDL: tau length does not match qaOut";
        end;
    endif;

    // Reshape parameter matrices
    _beta  = reshape(_beta,  ntau, k);
    _phi   = reshape(_phi,   ntau, p);
    _gamma = reshape(_gamma, ntau, k);

    // Set up graph controls
    struct plotControl myPlot;
    myPlot = plotSetQARDLDefaults(p, k);

    // 4-row layout: beta | gamma | phi | alpha+rho
    nCols = maxc(p|k);

    plotBetaGraphs(_beta,  k, p, tau, nCols, myPlot);
    plotGammaGraphs(_gamma, k, p, tau, nCols, myPlot);
    plotPhiGraphs(_phi,    k, p, tau, nCols, myPlot);
    plotAlphaRhoGraphs(_alpha, _rho, tau, nCols, myPlot);

    plotClearLayout();

endp;

proc (0) = plotBetaGraphs(_beta, k, p, tau, nCols, struct PlotControl myPlot);
    local vnames_beta, gp_indx;

    gp_indx = 1;
    vnames_beta = "\\beta_" $+ ntos(seqa(1, 1, k));

    for i(1, k, 1);
        plotLayout(4, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames_beta[i]);
        plotXY(myPlot, tau, _beta[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (0) = plotGammaGraphs(_gamma, k, p, tau, nCols, struct PlotControl myPlot);
    local vnames_gamma, gp_indx;

    gp_indx = maxc(k|p) + 1;
    vnames_gamma = "\\gamma_" $+ ntos(seqa(1, 1, k));

    for i(1, k, 1);
        plotLayout(4, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames_gamma[i]);
        plotXY(myPlot, tau, _gamma[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (0) = plotPhiGraphs(_phi, k, p, tau, nCols, struct plotControl myPlot);
    local vnames_phi, gp_indx;

    gp_indx = 2*maxc(k|p) + 1;
    vnames_phi = "\\phi_{t-" $+ ntos(seqa(1, 1, p)) $+ "}";

    for i(1, p, 1);
        plotLayout(4, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames_phi[i]);
        plotXY(myPlot, tau, _phi[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (0) = plotAlphaRhoGraphs(_alpha, _rho, tau, nCols, struct plotControl myPlot);
    local gp_indx;

    // Row 4, columns 1 and 2
    gp_indx = 3*nCols + 1;

    plotLayout(4, nCols, gp_indx);
    plotSetTitle(&myPlot, "\\alpha(\\tau)");
    plotXY(myPlot, tau, _alpha);

    plotLayout(4, nCols, gp_indx + 1);
    plotSetTitle(&myPlot, "\\rho(\\tau)");
    plotXY(myPlot, tau, _rho);
endp;

/*
**> plotQARDLbands
**
**  Purpose:    Plot quantile process curves with 95% asymptotic confidence
**              bands for long-run (beta), short-run (gamma), and AR (phi)
**              parameters.  Bands are point-wise: estimate +/- 1.96 * SE,
**              where SE is extracted from the diagonal of the covariance
**              matrices stored in the qardlOut struct.
**
**  Format:     plotQARDLbands(qaOut, tau);
**
**  Input:      qaOut       struct qardlOut returned by qardl().
**              tau         (ss x 1) vector of quantile indices.
*/
proc (0) = plotQARDLbands(struct qardlOut qaOut, tau = { 0.25, 0.5, 0.75 });
    local _beta, _gamma, _phi, ntau, k, p, nCols;
    local se_beta, se_gamma, se_phi;
    local lb_beta, ub_beta, lb_gamma, ub_gamma, lb_phi, ub_phi;

    call _qardlValidateTau(tau, "plotQARDLbands");

    ntau = rows(tau);

    _beta  = qaOut.bigbt;
    _gamma = qaOut.gamma;
    _phi   = qaOut.phi;

    // Recover dimensions
    k = rows(_beta) / ntau;
    p = rows(_phi)  / ntau;

    if round(k) /= k or round(p) /= p;
        errorlog "plotQARDLbands: tau length does not match qaOut";
        end;
    endif;

    // Reshape to (ntau x param)
    _beta  = reshape(_beta,  ntau, k);
    _phi   = reshape(_phi,   ntau, p);
    _gamma = reshape(_gamma, ntau, k);

    // Standard errors from covariance diagonals
    se_beta  = reshape(sqrt(diag(qaOut.bigbt_cov)),  ntau, k);
    se_phi   = reshape(sqrt(diag(qaOut.phi_cov)),    ntau, p);
    se_gamma = reshape(sqrt(diag(qaOut.gamma_cov)),  ntau, k);

    // 95% pointwise bands
    lb_beta  = _beta  - 1.96 * se_beta;
    ub_beta  = _beta  + 1.96 * se_beta;
    lb_gamma = _gamma - 1.96 * se_gamma;
    ub_gamma = _gamma + 1.96 * se_gamma;
    lb_phi   = _phi   - 1.96 * se_phi;
    ub_phi   = _phi   + 1.96 * se_phi;

    // Set up graph controls
    struct plotControl myPlot;
    myPlot = plotSetQARDLDefaults(p, k);

    // Line styles: dashed | solid | dashed  (lower, estimate, upper)
    plotSetLineStyle(&myPlot, 2|1|2);

    nCols = maxc(p|k);

    plotBetaBandGraphs(_beta, lb_beta, ub_beta, k, p, tau, nCols, myPlot);
    plotGammaBandGraphs(_gamma, lb_gamma, ub_gamma, k, p, tau, nCols, myPlot);
    plotPhiBandGraphs(_phi, lb_phi, ub_phi, k, p, tau, nCols, myPlot);

    plotClearLayout();

endp;

proc (0) = plotBetaBandGraphs(_beta, lb, ub, k, p, tau, nCols, struct plotControl myPlot);
    local vnames, gp_indx;

    gp_indx = 1;
    vnames = "\\beta_" $+ ntos(seqa(1, 1, k));

    for i(1, k, 1);
        plotLayout(3, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames[i]);
        plotXY(myPlot, tau, lb[., i]~_beta[., i]~ub[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (0) = plotGammaBandGraphs(_gamma, lb, ub, k, p, tau, nCols, struct plotControl myPlot);
    local vnames, gp_indx;

    gp_indx = maxc(k|p) + 1;
    vnames = "\\gamma_" $+ ntos(seqa(1, 1, k));

    for i(1, k, 1);
        plotLayout(3, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames[i]);
        plotXY(myPlot, tau, lb[., i]~_gamma[., i]~ub[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (0) = plotPhiBandGraphs(_phi, lb, ub, k, p, tau, nCols, struct plotControl myPlot);
    local vnames, gp_indx;

    gp_indx = 2*maxc(k|p) + 1;
    vnames = "\\phi_{t-" $+ ntos(seqa(1, 1, p)) $+ "}";

    for i(1, p, 1);
        plotLayout(3, nCols, gp_indx);
        plotSetTitle(&myPlot, vnames[i]);
        plotXY(myPlot, tau, lb[., i]~_phi[., i]~ub[., i]);
        gp_indx = gp_indx + 1;
    endfor;
endp;

proc (struct plotControl) = plotSetQARDLDefaults(p, k);
    local _font, title_size, axis_size, label_size;
    
    _font = "Arial";
    title_size = 18 - maxc(k|p);
    axis_size = 16 - maxc(k|p);
    label_size = 14 - maxc(k|p);
    
    struct plotControl myPlot;
    myPlot = plotGetDefaults("xy");
    plotSetTitle(&myPlot, "", _font, title_size);
    
    plotSetTextInterpreter(&myPlot, "LaTex", "all");
    
    plotSetXLabel(&myPlot, "\\tau", _font, axis_size);
    
    plotSetTicLabelFont(&myPlot, _font, label_size);
    
    plotSetYTicCount(&myPlot, 5);
    
    retp(myPlot);
endp;

/*
**> plotRollingQARDLECM
**
**  Purpose:    Plot rolling-window QARDL-ECM estimates.  Produces a 2-row
**              layout: top row shows rho(tau,t) with +/-1.96*SE bands; bottom
**              row shows alpha(tau,t) with bands.  One panel per quantile.
**
**  Format:     plotRollingQARDLECM(rECMOut);
**              plotRollingQARDLECM(rECMOut, tau = { 0.25, 0.5, 0.75 });
**              plotRollingQARDLECM(rECMOut, tau, dates);
**
**  Input:      rECMOut     struct rollingQardlECMOut returned by rollingQardlECM().
**              tau         (ss x 1) quantile vector.
**              dates       (num_est x 1) vector of date values for x-axis.
**                          Pass 0 (default) to use window indices 1, 2, ...
**
**  Developed:  April 2026
*/
proc (0) = plotRollingQARDLECM(struct rollingQardlECMOut rECMOut, tau = { 0.25, 0.5, 0.75 }, dates = 0);
    local ss, num_est, t_axis, jj;
    local rho_lb, rho_ub, alpha_lb, alpha_ub;
    local _font, title_size, axis_size, label_size;
    struct plotControl myPlot;

    call _qardlValidateTau(tau, "plotRollingQARDLECM");

    ss      = rows(tau);
    num_est = rows(rECMOut.rho);

    if cols(rECMOut.rho) /= ss or cols(rECMOut.alpha) /= ss;
        errorlog "plotRollingQARDLECM: tau length does not match rolling output";
        end;
    endif;

    // Build time axis
    if scalmiss(dates) or (rows(dates) == 1 and dates == 0);
        t_axis = seqa(1, 1, num_est);
    else;
        if rows(dates) /= num_est;
            errorlog "plotRollingQARDLECM: dates must have one row per rolling estimate";
            end;
        endif;
        t_axis = dates;
    endif;

    // 95% pointwise bands
    rho_lb   = rECMOut.rho   - 1.96 * rECMOut.rho_se;
    rho_ub   = rECMOut.rho   + 1.96 * rECMOut.rho_se;
    alpha_lb = rECMOut.alpha - 1.96 * rECMOut.alpha_se;
    alpha_ub = rECMOut.alpha + 1.96 * rECMOut.alpha_se;

    _font      = "Arial";
    title_size = 16 - ss;
    axis_size  = 14 - ss;
    label_size = 12 - ss;

    myPlot = plotGetDefaults("xy");
    plotSetTitle(&myPlot, "", _font, title_size);
    plotSetTextInterpreter(&myPlot, "LaTex", "all");
    plotSetXLabel(&myPlot, "Window", _font, axis_size);
    plotSetTicLabelFont(&myPlot, _font, label_size);
    plotSetYTicCount(&myPlot, 5);
    plotSetLineStyle(&myPlot, 2|1|2);

    for jj(1, ss, 1);
        plotLayout(2, ss, jj);
        plotSetTitle(&myPlot, "\\rho(" $+ ntos(tau[jj]) $+ ")");
        plotXY(myPlot, t_axis, rho_lb[., jj]~rECMOut.rho[., jj]~rho_ub[., jj]);

        plotLayout(2, ss, ss + jj);
        plotSetTitle(&myPlot, "\\alpha(" $+ ntos(tau[jj]) $+ ")");
        plotXY(myPlot, t_axis, alpha_lb[., jj]~rECMOut.alpha[., jj]~alpha_ub[., jj]);
    endfor;

    plotClearLayout();
endp;

/*
**> plotRollingQARDL
**
**  Purpose:    Plot rolling-window QARDL long-run beta estimates with +/-1.96*SE
**              bands.  Produces a grid with ss rows (one per quantile) and k
**              columns (one per x variable).
**
**  Format:     plotRollingQARDL(rqaOut);
**              plotRollingQARDL(rqaOut, tau = { 0.25, 0.5, 0.75 });
**              plotRollingQARDL(rqaOut, tau, dates);
**
**  Input:      rqaOut      struct rollingQardlOut returned by rollingQardl().
**              tau         (ss x 1) quantile vector.
**              dates       (num_est x 1) x-axis values.  Pass 0 for 1..num_est.
**
**  Developed:  April 2026
*/
proc (0) = plotRollingQARDL(struct rollingQardlOut rqaOut, tau = { 0.25, 0.5, 0.75 }, dates = 0);
    local ss, num_est, k, t_axis, jj, vv;
    local beta_v, se_v, lb, ub;
    local _font, title_size, axis_size, label_size;
    struct plotControl myPlot;

    local _dims;
    call _qardlValidateTau(tau, "plotRollingQARDL");

    ss  = rows(tau);
    _dims   = getorders(rqaOut.bigbt);  // [k, num_est, num_tau]
    k       = _dims[1];
    num_est = _dims[2];

    if _dims[3] /= ss;
        errorlog "plotRollingQARDL: tau length does not match rolling output";
        end;
    endif;

    // Build time axis
    if scalmiss(dates) or (rows(dates) == 1 and dates == 0);
        t_axis = seqa(1, 1, num_est);
    else;
        if rows(dates) /= num_est;
            errorlog "plotRollingQARDL: dates must have one row per rolling estimate";
            end;
        endif;
        t_axis = dates;
    endif;

    _font      = "Arial";
    title_size = 16 - maxc(k|ss);
    axis_size  = 14 - maxc(k|ss);
    label_size = 12 - maxc(k|ss);

    myPlot = plotGetDefaults("xy");
    plotSetTitle(&myPlot, "", _font, title_size);
    plotSetTextInterpreter(&myPlot, "LaTex", "all");
    plotSetXLabel(&myPlot, "Window", _font, axis_size);
    plotSetTicLabelFont(&myPlot, _font, label_size);
    plotSetYTicCount(&myPlot, 5);
    plotSetLineStyle(&myPlot, 2|1|2);

    // Grid: rows = quantiles, cols = x variables
    for jj(1, ss, 1);
        for vv(1, k, 1);
            // Extract rolling beta and SE for variable vv at quantile jj
            // Arrays indexed [variable, window, quantile]
            beta_v = squeeze(rqaOut.bigbt[vv, ., jj]);
            se_v   = squeeze(rqaOut.bigbt_se[vv, ., jj]);
            lb     = beta_v - 1.96 * se_v;
            ub     = beta_v + 1.96 * se_v;

            plotLayout(ss, k, (jj-1)*k + vv);
            plotSetTitle(&myPlot, "\\beta_" $+ ntos(vv) $+ "(\\tau=" $+ ntos(tau[jj]) $+ ")");
            plotXY(myPlot, t_axis, lb~beta_v~ub);
        endfor;
    endfor;

    plotClearLayout();
endp;

proc (struct rollingQardlOut) = rollingQardl(data, pend, qend, tau, struct waldTestRestrictions wCtl);
    local window_size, k, T, num_est, num_tau, st, fin_obs, pst, qst,
        beta_array, phi_array, gamma_array, beta_se, gamma_se, phi_se, data_subset,
    wald_beta, pv_beta, wald_gamma, wald_phi, pv_gamma, pv_phi, c_indx, bigR_phi_test;

    // Struct declared once at proc scope (not inside the loop)
    struct qardlOut qaOut;
    struct rollingQardlOut rqaOut;

    call _qardlValidateSearchInputs(data, pend, qend, tau, "rollingQardl");
    
    // qardl order estimation
    // Estimated using full sample
    { pst, qst } = pqorder(data, pend, qend, "bic");
    
    // Select window size
    window_size = trunc(0.1*rows(data));
    if window_size <= maxc(pst|qst) + 2;
        errorlog "rollingQardl: rolling window is too short for selected lag orders";
        end;
    endif;
    
    // Dimensions
    k = cols(data) - 1;
    T = rows(data);
    num_est = T-window_size;
    num_tau = rows(tau);

    call _qardlValidateRestrictionShape(wCtl.bigR_beta, wCtl.smlr_beta, k*num_tau, "rollingQardl: beta restrictions");
    call _qardlValidateRestrictionShape(wCtl.bigR_phi, wCtl.smlr_phi, pend*num_tau, "rollingQardl: phi restrictions");
    call _qardlValidateRestrictionShape(wCtl.bigR_gamma, wCtl.smlr_gamma, k*num_tau, "rollingQardl: gamma restrictions");
    
    // Starting indeces for rolling data
    st = 1;
    fin_obs = window_size;
    
    // Initialize storage arrays
    beta_array = arrayinit(k|num_est|num_tau, 0);
    gamma_array = beta_array;
    phi_array = arrayinit(pst|num_est|num_tau, 0);
    
    beta_se = beta_array;
    gamma_se = gamma_array;
    phi_se = phi_array;
    
    // Wald test matrices
    wald_beta = zeros(num_est, 1);
    wald_phi = zeros(num_est, 1 );
    wald_gamma = zeros(num_est, 1);
    pv_beta = zeros(num_est, 1);
    pv_phi = zeros(num_est, 1);
    pv_gamma = zeros(num_est, 1);
    
    do while fin_obs<rows(data);
        
        // Get data subset
        data_subset = data[st:fin_obs, .];
        
        // Parameter estimation
        qaOut = qardl(data_subset, pst, qst, tau, "iid", 0, 0);
        
        // Wald tests
        // Long-run parameter (beta) testing
        { wald_beta[st], pv_beta[st] } = wtestlrb(qaOut.bigbt, qaOut.bigbt_cov, wCtl.bigR_beta, wCtl.smlr_beta, data_subset);
        
        // Short-run parameter (phi) testing
        bigR_phi_test = wCtl.bigR_phi;
        if pst < pend;
            c_indx = seqa(pst*rows(tau)+1, 1, cols(wCtl.bigR_phi)-(pst*rows(tau)));
            bigR_phi_test = delcols(wCtl.bigR_phi, c_indx);
        endif;   
        { wald_phi[st], pv_phi[st] } = wtestsrp(qaOut.phi, qaOut.phi_cov, bigR_phi_test, wCtl.smlr_phi, data_subset);
        
        // Short-run parameter (gamma) testing
        { wald_gamma[st], pv_gamma[st] } = wtestsrg(qaOut.gamma, qaOut.gamma_cov, wCtl.bigR_gamma, wCtl.smlr_gamma, data_subset);
        
        // Extract estimates
        beta_array[., st, .] = _getBetaArray(qaOut.bigbt, num_tau, k);
        gamma_array[., st, .] = _getGammaArray(qaOut.gamma, num_tau, k);
        phi_array[., st, .] = _getPhiArray(qaOut.phi, num_tau, pst);
        
        // Standard errors
        beta_se[., st, .] = _getBetaSE(qaOut.bigbt_cov, num_tau, k);
        gamma_se[., st, .] = _getGammaSE(qaOut.gamma_cov, num_tau, k);
        phi_se[., st, .] = _getPhiSE(qaOut.phi_cov, num_tau, pst);

        st = st + 1;
        fin_obs = fin_obs + 1;
    endo;
    
    // Output structure for results
    rqaOut.bigbt = beta_array;
    rqaOut.bigbt_se = beta_se;
    rqaOut.phi = phi_array;
    rqaOut.phi_se = phi_se;
    rqaOut.gamma = gamma_array;
    rqaOut.gamma_se = gamma_se;
    
    // Wald Test Results
    rqaOut.rWaldOut.wald_gamma = wald_gamma;
    rqaOut.rWaldOut.pv_gamma = pv_gamma;
    rqaOut.rWaldOut.wald_beta = wald_beta;
    rqaOut.rWaldOut.pv_beta = pv_beta;
    rqaOut.rWaldOut.wald_phi = wald_phi;
    rqaOut.rWaldOut.pv_phi = pv_phi;
    
    retp(rqaOut);
endp;

/*
**> rollingQardlECM
**
**  Purpose:    Rolling-window estimation of the QARDL-ECM model.  For each
**              window of length window_size = floor(0.1*T) rows, qardlECM()
**              is called and the resulting alpha(tau), rho(tau) and their
**              asymptotic standard errors are stored.
**
**  Format:     rECMOut = rollingQardlECM(data, ppp, qqq, tau);
**
**  Input:      data    (T x (1+k)) matrix.
**              ppp     scalar, AR lag order.
**              qqq     scalar, distributed-lag order.
**              tau     (ss x 1) vector of quantile levels.
**
**  Output:     rECMOut     struct rollingQardlECMOut with fields:
**                  .alpha      (num_est x ss) rolling intercept at each tau.
**                  .rho        (num_est x ss) rolling speed of adjustment.
**                  .alpha_se   (num_est x ss) SE of alpha.
**                  .rho_se     (num_est x ss) SE of rho.
**                  .beta_lr    (num_est x k) OLS long-run coefficients.
**                  .rho_ols    (num_est x 1) OLS speed of adjustment.
**
**  Developed:  March 2026
*/
proc (struct rollingQardlECMOut) = rollingQardlECM(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 });
    local window_size, k, T, num_est, ss, st, fin_obs;
    local alpha_mat, rho_mat, alpha_se_mat, rho_se_mat;
    local beta_lr_mat, rho_ols_vec;
    local data_subset;

    // Structs declared once at proc scope (not inside the loop)
    struct qardlECMOut qECMOut;
    struct rollingQardlECMOut rECMOut;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "rollingQardlECM");

    T          = rows(data);
    k          = cols(data) - 1;
    ss         = rows(tau);
    window_size = trunc(0.1 * T);
    if window_size <= maxc(ppp|qqq) + 2;
        errorlog "rollingQardlECM: rolling window is too short for selected lag orders";
        end;
    endif;
    num_est    = T - window_size;

    // Storage matrices: each row = one estimation window
    alpha_mat    = zeros(num_est, ss);
    rho_mat      = zeros(num_est, ss);
    alpha_se_mat = zeros(num_est, ss);
    rho_se_mat   = zeros(num_est, ss);
    beta_lr_mat  = zeros(num_est, k);
    rho_ols_vec  = zeros(num_est, 1);

    st      = 1;
    fin_obs = window_size;

    do while fin_obs < rows(data);

        data_subset = data[st:fin_obs, .];

        qECMOut = qardlECM(data_subset, ppp, qqq, tau, "iid", 0, 0);

        alpha_mat[st, .]    = qECMOut.alpha';
        rho_mat[st, .]      = qECMOut.rho';
        alpha_se_mat[st, .] = sqrt(diag(qECMOut.alpha_cov))';
        rho_se_mat[st, .]   = sqrt(diag(qECMOut.rho_cov))';
        beta_lr_mat[st, .]  = qECMOut.beta_lr';
        rho_ols_vec[st]     = qECMOut.rho_ols[1, 1];

        st      = st + 1;
        fin_obs = fin_obs + 1;
    endo;

    rECMOut.alpha    = alpha_mat;
    rECMOut.rho      = rho_mat;
    rECMOut.alpha_se = alpha_se_mat;
    rECMOut.rho_se   = rho_se_mat;
    rECMOut.beta_lr  = beta_lr_mat;
    rECMOut.rho_ols  = rho_ols_vec;

    retp(rECMOut);
endp;

proc (1) = _getBetaSE(_beta_cov, num_tau, k);
    local beta_se, beta_se_array;
    
    // Get  SE
    beta_se = sqrt(diag((_beta_cov)));
    
    // Reshape
    beta_se = reshape(beta_se, num_tau, k);
    
    beta_se_array = arrayinit(k|1|num_tau, 0);
    
    for i(1, k, 1);
        beta_se_array[i, ., .] = beta_se[., i]';
    endfor;
    
    retp(beta_se_array);
endp;

proc (1) = _getGammaSE(_gamma_cov, num_tau, k);
    local gamma_se, gamma_se_array;
    
    // Get  SE
    gamma_se = sqrt(diag((_gamma_cov)));
    
    // Reshape
    gamma_se = reshape(gamma_se, num_tau, k);
    
    gamma_se_array = arrayinit(k|1|num_tau, 0);
    
    for i(1, k, 1);
        gamma_se_array[i, ., .] = gamma_se[., i]';
    endfor;
    
    retp(gamma_se_array);
endp;

proc (1) = _getPhiSE(_phi_cov, num_tau, p);
    local phi_se, phi_se_array;
    
    // Get  SE
    phi_se = sqrt(diag((_phi_cov)));
    
    // Reshape
    phi_se = reshape(phi_se, num_tau, p);
    
    phi_se_array = arrayinit(p|1|num_tau, 0);
    
    for i(1, p, 1);
        phi_se_array[i, ., .] = phi_se[., i]';
    endfor;
    
    retp(phi_se_array);
endp;

proc (1) = _getBetaArray(_beta, num_tau, k);
    local beta_mat, beta_array;
    
    beta_mat = reshape(_beta, num_tau, k);
    
    beta_array = arrayinit(k|1|num_tau, 0);
    
    for i(1, k, 1);
        beta_array[i, ., .] = beta_mat[., i]';
    endfor;
    
    retp(beta_array);
endp;

proc (1) = _getGammaArray(_gamma, num_tau, k);
    local gamma_mat, gamma_array;
    
    gamma_mat = reshape(_gamma, num_tau, k);
    
    gamma_array = arrayinit(k|1|num_tau, 0);
    
    for i(1, k, 1);
        gamma_array[i, ., .] = gamma_mat[., i]';
    endfor;
    
    retp(gamma_array);
endp;

proc (1) = _getPhiArray(_phi, num_tau, p);
    local phi_mat, phi_array;

    phi_mat = reshape(_phi, num_tau, p);

    phi_array = arrayinit(p|1|num_tau, 0);

    for i(1, p, 1);
        phi_array[i, ., .] = phi_mat[., i]';
    endfor;

    retp(phi_array);
endp;

/*
**> printQARDL
**
**  Purpose:    Print a formatted summary table of QARDL estimation results,
**              including parameter estimates, asymptotic standard errors,
**              z-statistics, and two-sided p-values for all parameter sets.
**
**  Format:     printQARDL(qaOut, tau);
**
**  Input:      qaOut   struct, instance of qardlOut returned by qardl().
**
**              tau     (s x 1) vector of quantile levels used in estimation.
**
**  Output:     Prints to screen only. No return value.
**
**  Note:       The printed table has columns [tau, variable, estimate, SE,
**              z-stat, p-value]. For alpha and rho, the variable index is
**              replaced by a label column. P-values use the asymptotic
**              standard normal (z-test) as in qardl_pval().
**
**  Developed:  March 2026
*/

proc (0) = printQARDL(struct qardlOut qaOut, tau = { 0.25, 0.5, 0.75 });
    local ss, k, p, jj, ii, idx, level, alpha_ci, zcrit;
    local se_bt, se_phi, se_gam;
    local z_bt, z_phi, z_gam;
    local pv_bt, pv_phi, pv_gam;
    local lb, ub;

    ss = rows(tau);
    k  = rows(qaOut.bigbt) / ss;
    p  = rows(qaOut.phi)   / ss;
    level = 0.95;
    alpha_ci = 1 - level;
    zcrit = cdfni(1 - alpha_ci/2);

    se_bt  = sqrt(diag(qaOut.bigbt_cov));
    se_phi = sqrt(diag(qaOut.phi_cov));
    se_gam = sqrt(diag(qaOut.gamma_cov));

    z_bt  = qaOut.bigbt  ./ se_bt;
    z_phi = qaOut.phi    ./ se_phi;
    z_gam = qaOut.gamma  ./ se_gam;

    pv_bt  = 2 * cdfnc(abs(z_bt));
    pv_phi = 2 * cdfnc(abs(z_phi));
    pv_gam = 2 * cdfnc(abs(z_gam));

    print "================================================================================";
    print "QARDL Levels Estimator";
    print "================================================================================";
    sprintf("%-26s%12.0f        %-26s%12.0f", "No. of obs:", qaOut.nobs,
            "No. regressors:", qaOut.k);
    sprintf("%-26s%12.0f        %-26s%12.0f", "AR lags (p):", qaOut.p,
            "DL lags (q):", qaOut.q);
    sprintf("%-26s%12.0f        %-26s%12.4f", "No. quantiles:", ss,
            "CI level:", level);
    print "--------------------------------------------------------------------------------";
    print "Name                  Coeff.       Std. Err.      z-value       P>|z|           lb           ub";
    print "--------------------------------------------------------------------------------";

    jj = 1;
    do until jj > ss;
        sprintf("Tau = %8.4f", tau[jj]);

        ii = 1;
        do until ii > k;
            idx = (jj-1)*k + ii;
            lb = qaOut.bigbt[idx] - zcrit*se_bt[idx];
            ub = qaOut.bigbt[idx] + zcrit*se_bt[idx];
            sprintf("  beta_x%-4d%16.6f%15.6f%13.6f%12.6f%13.6f%13.6f",
                    ii, qaOut.bigbt[idx], se_bt[idx], z_bt[idx], pv_bt[idx], lb, ub);
            ii = ii + 1;
        endo;

        ii = 1;
        do until ii > k;
            idx = (jj-1)*k + ii;
            lb = qaOut.gamma[idx] - zcrit*se_gam[idx];
            ub = qaOut.gamma[idx] + zcrit*se_gam[idx];
            sprintf("  gamma_x%-3d%16.6f%15.6f%13.6f%12.6f%13.6f%13.6f",
                    ii, qaOut.gamma[idx], se_gam[idx], z_gam[idx], pv_gam[idx], lb, ub);
            ii = ii + 1;
        endo;

        ii = 1;
        do until ii > p;
            idx = (jj-1)*p + ii;
            lb = qaOut.phi[idx] - zcrit*se_phi[idx];
            ub = qaOut.phi[idx] + zcrit*se_phi[idx];
            sprintf("  phi_l%-5d%16.6f%15.6f%13.6f%12.6f%13.6f%13.6f",
                    ii, qaOut.phi[idx], se_phi[idx], z_phi[idx], pv_phi[idx], lb, ub);
            ii = ii + 1;
        endo;

        sprintf("  alpha     %16.6f", qaOut.alpha[jj]);
        sprintf("  rho       %16.6f", qaOut.rho[jj]);
        print "--------------------------------------------------------------------------------";
        jj = jj + 1;
    endo;

    print "================================================================================";

endp;

/*
**> printQARDLECM
**
**  Purpose:    Print a formatted results table for a qardlECMOut instance.
**              Shows OLS long-run coefficients, then quantile-varying alpha(tau)
**              and rho(tau) with asymptotic standard errors, z-statistics,
**              p-values, and confidence limits.
**
**  Format:     printQARDLECM(qECMOut);
**              printQARDLECM(qECMOut, tau = { 0.25, 0.5, 0.75 });
**
**  Input:      qECMOut     struct qardlECMOut returned by qardlECM().
**              tau         (ss x 1) vector of quantile levels.
**
**  Developed:  April 2026
*/
proc (0) = printQARDLECM(struct qardlECMOut qECMOut, tau = { 0.25, 0.5, 0.75 });
    local ss, k, jj, level, alpha_ci, zcrit, lb, ub;
    local se_alpha, se_rho;
    local z_alpha, z_rho;
    local pv_alpha, pv_rho;

    ss = rows(tau);
    k  = rows(qECMOut.beta_lr);
    level = 0.95;
    alpha_ci = 1 - level;
    zcrit = cdfni(1 - alpha_ci/2);

    se_alpha = sqrt(diag(qECMOut.alpha_cov));
    se_rho   = sqrt(diag(qECMOut.rho_cov));

    z_alpha  = qECMOut.alpha ./ se_alpha;
    z_rho    = qECMOut.rho   ./ se_rho;
    pv_alpha = 2 * cdfnc(abs(z_alpha));
    pv_rho   = 2 * cdfnc(abs(z_rho));

    print "================================================================================";
    print "QARDL-ECM Estimator (Two-Step)";
    print "================================================================================";
    sprintf("%-26s%12.0f        %-26s%12.0f", "No. of obs:", qECMOut.nobs,
            "No. regressors:", qECMOut.k);
    sprintf("%-26s%12.0f        %-26s%12.0f", "AR lags (p):", qECMOut.p,
            "DL lags (q):", qECMOut.q);
    sprintf("%-26s%12.0f        %-26s%12.4f", "No. quantiles:", ss,
            "CI level:", level);
    print "--------------------------------------------------------------------------------";

    print "";
    print "Step 1 - OLS Long-Run Coefficients";
    print "--------------------------------------------------------------------------------";
    print "Name                  Coeff.";
    jj = 1;
    do until jj > k;
        sprintf("  x%-4d      %16.6f", jj, qECMOut.beta_lr[jj]);
        jj = jj + 1;
    endo;
    sprintf("  rho_OLS   %16.6f", qECMOut.rho_ols[1, 1]);

    print "";
    print "Step 2 - ECM Quantile Parameters";
    print "--------------------------------------------------------------------------------";
    print "Name                  Coeff.       Std. Err.      z-value       P>|z|           lb           ub";
    print "--------------------------------------------------------------------------------";

    jj = 1;
    do until jj > ss;
        sprintf("Tau = %8.4f", tau[jj]);

        lb = qECMOut.alpha[jj] - zcrit*se_alpha[jj];
        ub = qECMOut.alpha[jj] + zcrit*se_alpha[jj];
        sprintf("  alpha     %16.6f%15.6f%13.6f%12.6f%13.6f%13.6f",
                qECMOut.alpha[jj], se_alpha[jj], z_alpha[jj], pv_alpha[jj], lb, ub);

        lb = qECMOut.rho[jj] - zcrit*se_rho[jj];
        ub = qECMOut.rho[jj] + zcrit*se_rho[jj];
        sprintf("  rho       %16.6f%15.6f%13.6f%12.6f%13.6f%13.6f",
                qECMOut.rho[jj], se_rho[jj], z_rho[jj], pv_rho[jj], lb, ub);

        print "--------------------------------------------------------------------------------";
        jj = jj + 1;
    endo;

    print "================================================================================";

endp;
/*
**> saveQARDLECMResults
**
**  Purpose:    Export QARDL-ECM estimation results to CSV files.
**              Writes OLS long-run coefficients and quantile-varying alpha(tau)
**              and rho(tau) with standard errors, z-statistics, and p-values.
**
**  Format:     saveQARDLECMResults(qECMOut);
**              saveQARDLECMResults(qECMOut, tau = { 0.25, 0.5, 0.75 }, outdir = ".");
**
**  Input:      qECMOut     struct qardlECMOut returned by qardlECM().
**              tau         (ss x 1) vector of quantile levels.
**              outdir      string, output directory.  Default: current directory.
**
**  Output:     Writes two CSV files:
**                  <outdir>/qardl_ecm_lr.csv   (OLS long-run: var_index, beta_lr)
**                  <outdir>/qardl_ecm_qr.csv   (QR ECM: tau, alpha, se_alpha,
**                                               z_alpha, pval_alpha, rho, se_rho,
**                                               z_rho, pval_rho)
**
**  Developed:  April 2026
*/
proc (0) = saveQARDLECMResults(struct qardlECMOut qECMOut, tau = { 0.25, 0.5, 0.75 }, outdir = ".");
    local ss, k, jj, sep, fpath;
    local se_alpha, se_rho, z_alpha, z_rho, pv_alpha, pv_rho;
    local out_lr, out_qr;

    call _qardlValidateTau(tau, "saveQARDLECMResults");

    ss = rows(tau);
    k  = rows(qECMOut.beta_lr);

    if rows(qECMOut.alpha) /= ss or rows(qECMOut.rho) /= ss;
        errorlog "saveQARDLECMResults: tau length does not match qECMOut";
        end;
    endif;

    // Ensure outdir ends with separator
    if strsect(outdir, strlen(outdir), 1) $/= "/";
        outdir = outdir $+ "/";
    endif;

    // OLS long-run CSV: [var_index, beta_lr]
    out_lr = seqa(1, 1, k)~qECMOut.beta_lr;
    fpath  = outdir $+ "qardl_ecm_lr.csv";
    _saveCSV(out_lr, "var_index,beta_lr", fpath);

    // Quantile ECM CSV: [tau, alpha, se_alpha, z_alpha, pval_alpha, rho, se_rho, z_rho, pval_rho]
    se_alpha = sqrt(diag(qECMOut.alpha_cov));
    se_rho   = sqrt(diag(qECMOut.rho_cov));
    z_alpha  = qECMOut.alpha ./ se_alpha;
    z_rho    = qECMOut.rho   ./ se_rho;
    pv_alpha = 2 * cdfnc(abs(z_alpha));
    pv_rho   = 2 * cdfnc(abs(z_rho));

    out_qr = tau~qECMOut.alpha~se_alpha~z_alpha~pv_alpha~qECMOut.rho~se_rho~z_rho~pv_rho;
    fpath  = outdir $+ "qardl_ecm_qr.csv";
    _saveCSV(out_qr, "tau,alpha,se_alpha,z_alpha,pval_alpha,rho,se_rho,z_rho,pval_rho", fpath);

    print "saveQARDLECMResults: wrote results to " $+ outdir;

endp;

/*
**> saveQARDLResults
**
**  Purpose:    Export QARDL estimation results to CSV files.  One file is
**              written per parameter group (beta, gamma, phi, ecm).  Each
**              file contains columns: tau, param_index, estimate, se, z, pval.
**
**  Format:     saveQARDLResults(qaOut, tau, outdir);
**
**  Input:      qaOut       struct qardlOut returned by qardl().
**
**              tau         (ss x 1) vector of quantile levels.
**
**              outdir      string, output directory path.  A trailing path
**                          separator is added automatically if absent.
**                          Pass "." to write to the current working directory.
**
**  Output:     Writes four CSV files:
**                  <outdir>/qardl_beta.csv
**                  <outdir>/qardl_gamma.csv
**                  <outdir>/qardl_phi.csv
**                  <outdir>/qardl_ecm.csv
**
**  Developed:  March 2026
*/
proc (0) = saveQARDLResults(struct qardlOut qaOut, tau = { 0.25, 0.5, 0.75 }, outdir = ".");
    local ss, k, p;
    local se_beta, se_gamma, se_phi;
    local _beta, _gamma, _phi;
    local z_beta, z_gamma, z_phi;
    local pv_beta, pv_gamma, pv_phi;
    local out_beta, out_gamma, out_phi, out_ecm;
    local jj, ii, row;
    local fpath, sep;

    call _qardlValidateTau(tau, "saveQARDLResults");

    ss = rows(tau);

    _beta  = qaOut.bigbt;
    _gamma = qaOut.gamma;
    _phi   = qaOut.phi;

    k = rows(_beta) / ss;
    p = rows(_phi)  / ss;

    if round(k) /= k or round(p) /= p;
        errorlog "saveQARDLResults: tau length does not match qaOut";
        end;
    endif;

    // Reshape to (ss x param)
    _beta  = reshape(_beta,  ss, k);
    _gamma = reshape(_gamma, ss, k);
    _phi   = reshape(_phi,   ss, p);

    // Standard errors
    se_beta  = reshape(sqrt(diag(qaOut.bigbt_cov)),  ss, k);
    se_gamma = reshape(sqrt(diag(qaOut.gamma_cov)),  ss, k);
    se_phi   = reshape(sqrt(diag(qaOut.phi_cov)),    ss, p);

    // z-statistics and p-values
    z_beta   = _beta  ./ se_beta;
    z_gamma  = _gamma ./ se_gamma;
    z_phi    = _phi   ./ se_phi;

    pv_beta  = 2 * cdfnc(abs(z_beta));
    pv_gamma = 2 * cdfnc(abs(z_gamma));
    pv_phi   = 2 * cdfnc(abs(z_phi));

    // Ensure outdir ends with a separator
    if strsect(outdir, strlen(outdir), 1) $/= "/";
        outdir = outdir $+ "/";
    endif;

    // --- Write beta CSV ---
    // Rows: (tau, param_index, estimate, se, z, pval)
    out_beta = zeros(ss * k, 6);
    row = 1;
    jj = 1;
    do until jj > ss;
        ii = 1;
        do until ii > k;
            out_beta[row, 1] = tau[jj];
            out_beta[row, 2] = ii;
            out_beta[row, 3] = _beta[jj, ii];
            out_beta[row, 4] = se_beta[jj, ii];
            out_beta[row, 5] = z_beta[jj, ii];
            out_beta[row, 6] = pv_beta[jj, ii];
            row = row + 1;
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;
    fpath = outdir $+ "qardl_beta.csv";
    _saveCSV(out_beta, "tau,param_index,estimate,se,z,pval", fpath);

    // --- Write gamma CSV ---
    out_gamma = zeros(ss * k, 6);
    row = 1;
    jj = 1;
    do until jj > ss;
        ii = 1;
        do until ii > k;
            out_gamma[row, 1] = tau[jj];
            out_gamma[row, 2] = ii;
            out_gamma[row, 3] = _gamma[jj, ii];
            out_gamma[row, 4] = se_gamma[jj, ii];
            out_gamma[row, 5] = z_gamma[jj, ii];
            out_gamma[row, 6] = pv_gamma[jj, ii];
            row = row + 1;
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;
    fpath = outdir $+ "qardl_gamma.csv";
    _saveCSV(out_gamma, "tau,param_index,estimate,se,z,pval", fpath);

    // --- Write phi CSV ---
    out_phi = zeros(ss * p, 6);
    row = 1;
    jj = 1;
    do until jj > ss;
        ii = 1;
        do until ii > p;
            out_phi[row, 1] = tau[jj];
            out_phi[row, 2] = ii;
            out_phi[row, 3] = _phi[jj, ii];
            out_phi[row, 4] = se_phi[jj, ii];
            out_phi[row, 5] = z_phi[jj, ii];
            out_phi[row, 6] = pv_phi[jj, ii];
            row = row + 1;
            ii = ii + 1;
        endo;
        jj = jj + 1;
    endo;
    fpath = outdir $+ "qardl_phi.csv";
    _saveCSV(out_phi, "tau,param_index,estimate,se,z,pval", fpath);

    // --- Write ECM CSV (alpha and rho, no SE available in qardlOut) ---
    out_ecm = zeros(ss, 3);
    out_ecm[., 1] = tau;
    out_ecm[., 2] = qaOut.alpha;
    out_ecm[., 3] = qaOut.rho;
    fpath = outdir $+ "qardl_ecm.csv";
    _saveCSV(out_ecm, "tau,alpha,rho", fpath);

    print "saveQARDLResults: wrote results to " $+ outdir;

endp;

// Helper: write numeric matrix with header line to a CSV file
proc (0) = _saveCSV(mat, header, fpath);
    local fid, nr, nc, jj, ii, csv_row, ret;

    fid = fopen(fpath, "w");

    if fid == -1;
        errorlog "saveQARDLResults: could not open " $+ fpath;
        end;
    endif;

    // Write header
    ret = fputs(fid, header $+ "\n");

    // Write data rows
    nr = rows(mat);
    nc = cols(mat);
    jj = 1;
    do until jj > nr;
        csv_row = "";
        ii = 1;
        do until ii > nc;
            if ii > 1;
                csv_row = csv_row $+ ",";
            endif;
            csv_row = csv_row $+ ftos(mat[jj, ii], "%g", 1, 0);
            ii = ii + 1;
        endo;
        ret = fputs(fid, csv_row $+ "\n");
        jj = jj + 1;
    endo;

    ret = close(fid);
endp;

/*
**> blockBootstrapQARDL
**
**  Purpose:    Compute bootstrap confidence intervals for QARDL parameter
**              estimates using the moving-block bootstrap (Kunsch 1989;
**              Liu & Singh 1992).  Resampling blocks of consecutive
**              observations preserves the short-run serial dependence
**              structure of the data.
**
**  Format:     { ci_beta, ci_gamma, ci_phi } =
**                  blockBootstrapQARDL(data, ppp, qqq);
**              { ci_beta, ci_gamma, ci_phi } =
**                  blockBootstrapQARDL(data, ppp, qqq, tau, B, blk_len, alpha);
**              { ci_beta, ci_gamma, ci_phi } =
**                  blockBootstrapQARDL(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 },
**                                      B = 999, blk_len = 0, alpha = 0.05);
**
**  Input:      data        (T x (1+k)) matrix.
**
**              ppp         scalar, AR lag order.
**
**              qqq         scalar, distributed-lag order.
**
**              tau         (ss x 1) vector of quantile levels.
**                          Default: { 0.25, 0.5, 0.75 }.
**
**              B           scalar, number of bootstrap replications.
**                          Default: 999.
**
**              blk_len     scalar, block length.  0 or omitted =>
**                          auto-select floor(T^(1/3)).  Default: 0.
**
**              alpha       scalar, confidence level in (0,1).
**                          Default: 0.05 (95% intervals).
**
**  Output:     ci_beta     (k*ss x 2) matrix.  Each row is one (tau,param)
**                          combination; columns are [lower, upper] bounds.
**
**              ci_gamma    (k*ss x 2) confidence intervals for gamma.
**
**              ci_phi      (p*ss x 2) confidence intervals for phi.
**
**  Remarks:    The bootstrap resamples blocks of length blk_len with
**              replacement and stacks them to form a pseudo-sample of
**              length T.  qardl() is re-estimated on each pseudo-sample.
**              The (alpha/2) and (1-alpha/2) empirical quantiles of the
**              B bootstrap draws are returned as the CI bounds.
**
**              The procedure uses rndu() for random block starts; results
**              are NOT reproducible unless the seed is set by the caller
**              via rndseed.
**
**  Developed:  March 2026
*/
proc (3) = blockBootstrapQARDL(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, B = 999, blk_len = 0, alpha = 0.05);
    local T, k0, ss, jj, ii, bbb;
    local n_blks, starts, idx, boot_data, idx_first, idx_last;
    local dim_beta, dim_phi, dim_gamma;
    local boot_beta, boot_gamma, boot_phi;
    local ci_beta, ci_gamma, ci_phi;
    local q_lo, q_hi;

    // Struct declared once at proc scope (not inside the loop)
    struct qardlOut qa_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDL");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDL: B must be a positive integer";
        end;
    endif;

    if rows(blk_len) * cols(blk_len) /= 1 or blk_len < 0 or round(blk_len) /= blk_len;
        errorlog "blockBootstrapQARDL: blk_len must be a non-negative integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDL: alpha must be a scalar in (0, 1)";
        end;
    endif;

    T   = rows(data);
    k0  = cols(data) - 1;
    ss  = rows(tau);

    // Default block length
    if blk_len <= 0 or scalmiss(blk_len);
        blk_len = trunc(T^(1/3));
        if blk_len < 2;
            blk_len = 2;
        endif;
    endif;

    // Number of blocks needed to cover T obs
    n_blks = ceil(T / blk_len);

    // Storage for bootstrap parameter vectors
    dim_beta  = k0 * ss;
    dim_gamma = k0 * ss;
    dim_phi   = ppp * ss;

    boot_beta  = zeros(B, dim_beta);
    boot_gamma = zeros(B, dim_gamma);
    boot_phi   = zeros(B, dim_phi);

    bbb = 1;
    do until bbb > B;

        // Draw n_blks random block starts (uniform on 1 to T-blk_len+1)
        starts = ceil(rndu(n_blks, 1) * (T - blk_len + 1));

        // Build pseudo-sample by concatenating blocks, then trim to T
        idx = zeros(n_blks*blk_len, 1);
        jj = 1;
        do until jj > n_blks;
            idx_first = (jj-1)*blk_len + 1;
            idx_last  = jj*blk_len;
            idx[idx_first:idx_last] = seqa(starts[jj], 1, blk_len);
            jj = jj + 1;
        endo;
        idx = idx[1:T, .];

        boot_data = data[idx, .];

        qa_b = qardl(boot_data, ppp, qqq, tau, "iid", 0, 0);

        boot_beta[bbb, .]  = qa_b.bigbt';
        boot_gamma[bbb, .] = qa_b.gamma';
        boot_phi[bbb, .]   = qa_b.phi';

        bbb = bbb + 1;
    endo;

    // Empirical quantile CI bounds
    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_beta  = zeros(dim_beta,  2);
    ci_gamma = zeros(dim_gamma, 2);
    ci_phi   = zeros(dim_phi,   2);

    jj = 1;
    do until jj > dim_beta;
        ci_beta[jj, 1] = quantile(boot_beta[., jj],  q_lo);
        ci_beta[jj, 2] = quantile(boot_beta[., jj],  q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_gamma;
        ci_gamma[jj, 1] = quantile(boot_gamma[., jj], q_lo);
        ci_gamma[jj, 2] = quantile(boot_gamma[., jj], q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_phi;
        ci_phi[jj, 1] = quantile(boot_phi[., jj], q_lo);
        ci_phi[jj, 2] = quantile(boot_phi[., jj], q_hi);
        jj = jj + 1;
    endo;

    retp(ci_beta, ci_gamma, ci_phi);
endp;

/*
**> blockBootstrapQARDLMethod
**
**  Purpose:    Bootstrap confidence intervals for QARDL parameters with
**              selectable resampling method.
**
**  Input:      method      string: "moving" (default moving-block bootstrap),
**                          "circular" (circular-block bootstrap), or
**                          "stationary" (Politis-Romano stationary bootstrap).
*/
proc (3) = blockBootstrapQARDLMethod(data, ppp, qqq, tau, B, blk_len, alpha, method);
    local T, k0, ss, jj, bbb, idx, boot_data, used_blk_len;
    local dim_beta, dim_phi, dim_gamma;
    local boot_beta, boot_gamma, boot_phi;
    local ci_beta, ci_gamma, ci_phi;
    local q_lo, q_hi;

    struct qardlOut qa_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDLMethod");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDLMethod: B must be a positive integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDLMethod: alpha must be a scalar in (0, 1)";
        end;
    endif;

    method = lower(method);
    call _qardlValidateBootstrapMethod(method, "blockBootstrapQARDLMethod");

    T = rows(data);
    k0 = cols(data) - 1;
    ss = rows(tau);
    used_blk_len = _qardlResolvedBlockLength(T, blk_len, "blockBootstrapQARDLMethod");

    dim_beta  = k0 * ss;
    dim_gamma = k0 * ss;
    dim_phi   = ppp * ss;

    boot_beta  = zeros(B, dim_beta);
    boot_gamma = zeros(B, dim_gamma);
    boot_phi   = zeros(B, dim_phi);

    bbb = 1;
    do until bbb > B;
        idx = _qardlBootstrapIndex(T, used_blk_len, method);
        boot_data = data[idx, .];

        qa_b = qardl(boot_data, ppp, qqq, tau, "iid", 0, 0);

        boot_beta[bbb, .]  = qa_b.bigbt';
        boot_gamma[bbb, .] = qa_b.gamma';
        boot_phi[bbb, .]   = qa_b.phi';

        bbb = bbb + 1;
    endo;

    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_beta  = zeros(dim_beta,  2);
    ci_gamma = zeros(dim_gamma, 2);
    ci_phi   = zeros(dim_phi,   2);

    jj = 1;
    do until jj > dim_beta;
        ci_beta[jj, 1] = quantile(boot_beta[., jj], q_lo);
        ci_beta[jj, 2] = quantile(boot_beta[., jj], q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_gamma;
        ci_gamma[jj, 1] = quantile(boot_gamma[., jj], q_lo);
        ci_gamma[jj, 2] = quantile(boot_gamma[., jj], q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_phi;
        ci_phi[jj, 1] = quantile(boot_phi[., jj], q_lo);
        ci_phi[jj, 2] = quantile(boot_phi[., jj], q_hi);
        jj = jj + 1;
    endo;

    retp(ci_beta, ci_gamma, ci_phi);
endp;

/*
**> blockBootstrapQARDLDiag
**
**  Purpose:    Moving-block bootstrap confidence intervals for QARDL
**              parameters with reproducible seed control and simple run
**              diagnostics.
**
**  Format:     { ci_beta, ci_gamma, ci_phi, boot_diag } =
**                  blockBootstrapQARDLDiag(data, ppp, qqq, tau, B, blk_len,
**                                         alpha, seed);
**
**  Input:      seed        scalar.  If seed > 0, rndseed is set before
**                          drawing bootstrap block starts.  Use 0 to leave
**                          the current GAUSS random state unchanged.
**
**  Output:     boot_diag   (1 x 5) matrix:
**                          [B requested, B completed, B failed, blk_len, seed].
**
**  Remarks:    Rank-deficient bootstrap resamples are skipped before
**              estimation and counted as failed replications. The procedure
**              attempts up to 5*B draws to complete B valid replications.
*/
proc (4) = blockBootstrapQARDLDiag(data, ppp, qqq, tau, B, blk_len, alpha, seed);
    local T, k0, ss, jj, bbb, attempts, max_attempts, failed_reps, completed_reps;
    local n_blks, starts, idx, boot_data, idx_first, idx_last;
    local dim_beta, dim_phi, dim_gamma;
    local boot_beta, boot_gamma, boot_phi;
    local ci_beta, ci_gamma, ci_phi, boot_diag, used_blk_len;
    local q_lo, q_hi;

    struct qardlOut qa_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDLDiag");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDLDiag: B must be a positive integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDLDiag: alpha must be a scalar in (0, 1)";
        end;
    endif;

    call _qardlValidateBootstrapSeed(seed, "blockBootstrapQARDLDiag");

    T = rows(data);
    k0 = cols(data) - 1;
    ss = rows(tau);
    used_blk_len = _qardlResolvedBlockLength(T, blk_len, "blockBootstrapQARDLDiag");
    n_blks = ceil(T / used_blk_len);

    dim_beta  = k0 * ss;
    dim_gamma = k0 * ss;
    dim_phi   = ppp * ss;

    boot_beta  = zeros(B, dim_beta);
    boot_gamma = zeros(B, dim_gamma);
    boot_phi   = zeros(B, dim_phi);

    if seed > 0;
        rndseed seed;
    endif;

    completed_reps = 0;
    failed_reps = 0;
    attempts = 0;
    max_attempts = 5*B;

    do until completed_reps >= B or attempts >= max_attempts;
        attempts = attempts + 1;

        starts = ceil(rndu(n_blks, 1) * (T - used_blk_len + 1));

        idx = zeros(n_blks*used_blk_len, 1);
        jj = 1;
        do until jj > n_blks;
            idx_first = (jj-1)*used_blk_len + 1;
            idx_last  = jj*used_blk_len;
            idx[idx_first:idx_last] = seqa(starts[jj], 1, used_blk_len);
            jj = jj + 1;
        endo;
        idx = idx[1:T, .];

        boot_data = data[idx, .];

        if _qardlLevelsDesignOK(boot_data, ppp, qqq);
            qa_b = qardl(boot_data, ppp, qqq, tau, "iid", 0, 0);
            completed_reps = completed_reps + 1;
            boot_beta[completed_reps, .]  = qa_b.bigbt';
            boot_gamma[completed_reps, .] = qa_b.gamma';
            boot_phi[completed_reps, .]   = qa_b.phi';
        else;
            failed_reps = failed_reps + 1;
        endif;
    endo;

    if completed_reps < 1;
        errorlog "blockBootstrapQARDLDiag: no valid bootstrap replications completed";
        end;
    endif;

    if completed_reps < B;
        boot_beta  = boot_beta[1:completed_reps, .];
        boot_gamma = boot_gamma[1:completed_reps, .];
        boot_phi   = boot_phi[1:completed_reps, .];
    endif;

    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_beta  = zeros(dim_beta,  2);
    ci_gamma = zeros(dim_gamma, 2);
    ci_phi   = zeros(dim_phi,   2);

    jj = 1;
    do until jj > dim_beta;
        ci_beta[jj, 1] = quantile(boot_beta[., jj], q_lo);
        ci_beta[jj, 2] = quantile(boot_beta[., jj], q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_gamma;
        ci_gamma[jj, 1] = quantile(boot_gamma[., jj], q_lo);
        ci_gamma[jj, 2] = quantile(boot_gamma[., jj], q_hi);
        jj = jj + 1;
    endo;

    jj = 1;
    do until jj > dim_phi;
        ci_phi[jj, 1] = quantile(boot_phi[., jj], q_lo);
        ci_phi[jj, 2] = quantile(boot_phi[., jj], q_hi);
        jj = jj + 1;
    endo;

    boot_diag = B~completed_reps~failed_reps~used_blk_len~seed;

    retp(ci_beta, ci_gamma, ci_phi, boot_diag);
endp;

/*
**> blockBootstrapQARDLECM
**
**  Purpose:    Moving-block bootstrap confidence intervals for the QARDL-ECM
**              speed-of-adjustment rho(tau) and intercept alpha(tau).  Uses
**              the same block-resampling scheme as blockBootstrapQARDL.
**
**  Format:     { ci_rho, ci_alpha } = blockBootstrapQARDLECM(data, ppp, qqq);
**              { ci_rho, ci_alpha } = blockBootstrapQARDLECM(data, ppp, qqq,
**                  tau = { 0.25, 0.5, 0.75 }, B = 999, blk_len = 0,
**                  alpha = 0.05, formula = "");
**
**  Input:      data        (T x (1+k)) matrix.
**              ppp         scalar, AR lag order.
**              qqq         scalar, distributed-lag order.
**              tau         (ss x 1) quantile vector.
**              B           scalar, bootstrap replications. Default 999.
**              blk_len     scalar, block length. 0 = floor(T^(1/3)). Default 0.
**              alpha       scalar, confidence level. Default 0.05 (95% CI).
**              formula     string, Wilkinson formula. Default "".
**
**  Output:     ci_rho      (ss x 2) [lower, upper] CI bounds for rho(tau).
**              ci_alpha    (ss x 2) [lower, upper] CI bounds for alpha(tau).
**
**  Developed:  April 2026
*/
proc (2) = blockBootstrapQARDLECM(data, ppp, qqq, tau = { 0.25, 0.5, 0.75 }, B = 999, blk_len = 0, alpha = 0.05);
    local T, ss, jj, bbb;
    local n_blks, starts, idx, boot_data, idx_first, idx_last;
    local boot_rho, boot_alpha;
    local ci_rho, ci_alpha;
    local q_lo, q_hi;

    struct qardlECMOut qecm_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDLECM");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDLECM: B must be a positive integer";
        end;
    endif;

    if rows(blk_len) * cols(blk_len) /= 1 or blk_len < 0 or round(blk_len) /= blk_len;
        errorlog "blockBootstrapQARDLECM: blk_len must be a non-negative integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDLECM: alpha must be a scalar in (0, 1)";
        end;
    endif;

    T  = rows(data);
    ss = rows(tau);

    if blk_len <= 0 or scalmiss(blk_len);
        blk_len = trunc(T^(1/3));
        if blk_len < 2;
            blk_len = 2;
        endif;
    endif;

    n_blks = ceil(T / blk_len);

    boot_rho   = zeros(B, ss);
    boot_alpha = zeros(B, ss);

    bbb = 1;
    do until bbb > B;

        starts = ceil(rndu(n_blks, 1) * (T - blk_len + 1));

        idx = zeros(n_blks*blk_len, 1);
        jj = 1;
        do until jj > n_blks;
            idx_first = (jj-1)*blk_len + 1;
            idx_last  = jj*blk_len;
            idx[idx_first:idx_last] = seqa(starts[jj], 1, blk_len);
            jj = jj + 1;
        endo;
        idx = idx[1:T, .];

        boot_data = data[idx, .];

        qecm_b = qardlECM(boot_data, ppp, qqq, tau, "iid", 0, 0);

        boot_rho[bbb, .]   = qecm_b.rho';
        boot_alpha[bbb, .] = qecm_b.alpha';

        bbb = bbb + 1;
    endo;

    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_rho   = zeros(ss, 2);
    ci_alpha = zeros(ss, 2);

    jj = 1;
    do until jj > ss;
        ci_rho[jj, 1]   = quantile(boot_rho[., jj],   q_lo);
        ci_rho[jj, 2]   = quantile(boot_rho[., jj],   q_hi);
        ci_alpha[jj, 1] = quantile(boot_alpha[., jj], q_lo);
        ci_alpha[jj, 2] = quantile(boot_alpha[., jj], q_hi);
        jj = jj + 1;
    endo;

    retp(ci_rho, ci_alpha);
endp;

/*
**> blockBootstrapQARDLECMMethod
**
**  Purpose:    Bootstrap confidence intervals for QARDL-ECM alpha/rho with
**              selectable resampling method.
**
**  Input:      method      string: "moving", "circular", or "stationary".
*/
proc (2) = blockBootstrapQARDLECMMethod(data, ppp, qqq, tau, B, blk_len, alpha, method);
    local T, ss, jj, bbb, idx, boot_data, used_blk_len;
    local boot_rho, boot_alpha;
    local ci_rho, ci_alpha;
    local q_lo, q_hi;

    struct qardlECMOut qecm_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDLECMMethod");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDLECMMethod: B must be a positive integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDLECMMethod: alpha must be a scalar in (0, 1)";
        end;
    endif;

    method = lower(method);
    call _qardlValidateBootstrapMethod(method, "blockBootstrapQARDLECMMethod");

    T = rows(data);
    ss = rows(tau);
    used_blk_len = _qardlResolvedBlockLength(T, blk_len, "blockBootstrapQARDLECMMethod");

    boot_rho   = zeros(B, ss);
    boot_alpha = zeros(B, ss);

    bbb = 1;
    do until bbb > B;
        idx = _qardlBootstrapIndex(T, used_blk_len, method);
        boot_data = data[idx, .];

        qecm_b = qardlECM(boot_data, ppp, qqq, tau, "iid", 0, 0);

        boot_rho[bbb, .]   = qecm_b.rho';
        boot_alpha[bbb, .] = qecm_b.alpha';

        bbb = bbb + 1;
    endo;

    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_rho   = zeros(ss, 2);
    ci_alpha = zeros(ss, 2);

    jj = 1;
    do until jj > ss;
        ci_rho[jj, 1]   = quantile(boot_rho[., jj], q_lo);
        ci_rho[jj, 2]   = quantile(boot_rho[., jj], q_hi);
        ci_alpha[jj, 1] = quantile(boot_alpha[., jj], q_lo);
        ci_alpha[jj, 2] = quantile(boot_alpha[., jj], q_hi);
        jj = jj + 1;
    endo;

    retp(ci_rho, ci_alpha);
endp;

/*
**> blockBootstrapQARDLECMDiag
**
**  Purpose:    Moving-block bootstrap confidence intervals for QARDL-ECM
**              alpha/rho with reproducible seed control and simple run
**              diagnostics.
**
**  Format:     { ci_rho, ci_alpha, boot_diag } =
**                  blockBootstrapQARDLECMDiag(data, ppp, qqq, tau, B, blk_len,
**                                            alpha, seed);
**
**  Output:     boot_diag   (1 x 5) matrix:
**                          [B requested, B completed, B failed, blk_len, seed].
**
**  Remarks:    Rank-deficient bootstrap resamples are skipped before
**              estimation and counted as failed replications. The procedure
**              attempts up to 5*B draws to complete B valid replications.
*/
proc (3) = blockBootstrapQARDLECMDiag(data, ppp, qqq, tau, B, blk_len, alpha, seed);
    local T, ss, jj, attempts, max_attempts, failed_reps, completed_reps;
    local n_blks, starts, idx, boot_data, idx_first, idx_last;
    local boot_rho, boot_alpha, ci_rho, ci_alpha, boot_diag, used_blk_len;
    local q_lo, q_hi;

    struct qardlECMOut qecm_b;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, tau, "blockBootstrapQARDLECMDiag");

    if rows(B) * cols(B) /= 1 or B < 1 or round(B) /= B;
        errorlog "blockBootstrapQARDLECMDiag: B must be a positive integer";
        end;
    endif;

    if rows(alpha) * cols(alpha) /= 1 or alpha <= 0 or alpha >= 1;
        errorlog "blockBootstrapQARDLECMDiag: alpha must be a scalar in (0, 1)";
        end;
    endif;

    call _qardlValidateBootstrapSeed(seed, "blockBootstrapQARDLECMDiag");

    T = rows(data);
    ss = rows(tau);
    used_blk_len = _qardlResolvedBlockLength(T, blk_len, "blockBootstrapQARDLECMDiag");
    n_blks = ceil(T / used_blk_len);

    boot_rho   = zeros(B, ss);
    boot_alpha = zeros(B, ss);

    if seed > 0;
        rndseed seed;
    endif;

    completed_reps = 0;
    failed_reps = 0;
    attempts = 0;
    max_attempts = 5*B;

    do until completed_reps >= B or attempts >= max_attempts;
        attempts = attempts + 1;

        starts = ceil(rndu(n_blks, 1) * (T - used_blk_len + 1));

        idx = zeros(n_blks*used_blk_len, 1);
        jj = 1;
        do until jj > n_blks;
            idx_first = (jj-1)*used_blk_len + 1;
            idx_last  = jj*used_blk_len;
            idx[idx_first:idx_last] = seqa(starts[jj], 1, used_blk_len);
            jj = jj + 1;
        endo;
        idx = idx[1:T, .];

        boot_data = data[idx, .];

        if _qardlECMDesignOK(boot_data, ppp, qqq);
            qecm_b = qardlECM(boot_data, ppp, qqq, tau, "iid", 0, 0);
            completed_reps = completed_reps + 1;
            boot_rho[completed_reps, .]   = qecm_b.rho';
            boot_alpha[completed_reps, .] = qecm_b.alpha';
        else;
            failed_reps = failed_reps + 1;
        endif;
    endo;

    if completed_reps < 1;
        errorlog "blockBootstrapQARDLECMDiag: no valid bootstrap replications completed";
        end;
    endif;

    if completed_reps < B;
        boot_rho   = boot_rho[1:completed_reps, .];
        boot_alpha = boot_alpha[1:completed_reps, .];
    endif;

    q_lo = alpha / 2;
    q_hi = 1 - q_lo;

    ci_rho   = zeros(ss, 2);
    ci_alpha = zeros(ss, 2);

    jj = 1;
    do until jj > ss;
        ci_rho[jj, 1]   = quantile(boot_rho[., jj], q_lo);
        ci_rho[jj, 2]   = quantile(boot_rho[., jj], q_hi);
        ci_alpha[jj, 1] = quantile(boot_alpha[., jj], q_lo);
        ci_alpha[jj, 2] = quantile(boot_alpha[., jj], q_hi);
        jj = jj + 1;
    endo;

    boot_diag = B~completed_reps~failed_reps~used_blk_len~seed;

    retp(ci_rho, ci_alpha, boot_diag);
endp;

/*
** Internal validation helpers for public QARDL APIs.
*/
proc (0) = _qardlValidateEstimatorInputs(data, ppp, qqq, tau, caller);
    local nn, k0, max_lag, n_eff, n_param;

    if rows(data) < 1 or cols(data) < 2;
        errorlog caller $+ ": data must have at least one dependent variable and one regressor column";
        end;
    endif;

    if ismiss(data);
        errorlog caller $+ ": data contains missing values; clean or align the sample before estimation";
        end;
    endif;

    call _qardlValidateLagScalar(ppp, caller $+ ": p");
    call _qardlValidateLagScalarZero(qqq, caller $+ ": q");
    call _qardlValidateTau(tau, caller);

    nn      = rows(data);
    k0      = cols(data) - 1;
    max_lag = maxc(ppp|qqq);
    n_eff   = nn - max_lag;
    n_param = 1 + qqq*k0 + k0 + ppp;

    if n_eff <= n_param;
        errorlog caller $+ ": not enough observations for the requested lag orders";
        end;
    endif;
endp;

proc (0) = _qardlValidateSearchInputs(data, pend, qend, tau, caller);
    if rows(data) < 1 or cols(data) < 2;
        errorlog caller $+ ": data must have at least one dependent variable and one regressor column";
        end;
    endif;

    if ismiss(data);
        errorlog caller $+ ": data contains missing values; clean or align the sample before estimation";
        end;
    endif;

    call _qardlValidateLagScalar(pend, caller $+ ": pend");
    call _qardlValidateLagScalarZero(qend, caller $+ ": qend");
    call _qardlValidateTau(tau, caller);

    call _qardlValidateEstimatorInputs(data, pend, qend, tau, caller);
endp;

proc (0) = _qardlValidateLagScalar(lag, label);
    if rows(lag) * cols(lag) /= 1 or lag < 1 or round(lag) /= lag;
        errorlog label $+ " must be a positive integer";
        end;
    endif;
endp;

proc (0) = _qardlValidateLagScalarZero(lag, label);
    if rows(lag) * cols(lag) /= 1 or lag < 0 or round(lag) /= lag;
        errorlog label $+ " must be a non-negative integer";
        end;
    endif;
endp;

proc (1) = _qardlNormalizeQVector(qvec, k0, label);
    local qv, ii;

    if rows(qvec) == 1 and cols(qvec) == k0;
        qv = qvec';
    elseif rows(qvec) == k0 and cols(qvec) == 1;
        qv = qvec;
    else;
        errorlog label $+ " must be a k x 1 or 1 x k vector with one lag order per regressor";
        end;
    endif;

    ii = 1;
    do until ii > k0;
        call _qardlValidateLagScalarZero(qv[ii], label $+ "[" $+ ftos(ii, "%g", 1, 0) $+ "]");
        ii = ii + 1;
    endo;

    retp(qv);
endp;

proc (0) = _qardlValidateRestrictionShape(bigR, smr, nparam, caller);
    if rows(bigR) < 1 or cols(bigR) /= nparam;
        errorlog caller $+ ": R must have one column per tested parameter";
        end;
    endif;

    if rows(smr) /= rows(bigR) or cols(smr) /= 1;
        errorlog caller $+ ": r must be a column vector with one row per restriction";
        end;
    endif;
endp;

proc (1) = _qardlConditionNumber(X);
    local U, S, V, sdiag, smax, smin;

    { U, S, V } = svd1(X);
    sdiag = abs(diag(S));
    smax = maxc(sdiag);
    smin = minc(sdiag);

    if smax <= 0 or smin <= 1e-14*smax;
        retp(1e256);
    endif;

    retp(smax/smin);
endp;

proc (0) = _qardlCheckFullColumnRank(X, caller, label);
    local rnk, cond_no;

    if rows(X) <= cols(X);
        errorlog caller $+ ": " $+ label $+ " has too few observations for its regressors";
        end;
    endif;

    rnk = rank(X);
    if rnk < cols(X);
        errorlog caller $+ ": " $+ label $+ " is rank deficient";
        errorlog "  rank = " $+ ftos(rnk, "%g", 1, 0) $+ ", columns = " $+ ftos(cols(X), "%g", 1, 0);
        end;
    endif;

    cond_no = sqrt(_qardlConditionNumber(X'X));
    if cond_no > 1e10;
        print "WARNING (" $+ caller $+ "): " $+ label $+ " is ill-conditioned; condition number = " $+ ftos(cond_no, "%*.*lf", 1, 4);
    endif;
endp;

proc (1) = _qardlSafeInv(X, caller, label);
    local rnk, cond_no;

    if rows(X) /= cols(X);
        errorlog caller $+ ": " $+ label $+ " must be square before inversion";
        end;
    endif;

    rnk = rank(X);
    if rnk < rows(X);
        errorlog caller $+ ": " $+ label $+ " is singular and cannot be inverted";
        errorlog "  rank = " $+ ftos(rnk, "%g", 1, 0) $+ ", order = " $+ ftos(rows(X), "%g", 1, 0);
        end;
    endif;

    cond_no = _qardlConditionNumber(X);
    if cond_no > 1e14;
        errorlog caller $+ ": " $+ label $+ " is too ill-conditioned to invert safely";
        errorlog "  condition number = " $+ ftos(cond_no, "%*.*lf", 1, 4);
        end;
    elseif cond_no > 1e10;
        print "WARNING (" $+ caller $+ "): " $+ label $+ " inversion is ill-conditioned; condition number = " $+ ftos(cond_no, "%*.*lf", 1, 4);
    endif;

    retp(inv(X));
endp;

proc (2) = _qardlWaldInvAndRank(X, caller, label);
    local rnk, cond_no, X_inv;

    if rows(X) /= cols(X);
        errorlog caller $+ ": " $+ label $+ " must be square before Wald inversion";
        end;
    endif;

    rnk = rank(X);
    if rnk < 1;
        errorlog caller $+ ": " $+ label $+ " has zero rank";
        end;
    endif;

    cond_no = _qardlConditionNumber(X);
    if rnk < rows(X);
        print "WARNING (" $+ caller $+ "): " $+ label $+ " is rank deficient; using pseudoinverse and rank-adjusted chi-square degrees of freedom.";
        X_inv = pinv(X);
    elseif cond_no > 1e10;
        print "WARNING (" $+ caller $+ "): " $+ label $+ " is ill-conditioned; using pseudoinverse. condition number = " $+ ftos(cond_no, "%*.*lf", 1, 4);
        X_inv = pinv(X);
    else;
        X_inv = inv(X);
    endif;

    retp(X_inv, rnk);
endp;

proc (0) = _qardlValidateWaldInputs(param, cov, bigR, smr, data, caller);
    if rows(param) < 1 or cols(param) /= 1;
        errorlog caller $+ ": parameter vector must be a non-empty column vector";
        end;
    endif;

    if rows(cov) /= rows(param) or cols(cov) /= rows(param);
        errorlog caller $+ ": covariance matrix must be square and conformable with the parameter vector";
        end;
    endif;

    call _qardlValidateRestrictionShape(bigR, smr, rows(param), caller);

    if rows(data) < 2;
        errorlog caller $+ ": data must contain at least two observations";
        end;
    endif;
endp;

proc (1) = _qardlLevelsDesignOK(data, ppp, qqq);
    local yy, xx, ee, nn, k0, jj;
    local eei, xxi, yyi, X, ONEX;

    nn = rows(data);
    k0 = cols(data) - 1;
    yy = data[., 1];
    xx = data[., 2:cols(data)];

    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;

    if qqq > 0;
        eei = zeros(nn-qqq, qqq*k0);
        xxi = xx[qqq+1:nn, .];
    else;
        xxi = xx;
    endif;

    if qqq > 0;
        jj = 1;
        do until jj > k0;
            eei[., 1+(jj-1)*qqq:(jj-1)*qqq+qqq] = packr(lagn(ee[., jj], seqa(-qqq, 1, qqq)));
            jj = jj + 1;
        endo;
    endif;

    yyi = packr(lagn(yy, seqa(-ppp+1, 1, ppp)));
    yyi = yyi[1:rows(yyi)-1, .];

    if qqq == 0;
        X = xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    elseif ppp .> qqq;
        X = eei[(rows(eei)+1-rows(yyi)):rows(eei), .]~xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    else;
        X = eei~xxi~yyi[(rows(yyi)+1-rows(xxi)):rows(yyi), .];
    endif;

    ONEX = ones(rows(X), 1)~X;

    retp(rank(ONEX) == cols(ONEX));
endp;

proc (4) = _qardlBuildLevelsDesignX(data, ppp, qvec);
    local yy, xx, ee, nn, k0, qmax, T0, N, Y, X, ONEX;
    local dx_terms, y_lags, ii, jj, col_idx, theta_start, phi_start;

    nn = rows(data);
    k0 = cols(data) - 1;
    yy = data[., 1];
    xx = data[., 2:cols(data)];

    qvec = _qardlNormalizeQVector(qvec, k0, "_qardlBuildLevelsDesignX: qvec");
    qmax = maxc(qvec);
    T0 = maxc(ppp|qmax);
    N = nn - T0;

    if N <= 0;
        errorlog "_qardlBuildLevelsDesignX: insufficient observations for requested lag orders";
        end;
    endif;

    Y = yy[(T0+1):nn];
    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;

    if sumc(qvec) > 0;
        dx_terms = zeros(N, sumc(qvec));
        col_idx = 1;
        ii = 1;
        do until ii > k0;
            if qvec[ii] > 0;
                for jj(0, qvec[ii]-1, 1);
                    dx_terms[., col_idx] = ee[(T0+1-jj):(nn-jj), ii];
                    col_idx = col_idx + 1;
                endfor;
            endif;
            ii = ii + 1;
        endo;
        X = dx_terms~xx[(T0+1):nn, .];
    else;
        X = xx[(T0+1):nn, .];
    endif;

    y_lags = zeros(N, ppp);
    jj = 1;
    do until jj > ppp;
        y_lags[., jj] = yy[(T0+1-jj):(nn-jj)];
        jj = jj + 1;
    endo;

    X = X~y_lags;
    ONEX = ones(N, 1)~X;
    theta_start = 2 + sumc(qvec);
    phi_start = theta_start + k0;

    retp(Y, ONEX, theta_start, phi_start);
endp;

proc (1) = _qardlECMDesignOK(data, ppp, qqq);
    local yy, xx, ee, nn, k0, jj, j;
    local eei, xxi, yyi, X_ols, ONEX_ols, bt_ols, beta_lr_ols;
    local N, T0, N_ecm, Y_ecm, ec_lag, ONEX_ecm, dy_lags, dx_ecm;

    if not _qardlLevelsDesignOK(data, ppp, qqq);
        retp(0);
    endif;

    nn = rows(data);
    k0 = cols(data) - 1;
    yy = data[., 1];
    xx = data[., 2:cols(data)];

    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;

    if qqq > 0;
        eei = zeros(nn-qqq, qqq*k0);
        xxi = xx[qqq+1:nn, .];
    else;
        xxi = xx;
    endif;

    if qqq > 0;
        jj = 1;
        do until jj > k0;
            eei[., 1+(jj-1)*qqq:(jj-1)*qqq+qqq] = packr(lagn(ee[., jj], seqa(-qqq, 1, qqq)));
            jj = jj + 1;
        endo;
    endif;

    yyi = packr(lagn(yy, seqa(-ppp+1, 1, ppp)));
    yyi = yyi[1:rows(yyi)-1, .];

    if qqq == 0;
        X_ols = xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    elseif ppp .> qqq;
        X_ols = eei[(rows(eei)+1-rows(yyi)):rows(eei), .]~xxi[(rows(xxi)+1-rows(yyi)):rows(xxi), .]~yyi;
    else;
        X_ols = eei~xxi~yyi[(rows(yyi)+1-rows(xxi)):rows(yyi), .];
    endif;

    ONEX_ols = ones(rows(X_ols), 1)~X_ols;
    if rank(ONEX_ols) /= cols(ONEX_ols);
        retp(0);
    endif;

    bt_ols = inv(ONEX_ols'ONEX_ols)*ONEX_ols'*yy[(nn-rows(X_ols)+1):nn, 1];
    beta_lr_ols = -bt_ols[(2+qqq*k0):(1+(qqq+1)*k0), 1] /
                  (sumc(bt_ols[(2+(qqq+1)*k0):(1+(qqq+1)*k0+ppp), 1]) - 1);

    T0 = maxc(ppp|qqq);
    N = nn - T0;
    N_ecm = N - 1;

    if N_ecm <= 0;
        retp(0);
    endif;

    Y_ecm = yy[(T0+2):nn] - yy[(T0+1):(nn-1)];
    ec_lag = yy[(T0+1):(nn-1)] - xx[(T0+1):(nn-1), .]*beta_lr_ols;
    ONEX_ecm = ones(N_ecm, 1)~ec_lag;

    if ppp > 1;
        dy_lags = zeros(N_ecm, ppp-1);
        for j(1, ppp-1, 1);
            dy_lags[., j] = yy[(T0+2-j):(nn-j)] - yy[(T0+1-j):(nn-j-1)];
        endfor;
        ONEX_ecm = ONEX_ecm~dy_lags;
    endif;

    if qqq > 0;
        dx_ecm = zeros(N_ecm, qqq*k0);
        jj = 1;
        do until jj > k0;
            for j(0, qqq-1, 1);
                dx_ecm[., (jj-1)*qqq + j + 1] =
                    xx[(T0+2-j):(nn-j), jj] - xx[(T0+1-j):(nn-j-1), jj];
            endfor;
            jj = jj + 1;
        endo;
        ONEX_ecm = ONEX_ecm~dx_ecm;
    endif;

    retp(rank(ONEX_ecm) == cols(ONEX_ecm) and rows(Y_ecm) > cols(ONEX_ecm));
endp;

proc (1) = _qardlQRCovSandwich(ONEX, Y, bt, tau, fh, D_inv, hac_lags);
    local N, K, ss, ii, jj, lag, w;
    local full_cov, resid_i, resid_j, psi_i, psi_j;
    local scores_i, scores_j, S_ij, cov_block, scale_i, scale_j;

    N = rows(ONEX);
    K = cols(ONEX);
    ss = rows(tau);

    full_cov = zeros(K*ss, K*ss);

    jj = 1;
    do until jj > ss;
        resid_j = Y - ONEX*bt[., jj];
        psi_j = tau[jj] - (resid_j .< 0);
        scores_j = ONEX .* (psi_j*ones(1, K));

        ii = 1;
        do until ii > ss;
            resid_i = Y - ONEX*bt[., ii];
            psi_i = tau[ii] - (resid_i .< 0);
            scores_i = ONEX .* (psi_i*ones(1, K));

            S_ij = scores_i'*scores_j / N;

            lag = 1;
            do until lag > hac_lags;
                w = 1 - lag/(hac_lags + 1);
                S_ij = S_ij
                     + w*(scores_i[(lag+1):N, .]'*scores_j[1:(N-lag), .] / N)
                     + w*(scores_i[1:(N-lag), .]'*scores_j[(lag+1):N, .] / N);
                lag = lag + 1;
            endo;

            scale_i = fh[ii];
            scale_j = fh[jj];
            cov_block = D_inv*S_ij*D_inv / (scale_i*scale_j*N);

            full_cov[(ii-1)*K+1:ii*K, (jj-1)*K+1:jj*K] = cov_block;

            ii = ii + 1;
        endo;

        jj = jj + 1;
    endo;

    retp(full_cov);
endp;

proc (3) = _qardlLevelsCovFromFull(full_cov, bt, ppp, qqq, k0, ss);
    local K, theta_start, theta_end, phi_start, phi_end;
    local bigbt_cov, phi_cov, gamma_cov, ii, jj, row_i, row_j;
    local trans_i, trans_j, block_ij, cov_beta_ij, theta_i, den_i;

    K = rows(bt);
    theta_start = 2 + qqq*k0;
    theta_end = 1 + (qqq+1)*k0;
    phi_start = 2 + (qqq+1)*k0;
    phi_end = 1 + (qqq+1)*k0 + ppp;

    bigbt_cov = zeros(k0*ss, k0*ss);
    phi_cov = zeros(ppp*ss, ppp*ss);
    gamma_cov = zeros(k0*ss, k0*ss);

    ii = 1;
    do until ii > ss;
        theta_i = bt[theta_start:theta_end, ii];
        den_i = 1 - sumc(bt[phi_start:phi_end, ii]);

        trans_i = zeros(k0, K);
        trans_i[., theta_start:theta_end] = eye(k0) / den_i;
        trans_i[., phi_start:phi_end] = (theta_i/(den_i^2))*ones(1, ppp);

        jj = 1;
        do until jj > ss;
            theta_i = bt[theta_start:theta_end, jj];
            den_i = 1 - sumc(bt[phi_start:phi_end, jj]);

            trans_j = zeros(k0, K);
            trans_j[., theta_start:theta_end] = eye(k0) / den_i;
            trans_j[., phi_start:phi_end] = (theta_i/(den_i^2))*ones(1, ppp);

            row_i = (ii-1)*K + 1;
            row_j = (jj-1)*K + 1;
            block_ij = full_cov[row_i:row_i+K-1, row_j:row_j+K-1];

            cov_beta_ij = trans_i*block_ij*trans_j';

            bigbt_cov[(ii-1)*k0+1:ii*k0, (jj-1)*k0+1:jj*k0] = cov_beta_ij;
            gamma_cov[(ii-1)*k0+1:ii*k0, (jj-1)*k0+1:jj*k0] =
                block_ij[theta_start:theta_end, theta_start:theta_end];
            phi_cov[(ii-1)*ppp+1:ii*ppp, (jj-1)*ppp+1:jj*ppp] =
                block_ij[phi_start:phi_end, phi_start:phi_end];

            jj = jj + 1;
        endo;

        ii = ii + 1;
    endo;

    retp(bigbt_cov, phi_cov, gamma_cov);
endp;

proc (3) = _qardlLevelsCovFromFullPositions(full_cov, bt, theta_start, phi_start, k0, ppp, ss);
    local K, theta_end, phi_end;
    local bigbt_cov, phi_cov, gamma_cov, ii, jj, row_i, row_j;
    local trans_i, trans_j, block_ij, cov_beta_ij, theta_i, den_i;

    K = rows(bt);
    theta_end = theta_start + k0 - 1;
    phi_end = phi_start + ppp - 1;

    bigbt_cov = zeros(k0*ss, k0*ss);
    phi_cov = zeros(ppp*ss, ppp*ss);
    gamma_cov = zeros(k0*ss, k0*ss);

    ii = 1;
    do until ii > ss;
        theta_i = bt[theta_start:theta_end, ii];
        den_i = 1 - sumc(bt[phi_start:phi_end, ii]);

        trans_i = zeros(k0, K);
        trans_i[., theta_start:theta_end] = eye(k0) / den_i;
        trans_i[., phi_start:phi_end] = (theta_i/(den_i^2))*ones(1, ppp);

        jj = 1;
        do until jj > ss;
            theta_i = bt[theta_start:theta_end, jj];
            den_i = 1 - sumc(bt[phi_start:phi_end, jj]);

            trans_j = zeros(k0, K);
            trans_j[., theta_start:theta_end] = eye(k0) / den_i;
            trans_j[., phi_start:phi_end] = (theta_i/(den_i^2))*ones(1, ppp);

            row_i = (ii-1)*K + 1;
            row_j = (jj-1)*K + 1;
            block_ij = full_cov[row_i:row_i+K-1, row_j:row_j+K-1];

            cov_beta_ij = trans_i*block_ij*trans_j';

            bigbt_cov[(ii-1)*k0+1:ii*k0, (jj-1)*k0+1:jj*k0] = cov_beta_ij;
            gamma_cov[(ii-1)*k0+1:ii*k0, (jj-1)*k0+1:jj*k0] =
                block_ij[theta_start:theta_end, theta_start:theta_end];
            phi_cov[(ii-1)*ppp+1:ii*ppp, (jj-1)*ppp+1:jj*ppp] =
                block_ij[phi_start:phi_end, phi_start:phi_end];

            jj = jj + 1;
        endo;

        ii = ii + 1;
    endo;

    retp(bigbt_cov, phi_cov, gamma_cov);
endp;

proc (2) = _qardlECMCovSandwich(ONEX_ecm, Y_ecm, bt_ecm, tau, fh_ecm, D_inv_ecm, hac_lags);
    local N_ecm, K_ecm, ss, ii, jj, lag, w;
    local alpha_cov, rho_cov, resid_i, resid_j, psi_i, psi_j;
    local scores_i, scores_j, S_ij, cov_block, scale_i, scale_j;

    N_ecm = rows(ONEX_ecm);
    K_ecm = cols(ONEX_ecm);
    ss = rows(tau);

    alpha_cov = zeros(ss, ss);
    rho_cov = zeros(ss, ss);

    jj = 1;
    do until jj > ss;
        resid_j = Y_ecm - ONEX_ecm*bt_ecm[., jj];
        psi_j = tau[jj] - (resid_j .< 0);
        scores_j = ONEX_ecm .* (psi_j*ones(1, K_ecm));

        ii = 1;
        do until ii > ss;
            resid_i = Y_ecm - ONEX_ecm*bt_ecm[., ii];
            psi_i = tau[ii] - (resid_i .< 0);
            scores_i = ONEX_ecm .* (psi_i*ones(1, K_ecm));

            S_ij = scores_i'*scores_j / N_ecm;

            lag = 1;
            do until lag > hac_lags;
                w = 1 - lag/(hac_lags + 1);
                S_ij = S_ij
                     + w*(scores_i[(lag+1):N_ecm, .]'*scores_j[1:(N_ecm-lag), .] / N_ecm)
                     + w*(scores_i[1:(N_ecm-lag), .]'*scores_j[(lag+1):N_ecm, .] / N_ecm);
                lag = lag + 1;
            endo;

            scale_i = fh_ecm[ii];
            scale_j = fh_ecm[jj];
            cov_block = D_inv_ecm*S_ij*D_inv_ecm / (scale_i*scale_j*N_ecm);

            alpha_cov[ii, jj] = cov_block[1, 1];
            rho_cov[ii, jj] = cov_block[2, 2];

            ii = ii + 1;
        endo;

        jj = jj + 1;
    endo;

    retp(alpha_cov, rho_cov);
endp;

proc (1) = _qardlAutomaticHACLags(N_ecm);
    local hac_lags;

    hac_lags = trunc(4*(N_ecm/100)^(2/9));
    if hac_lags < 1;
        hac_lags = 1;
    endif;
    if hac_lags > N_ecm - 1;
        hac_lags = N_ecm - 1;
    endif;

    retp(hac_lags);
endp;

proc (0) = _qardlValidateECMCovType(cov_type, caller);
    if not (cov_type $== "iid" or cov_type $== "robust" or cov_type $== "hac");
        errorlog caller $+ ": cov_type must be \"iid\", \"robust\", or \"hac\"";
        end;
    endif;
endp;

proc (0) = _qardlValidateHACLags(hac_lags, caller);
    if rows(hac_lags) * cols(hac_lags) /= 1 or hac_lags < 0 or round(hac_lags) /= hac_lags;
        errorlog caller $+ ": hac_lags must be a non-negative integer";
        end;
    endif;
endp;

proc (1) = _qardlResolvedBlockLength(T, blk_len, caller);
    local used_blk_len;

    if rows(blk_len) * cols(blk_len) /= 1 or blk_len < 0 or round(blk_len) /= blk_len;
        errorlog caller $+ ": blk_len must be a non-negative integer";
        end;
    endif;

    if blk_len <= 0 or scalmiss(blk_len);
        used_blk_len = trunc(T^(1/3));
        if used_blk_len < 2;
            used_blk_len = 2;
        endif;
    else;
        used_blk_len = blk_len;
    endif;

    retp(used_blk_len);
endp;

proc (1) = _qardlBootstrapIndex(T, blk_len, method);
    local idx, n_blks, starts, jj, kk, idx_first, idx_last;
    local pos, new_start_prob;

    if method $== "stationary";
        idx = zeros(T, 1);
        new_start_prob = 1 / blk_len;
        pos = ceil(rndu(1, 1) * T);
        jj = 1;
        do until jj > T;
            idx[jj] = pos;
            if rndu(1, 1) < new_start_prob;
                pos = ceil(rndu(1, 1) * T);
            else;
                pos = pos + 1;
                if pos > T;
                    pos = 1;
                endif;
            endif;
            jj = jj + 1;
        endo;
        retp(idx);
    endif;

    n_blks = ceil(T / blk_len);
    idx = zeros(n_blks*blk_len, 1);

    if method $== "moving";
        starts = ceil(rndu(n_blks, 1) * (T - blk_len + 1));

        jj = 1;
        do until jj > n_blks;
            idx_first = (jj-1)*blk_len + 1;
            idx_last  = jj*blk_len;
            idx[idx_first:idx_last] = seqa(starts[jj], 1, blk_len);
            jj = jj + 1;
        endo;
    else;
        starts = ceil(rndu(n_blks, 1) * T);

        jj = 1;
        do until jj > n_blks;
            kk = 1;
            do until kk > blk_len;
                idx[(jj-1)*blk_len + kk] = starts[jj] + kk - 1;
                do while idx[(jj-1)*blk_len + kk] > T;
                    idx[(jj-1)*blk_len + kk] = idx[(jj-1)*blk_len + kk] - T;
                endo;
                kk = kk + 1;
            endo;
            jj = jj + 1;
        endo;
    endif;

    retp(idx[1:T, .]);
endp;

proc (0) = _qardlValidateBootstrapMethod(method, caller);
    if not (method $== "moving" or method $== "circular" or method $== "stationary");
        errorlog caller $+ ": method must be \"moving\", \"circular\", or \"stationary\"";
        end;
    endif;
endp;

proc (0) = _qardlValidateBootstrapSeed(seed, caller);
    if rows(seed) * cols(seed) /= 1 or seed < 0 or round(seed) /= seed;
        errorlog caller $+ ": seed must be a non-negative integer";
        end;
    endif;
endp;

proc (0) = _qardlValidateTau(tau, caller);
    local tau_sorted;

    if rows(tau) < 1 or cols(tau) /= 1;
        errorlog caller $+ ": tau must be a non-empty column vector";
        end;
    endif;

    if ismiss(tau);
        errorlog caller $+ ": tau contains missing values";
        end;
    endif;

    if minc(tau) <= 0 or maxc(tau) >= 1;
        errorlog caller $+ ": tau values must lie strictly between 0 and 1";
        end;
    endif;

    if rows(tau) > 1;
        tau_sorted = sortc(tau, 1);
        if minc(tau_sorted[2:rows(tau_sorted)] - tau_sorted[1:rows(tau_sorted)-1]) == 0;
            errorlog caller $+ ": tau values must be unique";
            end;
        endif;
    endif;
endp;

/*
**> qardlFull
**
**  Purpose:    Integrated QARDL workflow: lag selection, ARDL bounds test,
**              QARDL levels estimation, and QARDL-ECM estimation in one call.
**              Prints a complete results summary to the screen.
**
**  Format:     qfOut = qardlFull(data, pend, qend);
**              qfOut = qardlFull(data, pend, qend, tau = { 0.25, 0.5, 0.75 },
**                                formula = "", verbose = 1, criterion = "bic",
**                                cov_type = "iid", hac_lags = 0);
**
**  Input:      data    (T x (1+k)) matrix (or dataframe with formula).
**              pend    scalar, maximum AR lag to search.
**              qend    scalar, maximum DL lag to search.
**              tau     (ss x 1) quantile vector.
**              formula string, Wilkinson formula for column selection.
**
**              verbose scalar, 1 = print summaries, 0 = compute silently.
**
**              criterion string, lag-selection information criterion:
**                       "bic" (default), "aic", "hq", or "hqc".
**
**              cov_type string, covariance estimator passed to qardl() and
**                       qardlECM(): "iid" (default), "robust", or "hac".
**
**              hac_lags scalar, non-negative HAC lag truncation. If cov_type
**                       is "hac" and hac_lags = 0, the automatic bandwidth is
**                       used.
**
**  Output:     qfOut   struct qardlFullOut:
**                  .pst        Selected AR lag order.
**                  .qst        Selected DL lag order.
**                  .ardl_fstat Bounds test F-statistic.
**                  .ardl_cv    (3 x 2) I(0)/I(1) critical values.
**                  .qa         qardlOut (levels estimates).
**                  .ecm        qardlECMOut (ECM two-step estimates).
**
**  Developed:  April 2026
*/
proc (struct qardlFullOut) = qardlFull(data, pend, qend, tau = { 0.25, 0.5, 0.75 }, formula = "", verbose = 1, criterion = "bic", cov_type = "iid", hac_lags = 0);
    local pst, qst, fstat, cv;

    struct qardlFullOut qfOut;
    struct qardlOut qa;
    struct qardlECMOut ecm;

    if rows(verbose) * cols(verbose) /= 1 or (verbose /= 0 and verbose /= 1);
        errorlog "qardlFull: verbose must be 0 or 1";
        end;
    endif;

    data = _applyFormula(data, formula);
    call _qardlValidateSearchInputs(data, pend, qend, tau, "qardlFull");
    criterion = lower(criterion);
    call _qardlValidateICCriterion(criterion, "qardlFull");
    cov_type = lower(cov_type);
    call _qardlValidateECMCovType(cov_type, "qardlFull");
    call _qardlValidateHACLags(hac_lags, "qardlFull");

    // Step 1: Information-criterion lag order selection
    if verbose;
        print "qardlFull: selecting lag orders (" $+ upper(criterion) $+ ") ...";
    endif;
    { pst, qst } = pqorder(data, pend, qend, criterion);
    if verbose;
        sprintf("  %s-selected: p = %d, q = %d", upper(criterion), pst, qst);
    endif;

    // Step 2: ARDL bounds test
    if verbose;
        print "qardlFull: running ARDL bounds test ...";
    endif;
    { fstat, cv } = ardlbounds(data, pst, qst);
    if verbose;
        ardlbounds_print(fstat, cv, cols(data) - 1);
    endif;

    // Step 3: QARDL levels estimation
    if verbose;
        if cov_type $== "iid";
            print "qardlFull: estimating QARDL (levels form) ...";
        else;
            print "qardlFull: estimating QARDL (levels form, " $+ upper(cov_type) $+ " covariance) ...";
        endif;
    endif;
    qa = qardl(data, pst, qst, tau, cov_type, hac_lags, 0);
    if verbose;
        printQARDL(qa, tau);
    endif;

    // Step 4: QARDL-ECM two-step estimation
    if verbose;
        if cov_type $== "iid";
            print "qardlFull: estimating QARDL-ECM (two-step) ...";
        else;
            print "qardlFull: estimating QARDL-ECM (two-step, " $+ upper(cov_type) $+ " covariance) ...";
        endif;
    endif;
    ecm = qardlECM(data, pst, qst, tau, cov_type, hac_lags, 0);
    if verbose;
        printQARDLECM(ecm, tau);
    endif;

    qfOut.pst        = pst;
    qfOut.qst        = qst;
    qfOut.tau        = tau;
    qfOut.nobs       = rows(data);
    qfOut.ardl_fstat = fstat;
    qfOut.ardl_cv    = cv;
    qfOut.qa         = qa;
    qfOut.ecm        = ecm;

    retp(qfOut);
endp;

/*
**> applyQARDLFormula
**
**  Purpose:    Preprocess a named-column GAUSS dataframe using a Wilkinson
**              formula string.  Selects and reorders columns so that the
**              dependent variable is in column 1 and the regressors follow.
**              Use this before calling qardl(), qardlECM(), rollingQardl(),
**              or any other procedure that expects data in [y, x1, x2, ...]
**              column order.
**
**  Format:     data = applyQARDLFormula(data, formula);
**
**  Input:      data      GAUSS dataframe with named columns.
**              formula   Wilkinson formula string, e.g. "y ~ x1 + x2".
**
**  Output:     data      Reordered data matrix with y in column 1.
**
**  Example:
**              data = loadd("macro.csv");
**              data = applyQARDLFormula(data, "consumption ~ income + wealth");
**              qaOut = qardl(data, pst, qst);
**
**  Developed:  April 2026
*/
proc (1) = applyQARDLFormula(data, formula);
    retp(_applyFormula(data, formula));
endp;

// Internal helper: apply Wilkinson formula "y ~ x1 + x2" to reorder data as [y, x1, x2, ...]
// Uses native GAUSS string functions — no external library required.
// If formula is empty or data has no column names, returns data unchanged.
proc (1) = _applyFormula(data, formula);
    local tilde_pos, lhs, rhs, xvars, n_x, ii;
    local colnames, y_idx, x_idx, pos, part, remaining;

    if strlen(formula) == 0;
        retp(data);
    endif;

    tilde_pos = strindx(formula, "~", 1);
    if tilde_pos == 0;
        retp(data);
    endif;

    // LHS: y variable name
    lhs = strtrim(strsect(formula, 1, tilde_pos - 1));

    // RHS: parse "x1 + x2 + ..." into a string array
    remaining = strtrim(strsect(formula, tilde_pos + 1, strlen(formula)));
    xvars = "";
    n_x   = 0;

    do while strlen(remaining) > 0;
        pos = strindx(remaining, "+", 1);
        if pos == 0;
            part      = strtrim(remaining);
            remaining = "";
        else;
            part      = strtrim(strsect(remaining, 1, pos - 1));
            remaining = strtrim(strsect(remaining, pos + 1, strlen(remaining)));
        endif;
        if strlen(part) > 0;
            if n_x == 0;
                xvars = part;
            else;
                xvars = xvars $| part;
            endif;
            n_x = n_x + 1;
        endif;
    endo;

    // Case-insensitive column index lookup
    colnames = lower(getcolnames(data));
    y_idx    = indsav(lower(lhs),   colnames);
    x_idx    = indsav(lower(xvars), colnames);

    if rows(y_idx) == 0;
        errorlog "applyQARDLFormula: dependent variable not found: " $+ lhs;
        end;
    endif;

    if rows(x_idx) /= n_x;
        errorlog "applyQARDLFormula: one or more RHS variables were not found";
        end;
    endif;

    data = data[., y_idx | x_idx];

    retp(data);
endp;
