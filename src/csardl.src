/*
**> csardl
**
**  Purpose:    Cross-Sectional ARDL (CS-ARDL) pooled levels estimation with
**              cross-sectional-average controls. Matrix input is a balanced
**              panel stacked by unit: [unit_id, y, x1, x2, ...].
**
**  Format:     csaOut = csardl(data, ppp, qqq);
**              csaOut = csardl(data, ppp, qqq, cs_lags, formula, print_results);
**
**  Input:      data      balanced panel stacked by unit.
**              ppp       scalar, AR lag order.
**              qqq       scalar, distributed-lag order.
**              cs_lags   scalar, cross-sectional-average lag order.
**              formula   optional formula "y ~ x1 + x2". For dataframe
**                        input, the unit and time variables are inferred
**                        from GAUSS panel-data metadata conventions.
**
**  Output:     csaOut    struct csardlOut.
*/
proc (struct csardlOut) = csardl(data, ppp, qqq, cs_lags = 0, formula = "", print_results = 1);
    local Y, ONEX, csavg, unit_ids, unit_nobs, bt, k0, phi_start, cross_start;
    local gam, phi, denom, bigbt, cross_avg_coef;
    local fitted, resid, coef_cov, sigma2, bigbt_cov, phi_cov, gamma_cov;
    local depvar, xvars, unitvar, timevar, max_lag;

    { depvar, xvars, unitvar, timevar } = _csardlMetadataNames(data, formula);
    data = applyCSARDLFormula(data, formula);
    call _csardlValidateEstimatorInputs(data, ppp, qqq, cs_lags, "csardl");

    { Y, ONEX, csavg, unit_ids, unit_nobs } = _csardlBuildDesign(data, ppp, qqq, cs_lags);
    call _qardlCheckFullColumnRank(ONEX, "csardl", "levels design matrix");

    bt = _qardlSafeInv(ONEX'*ONEX, "csardl", "levels moment matrix")*ONEX'*Y;
    fitted = ONEX*bt;
    resid = Y - fitted;
    { coef_cov, sigma2 } = _csardlOLSCov(ONEX, resid, "csardl");

    k0 = cols(data) - 2;
    gam = bt[2:1+k0];
    phi_start = 2 + k0;
    phi = bt[phi_start:phi_start+ppp-1];
    cross_start = phi_start + ppp + qqq*k0;
    cross_avg_coef = bt[cross_start:rows(bt)];
    denom = 1 - sumc(phi);
    bigbt = gam ./ denom;
    bigbt_cov = _csardlLongRunCov(bt, coef_cov, ppp, qqq, cs_lags, k0);
    phi_cov = coef_cov[phi_start:phi_start+ppp-1, phi_start:phi_start+ppp-1];
    gamma_cov = coef_cov[2:1+k0, 2:1+k0];
    max_lag = maxc(ppp|qqq|cs_lags);

    struct csardlOut csaOut;
    csaOut.model_family = "CS-ARDL";
    csaOut.formula = formula;
    csaOut.depvar = depvar;
    csaOut.xvars = xvars;
    csaOut.unitvar = unitvar;
    csaOut.timevar = timevar;
    csaOut.deterministic = "constant";
    csaOut.covariance_type = "ols";
    csaOut.selection_criterion = "none";
    csaOut.sample_start = 1;
    csaOut.sample_end = rows(data);
    csaOut.estimation_start = max_lag + 1;
    csaOut.estimation_end = unit_nobs[1];
    csaOut.p = ppp;
    csaOut.q = qqq;
    csaOut.qvec = qqq*ones(k0, 1);
    csaOut.cs_lags = cs_lags;
    csaOut.nobs = rows(Y);
    csaOut.k = k0;
    csaOut.nunits = rows(unit_ids);
    csaOut.design_rank = rank(ONEX);
    csaOut.design_cols = cols(ONEX);
    csaOut.design_condition = sqrt(_qardlConditionNumber(ONEX'ONEX));
    csaOut.bigbt = bigbt;
    csaOut.bigbt_cov = bigbt_cov;
    csaOut.phi = phi;
    csaOut.phi_cov = phi_cov;
    csaOut.gamma = gam;
    csaOut.gamma_cov = gamma_cov;
    csaOut.alpha = bt[1];
    csaOut.rho = -(1 - sumc(phi));
    csaOut.bt = bt;
    csaOut.cross_avg = csavg;
    csaOut.cross_avg_coef = cross_avg_coef;
    csaOut.unit_ids = unit_ids;
    csaOut.unit_nobs = unit_nobs;
    csaOut.fitted = fitted;
    csaOut.resid = resid;
    csaOut.sigma2 = sigma2;
    csaOut.coef_cov = coef_cov;

    if print_results;
        call printCSARDL(csaOut);
    endif;

    retp(csaOut);
endp;

/*
**> csardlECM
**
**  Purpose:    Two-step CS-ARDL-ECM estimation using pooled long-run
**              coefficients from csardl(), with lagged error correction,
**              lagged Dy/Dx terms, and cross-sectional-average changes.
*/
proc (struct csardlECMOut) = csardlECM(data, ppp, qqq, cs_lags = 0, formula = "", print_results = 1);
    local Y_ecm, ONEX_ecm, bt_ecm, fitted, resid, coef_cov, sigma2;
    local depvar, xvars, unitvar, timevar, unit_ids, T, max_lag;

    { depvar, xvars, unitvar, timevar } = _csardlMetadataNames(data, formula);
    data = applyCSARDLFormula(data, formula);
    call _csardlValidateEstimatorInputs(data, ppp, qqq, cs_lags, "csardlECM");

    struct csardlOut csaOut;
    csaOut = csardl(data, ppp, qqq, cs_lags, "", 0);

    { Y_ecm, ONEX_ecm } = _csardlBuildECMDesign(data, ppp, qqq, cs_lags, csaOut.bigbt);
    call _qardlCheckFullColumnRank(ONEX_ecm, "csardlECM", "ECM design matrix");

    bt_ecm = _qardlSafeInv(ONEX_ecm'*ONEX_ecm, "csardlECM", "ECM moment matrix")*ONEX_ecm'*Y_ecm;
    fitted = ONEX_ecm*bt_ecm;
    resid = Y_ecm - fitted;
    { coef_cov, sigma2 } = _csardlOLSCov(ONEX_ecm, resid, "csardlECM");
    { unit_ids, T } = _csardlPanelInfo(data, "csardlECM");
    max_lag = maxc(ppp|qqq|cs_lags);

    struct csardlECMOut cECMOut;
    cECMOut.model_family = "CS-ARDL-ECM";
    cECMOut.formula = formula;
    cECMOut.depvar = depvar;
    cECMOut.xvars = xvars;
    cECMOut.unitvar = unitvar;
    cECMOut.timevar = timevar;
    cECMOut.deterministic = "constant";
    cECMOut.covariance_type = "ols";
    cECMOut.selection_criterion = "none";
    cECMOut.sample_start = 1;
    cECMOut.sample_end = rows(data);
    cECMOut.estimation_start = max_lag + 2;
    cECMOut.estimation_end = T;
    cECMOut.p = ppp;
    cECMOut.q = qqq;
    cECMOut.qvec = qqq*ones(cols(data) - 2, 1);
    cECMOut.cs_lags = cs_lags;
    cECMOut.nobs = rows(Y_ecm);
    cECMOut.k = cols(data) - 2;
    cECMOut.nunits = csaOut.nunits;
    cECMOut.design_rank = rank(ONEX_ecm);
    cECMOut.design_cols = cols(ONEX_ecm);
    cECMOut.design_condition = sqrt(_qardlConditionNumber(ONEX_ecm'ONEX_ecm));
    cECMOut.beta_lr = csaOut.bigbt;
    cECMOut.rho_ols = csaOut.rho;
    cECMOut.alpha = bt_ecm[1];
    cECMOut.rho = bt_ecm[2];
    cECMOut.alpha_cov = coef_cov[1, 1];
    cECMOut.rho_cov = coef_cov[2, 2];
    cECMOut.bt = bt_ecm;
    cECMOut.cross_avg_coef = csaOut.cross_avg_coef;
    cECMOut.coef_cov = coef_cov;
    cECMOut.fitted = fitted;
    cECMOut.resid = resid;
    cECMOut.sigma2 = sigma2;

    if print_results;
        call printCSARDLECM(cECMOut);
    endif;

    retp(cECMOut);
endp;

/*
**> csardlFull
**
**  Purpose:    Integrated CS-ARDL workflow with information-criterion lag
**              selection followed by levels and ECM estimation.
**
**  Format:     cfOut = csardlFull(data);
**              cfOut = csardlFull(data, pend, qend, cs_lags, formula,
**                                verbose, criterion);
**
**  Note:       If omitted, pend and qend default to 8 and cs_lags defaults
**              to 0.
*/
proc (struct csardlFullOut) = csardlFull(data, pend = 8, qend = 8, cs_lags = 0, formula = "", verbose = 1, criterion = "bic");
    local pst, qst, depvar, xvars, unitvar, timevar;

    call _qardlValidateLagScalar(pend, "csardlFull: pend");
    call _qardlValidateLagScalarZero(qend, "csardlFull: qend");
    call _qardlValidateLagScalarZero(cs_lags, "csardlFull: cs_lags");

    { depvar, xvars, unitvar, timevar } = _csardlMetadataNames(data, formula);
    data = applyCSARDLFormula(data, formula);
    { pst, qst } = csardlOrder(data, pend, qend, cs_lags, criterion);

    if verbose;
        sprintf("csardlFull: %s-selected p = %d, q = %d", upper(criterion), pst, qst);
    endif;

    struct csardlFullOut cfOut;
    cfOut.model_family = "CS-ARDL";
    cfOut.formula = formula;
    cfOut.depvar = depvar;
    cfOut.xvars = xvars;
    cfOut.unitvar = unitvar;
    cfOut.timevar = timevar;
    cfOut.deterministic = "constant";
    cfOut.covariance_type = "ols";
    cfOut.selection_criterion = criterion;
    cfOut.pmax = pend;
    cfOut.qmax = qend;
    cfOut.sample_start = 1;
    cfOut.sample_end = rows(data);
    cfOut.pst = pst;
    cfOut.qst = qst;
    cfOut.cs_lags = cs_lags;
    cfOut.nobs = rows(data);
    cfOut.csa = csardl(data, pst, qst, cs_lags, "", 0);
    cfOut.ecm = csardlECM(data, pst, qst, cs_lags, "", 0);
    cfOut.csa.formula = formula;
    cfOut.csa.depvar = depvar;
    cfOut.csa.xvars = xvars;
    cfOut.csa.unitvar = unitvar;
    cfOut.csa.timevar = timevar;
    cfOut.csa.selection_criterion = criterion;
    cfOut.ecm.formula = formula;
    cfOut.ecm.depvar = depvar;
    cfOut.ecm.xvars = xvars;
    cfOut.ecm.unitvar = unitvar;
    cfOut.ecm.timevar = timevar;
    cfOut.ecm.selection_criterion = criterion;

    if verbose;
        call printCSARDL(cfOut.csa);
        call printCSARDLECM(cfOut.ecm);
    endif;

    retp(cfOut);
endp;

/*
**> csardlOrder
**
**  Purpose:    Select scalar CS-ARDL p and q orders by information criterion.
*/
proc (2) = csardlOrder(data, pend = 8, qend = 8, cs_lags = 0, criterion = "bic");
    local grid, idx;

    grid = csardlOrderGrid(data, pend, qend, cs_lags, criterion);
    idx = minindc(grid[., 3]);

    retp(grid[idx, 1], grid[idx, 2]);
endp;

/*
**> csardlOrderGrid
**
**  Purpose:    Return the full CS-ARDL p/q information-criterion table.
*/
proc (1) = csardlOrderGrid(data, pend = 8, qend = 8, cs_lags = 0, criterion = "bic");
    local p, q, grid, row, ic;

    call _qardlValidateLagScalar(pend, "csardlOrderGrid: pend");
    call _qardlValidateLagScalarZero(qend, "csardlOrderGrid: qend");
    call _qardlValidateLagScalarZero(cs_lags, "csardlOrderGrid: cs_lags");
    call _qardlValidateICCriterion(criterion, "csardlOrderGrid");

    grid = zeros(pend*(qend+1), 3);
    row = 1;
    p = 1;
    do until p > pend;
        q = 0;
        do until q > qend;
            ic = csardlICMean(data, p, q, cs_lags, criterion);
            grid[row, .] = p~q~ic;
            row = row + 1;
            q = q + 1;
        endo;
        p = p + 1;
    endo;

    retp(grid);
endp;

/*
**> csardlICMean
**
**  Purpose:    Compute AIC/BIC/HQ/HQC for a specified CS-ARDL lag order.
*/
proc (1) = csardlICMean(data, ppp, qqq, cs_lags = 0, criterion = "bic");
    local Y, ONEX, csavg, unit_ids, unit_nobs, bt, resid, N, K, s2, ic;

    call _csardlValidateEstimatorInputs(data, ppp, qqq, cs_lags, "csardlICMean");
    call _qardlValidateICCriterion(criterion, "csardlICMean");

    { Y, ONEX, csavg, unit_ids, unit_nobs } = _csardlBuildDesign(data, ppp, qqq, cs_lags);
    call _qardlCheckFullColumnRank(ONEX, "csardlICMean", "levels design matrix");
    bt = _qardlSafeInv(ONEX'*ONEX, "csardlICMean", "levels moment matrix")*ONEX'*Y;
    resid = Y - ONEX*bt;
    N = rows(Y);
    K = cols(ONEX);
    s2 = (resid'*resid) / N;

    if criterion $== "aic";
        ic = ln(s2) + 2*K/N;
    elseif criterion $== "hq" or criterion $== "hqc";
        ic = ln(s2) + 2*K*ln(ln(N))/N;
    else;
        ic = ln(s2) + K*ln(N)/N;
    endif;

    retp(ic);
endp;

/*
**> csardlDiagnostics
**
**  Purpose:    Optional mean-group, poolability, long-run slope
**              heterogeneity, and cross-sectional dependence diagnostics
**              for CS-ARDL.
**              Estimates the same cross-sectionally augmented ARDL equation
**              unit-by-unit, reports mean-group long-run coefficients, and
**              computes a Wald-style poolability diagnostic for equality of
**              unit long-run coefficients to the pooled CS-ARDL estimate,
**              plus a mean-group-centered slope heterogeneity diagnostic.
**
**  Format:     diagOut = csardlDiagnostics(data, ppp, qqq);
**              diagOut = csardlDiagnostics(data, ppp, qqq, cs_lags, formula, print_results);
*/
proc (struct csardlDiagOut) = csardlDiagnostics(data, ppp, qqq, cs_lags = 0, formula = "", print_results = 1);
    local unit_ids, T, nunits, k0, max_lag, n_param, unit_nobs;
    local ii, jj, Y_i, X_i, bt_i, resid_i, cov_i, sigma2_i, beta_i, beta_cov_i;
    local unit_bigbt, unit_phi, unit_bt, unit_sigma2, unit_resid, mean_group_bigbt, mean_group_se;
    local pooled_bigbt, poolability_wald, poolability_df, poolability_pv, diff, V_i;
    local slope_hetero_wald, slope_hetero_df, slope_hetero_pv;
    local cd_stat, cd_pv, cd_pairs, cd_avg_corr;
    local depvar, xvars, unitvar, timevar;

    { depvar, xvars, unitvar, timevar } = _csardlMetadataNames(data, formula);
    data = applyCSARDLFormula(data, formula);
    call _csardlValidateEstimatorInputs(data, ppp, qqq, cs_lags, "csardlDiagnostics");

    { unit_ids, T } = _csardlPanelInfo(data, "csardlDiagnostics");
    nunits = rows(unit_ids);
    k0 = cols(data) - 2;
    max_lag = maxc(ppp|qqq|cs_lags);
    unit_nobs = T - max_lag;
    n_param = 1 + k0 + ppp + qqq*k0 + (cs_lags+1)*(k0+1);

    if nunits < 2;
        errorlog "csardlDiagnostics: at least two units are required for mean-group diagnostics";
        end;
    endif;

    if unit_nobs <= n_param;
        errorlog "csardlDiagnostics: each unit must have more usable observations than regressors";
        end;
    endif;

    struct csardlOut csaOut;
    csaOut = csardl(data, ppp, qqq, cs_lags, "", 0);
    pooled_bigbt = csaOut.bigbt;

    unit_bigbt = zeros(nunits, k0);
    unit_phi = zeros(nunits, ppp);
    unit_bt = zeros(nunits, n_param);
    unit_sigma2 = zeros(nunits, 1);
    unit_resid = zeros(unit_nobs, nunits);
    poolability_wald = 0;

    ii = 1;
    do until ii > nunits;
        { Y_i, X_i } = _csardlBuildUnitDesign(data, ppp, qqq, cs_lags, ii);
        call _qardlCheckFullColumnRank(X_i, "csardlDiagnostics", "unit design matrix");

        bt_i = _qardlSafeInv(X_i'*X_i, "csardlDiagnostics", "unit moment matrix")*X_i'*Y_i;
        resid_i = Y_i - X_i*bt_i;
        { cov_i, sigma2_i } = _csardlOLSCov(X_i, resid_i, "csardlDiagnostics");
        beta_i = _csardlLongRunBeta(bt_i, ppp, k0);
        beta_cov_i = _csardlLongRunCov(bt_i, cov_i, ppp, qqq, cs_lags, k0);

        unit_bigbt[ii, .] = beta_i';
        unit_phi[ii, .] = bt_i[2+k0:1+k0+ppp]';
        unit_bt[ii, .] = bt_i';
        unit_sigma2[ii] = sigma2_i;
        unit_resid[., ii] = resid_i;

        diff = beta_i - pooled_bigbt;
        V_i = _qardlSafeInv(beta_cov_i, "csardlDiagnostics", "unit long-run covariance");
        poolability_wald = poolability_wald + diff'*V_i*diff;
        ii = ii + 1;
    endo;

    mean_group_bigbt = zeros(k0, 1);
    mean_group_se = zeros(k0, 1);
    jj = 1;
    do until jj > k0;
        mean_group_bigbt[jj] = meanc(unit_bigbt[., jj]);
        mean_group_se[jj] = sqrt(sumc((unit_bigbt[., jj] - mean_group_bigbt[jj])^2) /
                                  (nunits*(nunits-1)));
        jj = jj + 1;
    endo;

    poolability_df = (nunits - 1)*k0;
    poolability_pv = cdfchic(poolability_wald, poolability_df);

    slope_hetero_wald = 0;
    ii = 1;
    do until ii > nunits;
        { Y_i, X_i } = _csardlBuildUnitDesign(data, ppp, qqq, cs_lags, ii);
        bt_i = _qardlSafeInv(X_i'*X_i, "csardlDiagnostics", "unit moment matrix")*X_i'*Y_i;
        resid_i = Y_i - X_i*bt_i;
        { cov_i, sigma2_i } = _csardlOLSCov(X_i, resid_i, "csardlDiagnostics");
        beta_i = _csardlLongRunBeta(bt_i, ppp, k0);
        beta_cov_i = _csardlLongRunCov(bt_i, cov_i, ppp, qqq, cs_lags, k0);
        diff = beta_i - mean_group_bigbt;
        V_i = _qardlSafeInv(beta_cov_i, "csardlDiagnostics", "unit long-run covariance");
        slope_hetero_wald = slope_hetero_wald + diff'*V_i*diff;
        ii = ii + 1;
    endo;

    slope_hetero_df = (nunits - 1)*k0;
    slope_hetero_pv = cdfchic(slope_hetero_wald, slope_hetero_df);
    { cd_stat, cd_pv, cd_pairs, cd_avg_corr } = _csardlPesaranCD(unit_resid, "csardlDiagnostics");

    struct csardlDiagOut diagOut;
    diagOut.model_family = "CS-ARDL-Diagnostics";
    diagOut.formula = formula;
    diagOut.depvar = depvar;
    diagOut.xvars = xvars;
    diagOut.unitvar = unitvar;
    diagOut.timevar = timevar;
    diagOut.deterministic = "constant";
    diagOut.covariance_type = "ols";
    diagOut.selection_criterion = "none";
    diagOut.sample_start = 1;
    diagOut.sample_end = rows(data);
    diagOut.estimation_start = max_lag + 1;
    diagOut.estimation_end = T;
    diagOut.p = ppp;
    diagOut.q = qqq;
    diagOut.qvec = qqq*ones(k0, 1);
    diagOut.cs_lags = cs_lags;
    diagOut.unit_nobs = unit_nobs;
    diagOut.nobs = unit_nobs*nunits;
    diagOut.k = k0;
    diagOut.nunits = nunits;
    diagOut.unit_ids = unit_ids;
    diagOut.unit_bigbt = unit_bigbt;
    diagOut.unit_phi = unit_phi;
    diagOut.unit_bt = unit_bt;
    diagOut.unit_sigma2 = unit_sigma2;
    diagOut.mean_group_bigbt = mean_group_bigbt;
    diagOut.mean_group_se = mean_group_se;
    diagOut.pooled_bigbt = pooled_bigbt;
    diagOut.poolability_wald = poolability_wald;
    diagOut.poolability_pv = poolability_pv;
    diagOut.poolability_df = poolability_df;
    diagOut.slope_hetero_wald = slope_hetero_wald;
    diagOut.slope_hetero_pv = slope_hetero_pv;
    diagOut.slope_hetero_df = slope_hetero_df;
    diagOut.cd_stat = cd_stat;
    diagOut.cd_pv = cd_pv;
    diagOut.cd_pairs = cd_pairs;
    diagOut.cd_avg_corr = cd_avg_corr;

    if print_results;
        call printCSARDLDiagnostics(diagOut);
    endif;

    retp(diagOut);
endp;

proc (4) = _csardlPesaranCD(unit_resid, caller);
    local TT, nunits, ii, jj, ui, uj, denom, rho_ij, rho_sum, npairs;
    local cd_stat, cd_pv, cd_avg_corr;

    TT = rows(unit_resid);
    nunits = cols(unit_resid);
    if nunits < 2;
        errorlog caller $+ ": at least two units are required for Pesaran CD diagnostics";
        end;
    endif;

    rho_sum = 0;
    npairs = 0;
    ii = 1;
    do until ii >= nunits;
        ui = unit_resid[., ii] - meanc(unit_resid[., ii]);
        jj = ii + 1;
        do until jj > nunits;
            uj = unit_resid[., jj] - meanc(unit_resid[., jj]);
            denom = sqrt((ui'*ui) * (uj'*uj));
            if denom <= 1e-14;
                errorlog caller $+ ": unit residual variance is too small for Pesaran CD diagnostics";
                end;
            endif;

            rho_ij = (ui'*uj) / denom;
            rho_sum = rho_sum + rho_ij;
            npairs = npairs + 1;
            jj = jj + 1;
        endo;
        ii = ii + 1;
    endo;

    cd_avg_corr = rho_sum / npairs;
    cd_stat = sqrt((2 * TT) / (nunits * (nunits - 1))) * rho_sum;
    cd_pv = 2 * cdfnc(abs(cd_stat));

    retp(cd_stat, cd_pv, npairs, cd_avg_corr);
endp;

/*
**> printCSARDLDiagnostics
**
**  Purpose:    Print CS-ARDL mean-group, poolability, slope heterogeneity,
**              and CD diagnostics.
*/
proc (0) = printCSARDLDiagnostics(struct csardlDiagOut diagOut);
    local ii;
    local header, note, table_width, eq_line, dash_line;

    header = "Name                  Pooled       Mean Group       MG Std. Err.";
    note = _qardlSignifNote();
    table_width = maxc(strlen(header)|87|strlen(note));
    eq_line = _qardlTableBorder("=", table_width);
    dash_line = _qardlTableBorder("-", table_width);

    print eq_line;
    print "CS-ARDL Mean-Group / Poolability Diagnostics";
    print eq_line;
    sprintf("%-26s%12.0f        %-26s%12.0f", "No. units:", diagOut.nunits,
            "Unit obs:", diagOut.unit_nobs);
    sprintf("%-26s%12.0f        %-26s%12.0f", "AR lags (p):", diagOut.p,
            "DL lags (q):", diagOut.q);
    sprintf("%-26s%12.0f", "CS lags:", diagOut.cs_lags);
    print "Covariance: " $+ diagOut.covariance_type;
    print dash_line;
    print header;
    print dash_line;
    ii = 1;
    do until ii > diagOut.k;
        sprintf("  beta_x%-7d%16.6f%16.6f%16.6f",
                ii, diagOut.pooled_bigbt[ii], diagOut.mean_group_bigbt[ii], diagOut.mean_group_se[ii]);
        ii = ii + 1;
    endo;
    print dash_line;
    sprintf("%-25s%13.6f    %-8s%8.0f    p-value: %12.6f    Sig: %-3s",
            "Poolability Wald:",
            diagOut.poolability_wald, "df:", diagOut.poolability_df, diagOut.poolability_pv,
            _qardlSignifStars(diagOut.poolability_pv));
    sprintf("%-25s%13.6f    %-8s%8.0f    p-value: %12.6f    Sig: %-3s",
            "Slope heterogeneity:",
            diagOut.slope_hetero_wald, "df:", diagOut.slope_hetero_df, diagOut.slope_hetero_pv,
            _qardlSignifStars(diagOut.slope_hetero_pv));
    sprintf("%-25s%13.6f    %-8s%8.0f    p-value: %12.6f    Sig: %-3s",
            "Pesaran CD:",
            diagOut.cd_stat, "pairs:", diagOut.cd_pairs, diagOut.cd_pv,
            _qardlSignifStars(diagOut.cd_pv));
    print "Average residual";
    sprintf("%-25s%13.6f", "correlation:", diagOut.cd_avg_corr);
    print eq_line;
    print note;
endp;

/*
**> printCSARDL
**
**  Purpose:    Print formatted CS-ARDL levels output.
*/
proc (0) = printCSARDL(struct csardlOut csaOut);
    local ii, se_beta, se_phi, z_beta, z_phi, pv_beta, pv_phi;
    local header, note, table_width, eq_line, dash_line;

    se_beta = sqrt(diag(csaOut.bigbt_cov));
    se_phi = sqrt(diag(csaOut.phi_cov));
    z_beta = csaOut.bigbt ./ se_beta;
    z_phi = csaOut.phi ./ se_phi;
    pv_beta = 2*cdfnc(abs(z_beta));
    pv_phi = 2*cdfnc(abs(z_phi));

    header = "Name                  Coeff.       Std. Err.      z-value       P>|z|    Sig.";
    note = _qardlSignifNote();
    table_width = maxc(strlen(header)|84|strlen(note));
    eq_line = _qardlTableBorder("=", table_width);
    dash_line = _qardlTableBorder("-", table_width);

    print eq_line;
    print "CS-ARDL Levels Estimator";
    print eq_line;
    sprintf("%-26s%12.0f        %-26s%12.0f", "No. of obs:", csaOut.nobs,
            "No. units:", csaOut.nunits);
    sprintf("%-26s%12.0f        %-26s%12.0f", "AR lags (p):", csaOut.p,
            "DL lags (q):", csaOut.q);
    sprintf("%-26s%12.0f        %-26s%12.0f", "CS lags:", csaOut.cs_lags,
            "No. regressors:", csaOut.k);
    print "Covariance: " $+ csaOut.covariance_type;
    print dash_line;
    print header;
    print dash_line;

    ii = 1;
    do until ii > csaOut.k;
        sprintf("  beta_x%-7d%16.6f%15.6f%13.6f%12.6f%7s",
                ii, csaOut.bigbt[ii], se_beta[ii], z_beta[ii], pv_beta[ii],
                _qardlSignifStars(pv_beta[ii]));
        ii = ii + 1;
    endo;

    ii = 1;
    do until ii > rows(csaOut.phi);
        sprintf("  phi_l%-8d%16.6f%15.6f%13.6f%12.6f%7s",
                ii, csaOut.phi[ii], se_phi[ii], z_phi[ii], pv_phi[ii],
                _qardlSignifStars(pv_phi[ii]));
        ii = ii + 1;
    endo;
    sprintf("  alpha       %16.6f", csaOut.alpha[1]);
    sprintf("  rho         %16.6f", csaOut.rho[1]);
    print eq_line;
    print note;
endp;

/*
**> printCSARDLECM
**
**  Purpose:    Print formatted CS-ARDL-ECM output.
*/
proc (0) = printCSARDLECM(struct csardlECMOut cECMOut);
    local se_alpha, se_rho, z_alpha, z_rho, pv_alpha, pv_rho;
    local header, note, table_width, eq_line, dash_line;

    se_alpha = sqrt(cECMOut.alpha_cov[1, 1]);
    se_rho = sqrt(cECMOut.rho_cov[1, 1]);
    z_alpha = cECMOut.alpha[1] / se_alpha;
    z_rho = cECMOut.rho[1] / se_rho;
    pv_alpha = 2*cdfnc(abs(z_alpha));
    pv_rho = 2*cdfnc(abs(z_rho));

    header = "Name                  Coeff.       Std. Err.      z-value       P>|z|    Sig.";
    note = _qardlSignifNote();
    table_width = maxc(strlen(header)|84|strlen(note));
    eq_line = _qardlTableBorder("=", table_width);
    dash_line = _qardlTableBorder("-", table_width);

    print eq_line;
    print "CS-ARDL-ECM Estimator";
    print eq_line;
    sprintf("%-26s%12.0f        %-26s%12.0f", "No. of obs:", cECMOut.nobs,
            "No. units:", cECMOut.nunits);
    sprintf("%-26s%12.0f        %-26s%12.0f", "AR lags (p):", cECMOut.p,
            "DL lags (q):", cECMOut.q);
    print "Covariance: " $+ cECMOut.covariance_type;
    print dash_line;
    print header;
    print dash_line;
    sprintf("  alpha       %16.6f%15.6f%13.6f%12.6f%7s",
            cECMOut.alpha[1], se_alpha, z_alpha, pv_alpha,
            _qardlSignifStars(pv_alpha));
    sprintf("  rho         %16.6f%15.6f%13.6f%12.6f%7s",
            cECMOut.rho[1], se_rho, z_rho, pv_rho,
            _qardlSignifStars(pv_rho));
    print eq_line;
    print note;
endp;

/*
**> predictCSARDL
**
**  Purpose:    Return in-sample fitted values from an estimated CS-ARDL model.
*/
proc (1) = predictCSARDL(struct csardlOut csaOut, data, formula = "");
    retp(_predictCSARDLLevels(csaOut, data, formula));
endp;

proc (1) = _predictCSARDLLevels(struct csardlOut csaOut, data, formula = "");
    local Y, ONEX, csavg, unit_ids, unit_nobs;

    data = applyCSARDLFormula(data, formula);
    { Y, ONEX, csavg, unit_ids, unit_nobs } = _csardlBuildDesign(data, csaOut.p, csaOut.q, csaOut.cs_lags);
    retp(ONEX*csaOut.bt);
endp;

/*
**> forecastCSARDL
**
**  Purpose:    Forecast hook for the CS-ARDL API.  The current forecast holds
**              future regressors and cross-sectional averages fixed and
**              returns the last fitted value for each requested horizon.
*/
proc (1) = forecastCSARDL(struct csardlOut csaOut, data, h = 1, formula = "", future_x = error(0));
    retp(_forecastCSARDLLevels(csaOut, data, h, formula, future_x));
endp;

proc (1) = _forecastCSARDLLevels(struct csardlOut csaOut, data, h = 1, formula = "", future_x = error(0));
    local fitted;

    call _qardlValidateLagScalar(h, "forecastCSARDL: h");
    if _ardlFutureXPathProvided(future_x);
        errorlog "forecastCSARDL: future_x paths are not yet supported for panel forecasts";
        end;
    endif;

    fitted = _predictCSARDLLevels(csaOut, data, formula);

    retp(ones(h, 1)*fitted[rows(fitted)]);
endp;

proc (4) = _csardlMetadataNames(data, formula);
    local depvar, xvars, unitvar, timevar;

    if strlen(formula) == 0;
        depvar = "y";
        xvars = _qardlDefaultXVars(cols(data) - 2);
        unitvar = "unit_id";
        timevar = "time_index";
        retp(depvar, xvars, unitvar, timevar);
    endif;

    { depvar, xvars } = _qardlFormulaNames(formula, cols(data) - 2);
    unitvar = _csardlInferPanelIDVar(data, "_csardlMetadataNames");
    timevar = _csardlInferPanelTimeVarQuiet(data, "_csardlMetadataNames");

    retp(depvar, xvars, unitvar, timevar);
endp;

/*
**> applyCSARDLFormula
**
**  Purpose:    Formula hook for CS-ARDL workflows.  The preferred dataframe
**              formula is "y ~ x1 + x2". The unit variable is inferred as
**              the first string/category column and the time variable is
**              inferred as the first date column, falling back to the first
**              numeric column.
*/
proc (1) = applyCSARDLFormula(data, formula);
    local tilde_pos, lhs, unit_var, y_var, xvars, n_x;
    local colnames, unit_idx, y_idx, x_idx, remaining, pos, part;
    local time_var;

    if strlen(formula) == 0;
        retp(data);
    endif;

    tilde_pos = strindx(formula, "~", 1);
    if tilde_pos == 0;
        retp(data);
    endif;

    lhs = strtrim(strsect(formula, 1, tilde_pos - 1));
    if strindx(lhs, "+", 1) > 0;
        errorlog "applyCSARDLFormula: formula must use \"y ~ x1 + x2\"; panel id/time variables are inferred from dataframe metadata";
        end;
    endif;

    if not hasmetadata(data);
        errorlog "applyCSARDLFormula: formula \"y ~ x1 + x2\" requires dataframe metadata";
        end;
    endif;

    unit_var = _csardlInferPanelIDVar(data, "applyCSARDLFormula");
    time_var = _csardlInferPanelTimeVar(data, "applyCSARDLFormula");
    y_var = lhs;

    remaining = strtrim(strsect(formula, tilde_pos + 1, strlen(formula)));
    xvars = "";
    n_x = 0;
    do while strlen(remaining) > 0;
        pos = strindx(remaining, "+", 1);
        if pos == 0;
            part = strtrim(remaining);
            remaining = "";
        else;
            part = strtrim(strsect(remaining, 1, pos - 1));
            remaining = strtrim(strsect(remaining, pos + 1, strlen(remaining)));
        endif;
        if strlen(part) > 0;
            if n_x == 0;
                xvars = part;
            else;
                xvars = xvars $| part;
            endif;
            n_x = n_x + 1;
        endif;
    endo;

    if n_x == 0;
        errorlog "applyCSARDLFormula: at least one RHS variable is required";
        end;
    endif;

    call _csardlCheckInferredTimeVar(time_var, y_var, xvars, "applyCSARDLFormula");
    data = sortmc(data, unit_var $| time_var);

    colnames = lower(getcolnames(data));
    unit_idx = indsav(lower(unit_var), colnames);
    y_idx = indsav(lower(y_var), colnames);
    x_idx = indsav(lower(xvars), colnames);

    if rows(unit_idx) == 0;
        errorlog "applyCSARDLFormula: unit variable not found: " $+ unit_var;
        end;
    endif;

    if rows(y_idx) == 0;
        errorlog "applyCSARDLFormula: dependent variable not found: " $+ y_var;
        end;
    endif;

    if rows(x_idx) /= n_x;
        errorlog "applyCSARDLFormula: one or more RHS variables were not found";
        end;
    endif;

    data = data[., unit_idx | y_idx | x_idx];

    retp(data);
endp;

proc (1) = _csardlInferPanelIDVar(data, caller);
    local col_types, varnames, idx;

    col_types = getcoltypes(data);
    varnames = getcolnames(data);
    idx = packr(indnv(META_TYPE_CATEGORY|META_TYPE_STRING, col_types));

    if ismiss(idx);
        errorlog caller $+ ": missing panel unit variable; expected the first string or category column";
        end;
    endif;

    retp(varnames[idx[1]]);
endp;

proc (1) = _csardlInferPanelTimeVar(data, caller);
    local col_types, varnames, idx, used_numeric;

    col_types = getcoltypes(data);
    varnames = getcolnames(data);
    used_numeric = 0;

    idx = packr(indnv(META_TYPE_DATE, col_types));
    if ismiss(idx);
        idx = packr(indnv(META_TYPE_NUMBER, col_types));
        used_numeric = 1;
    endif;

    if ismiss(idx);
        errorlog caller $+ ": missing panel time variable; expected the first date column or, if none exists, the first numeric column";
        end;
    endif;

    if used_numeric;
        warninglogat sprintf("%s: no date column found. Using numeric column '%s' as time variable.", caller, varnames[idx[1]]);
    endif;

    retp(varnames[idx[1]]);
endp;

proc (1) = _csardlInferPanelTimeVarQuiet(data, caller);
    local col_types, varnames, idx;

    col_types = getcoltypes(data);
    varnames = getcolnames(data);

    idx = packr(indnv(META_TYPE_DATE, col_types));
    if ismiss(idx);
        idx = packr(indnv(META_TYPE_NUMBER, col_types));
    endif;

    if ismiss(idx);
        errorlog caller $+ ": missing panel time variable; expected the first date column or, if none exists, the first numeric column";
        end;
    endif;

    retp(varnames[idx[1]]);
endp;

proc (0) = _csardlCheckInferredTimeVar(time_var, y_var, xvars, caller);
    if lower(time_var) $== lower(y_var) or not ismiss(indsav(lower(time_var), lower(xvars)));
        errorlog caller $+ ": inferred panel time variable is also in the model formula; place a date/numeric time column before model variables";
        end;
    endif;
endp;

proc (0) = _csardlValidateEstimatorInputs(data, ppp, qqq, cs_lags, caller);
    local unit_ids, T, max_lag, n_eff, n_param, k0;

    if rows(data) < 1 or cols(data) < 3;
        errorlog caller $+ ": data must be [unit_id, y, x1, ...]";
        end;
    endif;

    if ismiss(data);
        errorlog caller $+ ": data contains missing values; clean or align the panel before estimation";
        end;
    endif;

    call _qardlValidateLagScalar(ppp, caller $+ ": p");
    call _qardlValidateLagScalarZero(qqq, caller $+ ": q");
    call _qardlValidateLagScalarZero(cs_lags, caller $+ ": cs_lags");

    { unit_ids, T } = _csardlPanelInfo(data, caller);
    k0 = cols(data) - 2;
    max_lag = maxc(ppp|qqq|cs_lags);
    n_eff = (T - max_lag)*rows(unit_ids);
    n_param = 1 + k0 + ppp + qqq*k0 + (cs_lags+1)*(k0+1);

    if n_eff <= n_param;
        errorlog caller $+ ": not enough panel observations for the requested lag orders";
        end;
    endif;
endp;

proc (2) = _csardlPanelInfo(data, caller);
    local unit_ids, ii, nunits, T, start_row, finish_row;

    unit_ids = data[1, 1];
    ii = 2;
    do until ii > rows(data);
        if sumc(data[ii, 1] .== unit_ids) == 0;
            unit_ids = unit_ids | data[ii, 1];
        endif;
        ii = ii + 1;
    endo;

    nunits = rows(unit_ids);
    T = rows(data) / nunits;
    if round(T) /= T;
        errorlog caller $+ ": panel must be balanced and stacked by unit";
        end;
    endif;

    ii = 1;
    do until ii > nunits;
        start_row = (ii-1)*T + 1;
        finish_row = ii*T;
        if maxc(abs(data[start_row:finish_row, 1] - unit_ids[ii])) > 0;
            errorlog caller $+ ": panel must be stacked by unit with equal-length blocks";
            end;
        endif;
        ii = ii + 1;
    endo;

    retp(unit_ids, T);
endp;

proc (5) = _csardlBuildDesign(data, ppp, qqq, cs_lags);
    local unit_ids, T, nunits, k0, max_lag, N, Y, ONEX;
    local csavg, unit_nobs, x_level, y_lags, x_lags, cs_terms;
    local ii, jj, kk, tt, rr, start_row, src, col, block_width;

    { unit_ids, T } = _csardlPanelInfo(data, "_csardlBuildDesign");
    nunits = rows(unit_ids);
    k0 = cols(data) - 2;
    max_lag = maxc(ppp|qqq|cs_lags);
    N = (T - max_lag)*nunits;
    unit_nobs = T*ones(nunits, 1);
    csavg = _csardlCrossAverages(data);

    Y = zeros(N, 1);
    x_level = zeros(N, k0);
    y_lags = zeros(N, ppp);
    block_width = (cs_lags+1)*(k0+1);
    cs_terms = zeros(N, block_width);

    if qqq > 0;
        x_lags = zeros(N, qqq*k0);
    endif;

    rr = 1;
    ii = 1;
    do until ii > nunits;
        start_row = (ii-1)*T + 1;
        tt = max_lag + 1;
        do until tt > T;
            src = start_row + tt - 1;
            Y[rr] = data[src, 2];
            x_level[rr, .] = data[src, 3:cols(data)];

            jj = 1;
            do until jj > ppp;
                y_lags[rr, jj] = data[src-jj, 2];
                jj = jj + 1;
            endo;

            if qqq > 0;
                kk = 1;
                do until kk > k0;
                    jj = 1;
                    do until jj > qqq;
                        col = (kk-1)*qqq + jj;
                        x_lags[rr, col] = data[src-jj, 2+kk];
                        jj = jj + 1;
                    endo;
                    kk = kk + 1;
                endo;
            endif;

            jj = 0;
            do until jj > cs_lags;
                cs_terms[rr, jj*(k0+1)+1:(jj+1)*(k0+1)] = csavg[tt-jj, .];
                jj = jj + 1;
            endo;

            rr = rr + 1;
            tt = tt + 1;
        endo;
        ii = ii + 1;
    endo;

    ONEX = ones(N, 1)~x_level~y_lags;
    if qqq > 0;
        ONEX = ONEX~x_lags;
    endif;
    ONEX = ONEX~cs_terms;

    retp(Y, ONEX, csavg, unit_ids, unit_nobs);
endp;

proc (2) = _csardlBuildECMDesign(data, ppp, qqq, cs_lags, beta_lr);
    local unit_ids, T, nunits, k0, max_lag, N, Y, ONEX, csavg;
    local ec_lag, dy_lags, dx_lags, cs_diff_terms;
    local ii, jj, kk, tt, rr, start_row, src, col, block_width;

    { unit_ids, T } = _csardlPanelInfo(data, "_csardlBuildECMDesign");
    nunits = rows(unit_ids);
    k0 = cols(data) - 2;
    max_lag = maxc(ppp|qqq|cs_lags);
    N = nunits*(T - max_lag - 1);
    csavg = _csardlCrossAverages(data);

    Y = zeros(N, 1);
    ec_lag = zeros(N, 1);
    if ppp > 1;
        dy_lags = zeros(N, ppp-1);
    endif;
    if qqq > 0;
        dx_lags = zeros(N, qqq*k0);
    endif;
    block_width = (cs_lags+1)*(k0+1);
    cs_diff_terms = zeros(N, block_width);

    rr = 1;
    ii = 1;
    do until ii > nunits;
        start_row = (ii-1)*T + 1;
        tt = max_lag + 2;
        do until tt > T;
            src = start_row + tt - 1;
            Y[rr] = data[src, 2] - data[src-1, 2];
            ec_lag[rr] = data[src-1, 2] - data[src-1, 3:cols(data)]*beta_lr;

            if ppp > 1;
                jj = 1;
                do until jj > ppp-1;
                    dy_lags[rr, jj] = data[src-jj, 2] - data[src-jj-1, 2];
                    jj = jj + 1;
                endo;
            endif;

            if qqq > 0;
                kk = 1;
                do until kk > k0;
                    jj = 0;
                    do until jj > qqq-1;
                        col = (kk-1)*qqq + jj + 1;
                        dx_lags[rr, col] = data[src-jj, 2+kk] - data[src-jj-1, 2+kk];
                        jj = jj + 1;
                    endo;
                    kk = kk + 1;
                endo;
            endif;

            jj = 0;
            do until jj > cs_lags;
                cs_diff_terms[rr, jj*(k0+1)+1:(jj+1)*(k0+1)] =
                    csavg[tt-jj, .] - csavg[tt-jj-1, .];
                jj = jj + 1;
            endo;

            rr = rr + 1;
            tt = tt + 1;
        endo;
        ii = ii + 1;
    endo;

    ONEX = ones(N, 1)~ec_lag;
    if ppp > 1;
        ONEX = ONEX~dy_lags;
    endif;
    if qqq > 0;
        ONEX = ONEX~dx_lags;
    endif;
    ONEX = ONEX~cs_diff_terms;

    retp(Y, ONEX);
endp;

proc (2) = _csardlBuildUnitDesign(data, ppp, qqq, cs_lags, unit_index);
    local unit_ids, T, nunits, k0, max_lag, N, Y, ONEX;
    local csavg, x_level, y_lags, x_lags, cs_terms;
    local jj, kk, tt, rr, start_row, src, col, block_width;

    { unit_ids, T } = _csardlPanelInfo(data, "_csardlBuildUnitDesign");
    nunits = rows(unit_ids);
    if unit_index < 1 or unit_index > nunits;
        errorlog "_csardlBuildUnitDesign: unit_index is outside the available panel units";
        end;
    endif;

    k0 = cols(data) - 2;
    max_lag = maxc(ppp|qqq|cs_lags);
    N = T - max_lag;
    csavg = _csardlCrossAverages(data);

    Y = zeros(N, 1);
    x_level = zeros(N, k0);
    y_lags = zeros(N, ppp);
    block_width = (cs_lags+1)*(k0+1);
    cs_terms = zeros(N, block_width);

    if qqq > 0;
        x_lags = zeros(N, qqq*k0);
    endif;

    start_row = (unit_index-1)*T + 1;
    rr = 1;
    tt = max_lag + 1;
    do until tt > T;
        src = start_row + tt - 1;
        Y[rr] = data[src, 2];
        x_level[rr, .] = data[src, 3:cols(data)];

        jj = 1;
        do until jj > ppp;
            y_lags[rr, jj] = data[src-jj, 2];
            jj = jj + 1;
        endo;

        if qqq > 0;
            kk = 1;
            do until kk > k0;
                jj = 1;
                do until jj > qqq;
                    col = (kk-1)*qqq + jj;
                    x_lags[rr, col] = data[src-jj, 2+kk];
                    jj = jj + 1;
                endo;
                kk = kk + 1;
            endo;
        endif;

        jj = 0;
        do until jj > cs_lags;
            cs_terms[rr, jj*(k0+1)+1:(jj+1)*(k0+1)] = csavg[tt-jj, .];
            jj = jj + 1;
        endo;

        rr = rr + 1;
        tt = tt + 1;
    endo;

    ONEX = ones(N, 1)~x_level~y_lags;
    if qqq > 0;
        ONEX = ONEX~x_lags;
    endif;
    ONEX = ONEX~cs_terms;

    retp(Y, ONEX);
endp;

proc (1) = _csardlCrossAverages(data);
    local unit_ids, T, nunits, k0, csavg, tt, ii, src;

    { unit_ids, T } = _csardlPanelInfo(data, "_csardlCrossAverages");
    nunits = rows(unit_ids);
    k0 = cols(data) - 2;
    csavg = zeros(T, k0+1);

    tt = 1;
    do until tt > T;
        ii = 1;
        do until ii > nunits;
            src = (ii-1)*T + tt;
            csavg[tt, .] = csavg[tt, .] + data[src, 2:cols(data)];
            ii = ii + 1;
        endo;
        csavg[tt, .] = csavg[tt, .] ./ nunits;
        tt = tt + 1;
    endo;

    retp(csavg);
endp;

proc (2) = _csardlOLSCov(X, resid, caller);
    local N, K, sigma2, invXX, cov;

    N = rows(X);
    K = cols(X);
    sigma2 = (resid'*resid) / (N - K);
    invXX = _qardlSafeInv(X'*X, caller, "OLS covariance moment matrix");
    cov = sigma2*invXX;

    retp(cov, sigma2);
endp;

proc (1) = _csardlLongRunBeta(bt, ppp, k0);
    local phi_start, denom;

    phi_start = 2 + k0;
    denom = 1 - sumc(bt[phi_start:phi_start+ppp-1]);

    retp(bt[2:1+k0] ./ denom);
endp;

proc (1) = _csardlLongRunCov(bt, coef_cov, ppp, qqq, cs_lags, k0);
    local G, denom, ii, jj, phi_start;

    phi_start = 2 + k0;
    denom = 1 - sumc(bt[phi_start:phi_start+ppp-1]);
    G = zeros(k0, rows(bt));

    ii = 1;
    do until ii > k0;
        G[ii, 1+ii] = 1 / denom;
        jj = 1;
        do until jj > ppp;
            G[ii, phi_start+jj-1] = bt[1+ii] / (denom^2);
            jj = jj + 1;
        endo;
        ii = ii + 1;
    endo;

    retp(G*coef_cov*G');
endp;
