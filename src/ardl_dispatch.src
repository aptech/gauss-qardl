    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    se_beta = sqrt(diag(csaOut.bigbt_cov));
    se_phi = sqrt(diag(csaOut.phi_cov));
    z_beta = csaOut.bigbt ./ se_beta;
    z_phi = csaOut.phi ./ se_phi;
    pv_beta = 2*cdfnc(abs(z_beta));
    pv_phi = 2*cdfnc(abs(z_phi));

    ii = 1;
    do until ii > csaOut.k;
        call _ardlTableWriteRow(fid, fmt, csaOut.model_family, "", "beta_" $+ csaOut.xvars[ii],
                                csaOut.bigbt[ii], se_beta[ii], z_beta[ii], pv_beta[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    ii = 1;
    do until ii > rows(csaOut.phi);
        call _ardlTableWriteRow(fid, fmt, csaOut.model_family, "", "phi_l" $+ ntos(ii),
                                csaOut.phi[ii], se_phi[ii], z_phi[ii], pv_phi[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    call _ardlTableWriteRow(fid, fmt, csaOut.model_family, "", "alpha",
                            csaOut.alpha[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);
    call _ardlTableWriteRow(fid, fmt, csaOut.model_family, "", "rho",
                            csaOut.rho[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableCSARDLECM(struct csardlECMOut cECMOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit;
    local se_alpha, se_rho, z_alpha, z_rho, pv_alpha, pv_rho;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    se_alpha = sqrt(cECMOut.alpha_cov[1, 1]);
    se_rho = sqrt(cECMOut.rho_cov[1, 1]);
    z_alpha = cECMOut.alpha[1] / se_alpha;
    z_rho = cECMOut.rho[1] / se_rho;
    pv_alpha = 2*cdfnc(abs(z_alpha));
    pv_rho = 2*cdfnc(abs(z_rho));

    call _ardlTableWriteRow(fid, fmt, cECMOut.model_family, "", "alpha",
                            cECMOut.alpha[1], se_alpha, z_alpha, pv_alpha,
                            include_stars, include_ci, zcrit, precision);
    call _ardlTableWriteRow(fid, fmt, cECMOut.model_family, "", "rho",
                            cECMOut.rho[1], se_rho, z_rho, pv_rho,
                            include_stars, include_ci, zcrit, precision);

    call _ardlTableEnd(fid, fmt);
endp;

proc (5) = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, caller);
    local fmt, fid, include_stars, include_ci, zcrit;

    fmt = lower(table_format);
    if fmt $== "md";
        fmt = "markdown";
    elseif fmt $== "tex";
        fmt = "latex";
    endif;

    if not (fmt $== "markdown" or fmt $== "latex" or fmt $== "csv");
        errorlog caller $+ ": table_format must be 'markdown', 'latex', or 'csv'";
        end;
    endif;

    if precision < 0;
        errorlog caller $+ ": precision must be nonnegative";
        end;
    endif;

    include_stars = stars /= 0;
    include_ci = ci_level > 0;
    if include_ci and (ci_level <= 0 or ci_level >= 1);
        errorlog caller $+ ": ci_level must be between 0 and 1, or 0 to omit CI columns";
        end;
    endif;

    if include_ci;
        zcrit = cdfni(1 - (1-ci_level)/2);
    else;
        zcrit = error(0);
    endif;

    fid = fopen(fpath, "w");
    if fid == -1;
        errorlog caller $+ ": could not open " $+ fpath;
        end;
    endif;

    retp(fid, fmt, include_stars, include_ci, zcrit);
endp;

proc (0) = _ardlTableBegin(fid, fmt, include_stars, include_ci);
    local header, sep, ncols, ret;

    header = _ardlTableHeader(fmt, include_stars, include_ci);

    if fmt $== "latex";
        ncols = 7 + include_stars + 2*include_ci;
        ret = fputs(fid, "\\begin{tabular}{" $+ _qardlTableBorder("l", ncols) $+ "}\n");
        ret = fputs(fid, "\\hline\n");
        ret = fputs(fid, header $+ " \\\\\n");
        ret = fputs(fid, "\\hline\n");
    elseif fmt $== "markdown";
        sep = "|---|---|---|---|---|---|---|";
        if include_stars;
            sep = sep $+ "---|";
        endif;
        if include_ci;
            sep = sep $+ "---|---|";
        endif;
        ret = fputs(fid, header $+ "\n");
        ret = fputs(fid, sep $+ "\n");
    else;
        ret = fputs(fid, header $+ "\n");
    endif;
endp;

proc (1) = _ardlTableHeader(fmt, include_stars, include_ci);
    local header;

    if fmt $== "latex";
        header = "Model & Tau & Name & Estimate & Std. Err. & z-value & P>|z|";
        if include_stars;
            header = header $+ " & Sig.";
        endif;
        if include_ci;
            header = header $+ " & CI lower & CI upper";
        endif;
    elseif fmt $== "markdown";
        header = "| Model | Tau | Name | Estimate | Std. Err. | z-value | P>|z| |";
        if include_stars;
            header = header $+ " Sig. |";
        endif;
        if include_ci;
            header = header $+ " CI lower | CI upper |";
        endif;
    else;
        header = "model,tau,name,estimate,std_error,z_value,p_value";
        if include_stars;
            header = header $+ ",sig";
        endif;
        if include_ci;
            header = header $+ ",ci_lower,ci_upper";
        endif;
    endif;

    retp(header);
endp;

proc (0) = _ardlTableEnd(fid, fmt);
    local ret;

    if fmt $== "latex";
        ret = fputs(fid, "\\hline\n");
        ret = fputs(fid, "\\end{tabular}\n");
    endif;

    ret = close(fid);
endp;

proc (0) = _ardlTableWriteRow(fid, fmt, model, tau_label, name, estimate, se, zval, pval,
                              include_stars, include_ci, zcrit, precision);
    local out_line, sig, ci_lb, ci_ub, ret;

    if include_stars and not scalmiss(pval);
        sig = _qardlSignifStars(pval);
    else;
        sig = "";
    endif;

    if include_ci and not scalmiss(se);
        ci_lb = estimate - zcrit*se;
        ci_ub = estimate + zcrit*se;
    else;
        ci_lb = error(0);
        ci_ub = error(0);
    endif;

    if fmt $== "csv";
        out_line = _ardlCsvField(model) $+ "," $+ _ardlCsvField(tau_label);
        out_line = out_line $+ "," $+ _ardlCsvField(name);
        out_line = out_line $+ "," $+ _ardlFmtNum(estimate, precision);
        out_line = out_line $+ "," $+ _ardlFmtNum(se, precision);
        out_line = out_line $+ "," $+ _ardlFmtNum(zval, precision);
        out_line = out_line $+ "," $+ _ardlFmtNum(pval, precision);
        if include_stars;
            out_line = out_line $+ "," $+ _ardlCsvField(sig);
        endif;
        if include_ci;
            out_line = out_line $+ "," $+ _ardlFmtNum(ci_lb, precision) $+ "," $+ _ardlFmtNum(ci_ub, precision);
        endif;
    elseif fmt $== "latex";
        out_line = _ardlLatexEscape(model) $+ " & " $+ _ardlLatexEscape(tau_label);
        out_line = out_line $+ " & " $+ _ardlLatexEscape(name);
        out_line = out_line $+ " & " $+ _ardlFmtNum(estimate, precision);
        out_line = out_line $+ " & " $+ _ardlFmtNum(se, precision);
        out_line = out_line $+ " & " $+ _ardlFmtNum(zval, precision);
        out_line = out_line $+ " & " $+ _ardlFmtNum(pval, precision);
        if include_stars;
            out_line = out_line $+ " & " $+ _ardlLatexEscape(sig);
        endif;
        if include_ci;
            out_line = out_line $+ " & " $+ _ardlFmtNum(ci_lb, precision) $+ " & " $+ _ardlFmtNum(ci_ub, precision);
        endif;
        out_line = out_line $+ " \\\\";
    else;
        out_line = "| " $+ model $+ " | " $+ tau_label;
        out_line = out_line $+ " | " $+ name;
        out_line = out_line $+ " | " $+ _ardlFmtNum(estimate, precision);
        out_line = out_line $+ " | " $+ _ardlFmtNum(se, precision);
        out_line = out_line $+ " | " $+ _ardlFmtNum(zval, precision);
        out_line = out_line $+ " | " $+ _ardlFmtNum(pval, precision) $+ " |";
        if include_stars;
            out_line = out_line $+ " " $+ sig $+ " |";
        endif;
        if include_ci;
            out_line = out_line $+ " " $+ _ardlFmtNum(ci_lb, precision) $+ " | " $+ _ardlFmtNum(ci_ub, precision) $+ " |";
        endif;
    endif;

    ret = fputs(fid, out_line $+ "\n");
endp;

proc (1) = _ardlFmtNum(x, precision);
    if scalmiss(x);
        retp("");
    endif;

    retp(ftos(x, "%*.*lf", 1, precision));
endp;

proc (1) = _ardlCsvField(s);
    retp("\"" $+ s $+ "\"");
endp;

proc (1) = _ardlLatexEscape(s);
    local ii, ch, out;

    out = "";
    ii = 1;
    do until ii > strlen(s);
        ch = strsect(s, ii, 1);
        if ch $== "_";
            out = out $+ "\\_";
        elseif ch $== "%";
            out = out $+ "\\%";
        elseif ch $== "&";
            out = out $+ "\\&";
        elseif ch $== "#";
            out = out $+ "\\#";
        else;
            out = out $+ ch;
        endif;
        ii = ii + 1;
    endo;

    retp(out);
endp;
