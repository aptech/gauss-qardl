/*
**> predictARDL
**
**  Purpose:    Return in-sample fitted values from an estimated ARDL-family
**              model. Dispatches on ardlOut, qardlOut, nardlOut, or csardlOut.
**
**  Format:     fit = predictARDL(modelOut, data);
**              fit = predictARDL(modelOut, data, formula);
**
**  Input:      modelOut   ardlOut, qardlOut, nardlOut, or csardlOut.
**              data       estimation data.
**              formula    optional formula string.
*/
proc (1) = predictARDL(modelOut, data, formula = "");
    if isStructType(modelOut, "ardlOut");
        retp(_predictARDLLevels(modelOut, data, formula));
    elseif isStructType(modelOut, "qardlOut");
        retp(_predictQARDLLevels(modelOut, data, formula));
    elseif isStructType(modelOut, "nardlOut");
        retp(_predictNARDLLevels(modelOut, data, formula));
    elseif isStructType(modelOut, "csardlOut");
        retp(_predictCSARDLLevels(modelOut, data, formula));
    endif;

    errorlog "predictARDL: unsupported model output structure";
    end;
endp;

/*
**> forecastARDL
**
**  Purpose:    Recursive forecast for an estimated ARDL-family model.
**              Dispatches on ardlOut, qardlOut, nardlOut, or csardlOut.
**
**  Format:     fcst = forecastARDL(modelOut, data);
**              fcst = forecastARDL(modelOut, data, h, formula, future_x);
**
**  Input:      modelOut   ardlOut, qardlOut, nardlOut, or csardlOut.
**              data       estimation data.
**              h          optional scalar forecast horizon.
**              formula    optional formula string.
**              future_x   optional h x k future regressor path for ARDL,
**                         QARDL, and NARDL outputs.
*/
proc (1) = forecastARDL(modelOut, data, h = 1, formula = "", future_x = error(0));
    if isStructType(modelOut, "ardlOut");
        retp(_forecastARDLLevels(modelOut, data, h, formula, future_x));
    elseif isStructType(modelOut, "qardlOut");
        retp(_forecastQARDLLevels(modelOut, data, h, formula, future_x));
    elseif isStructType(modelOut, "nardlOut");
        retp(_forecastNARDLLevels(modelOut, data, h, formula, future_x));
    elseif isStructType(modelOut, "csardlOut");
        retp(_forecastCSARDLLevels(modelOut, data, h, formula, future_x));
    endif;

    errorlog "forecastARDL: unsupported model output structure";
    end;
endp;

/*
**> ardlLongRun
**
**  Purpose:    Extract long-run coefficients and covariance matrices from
**              ARDL-family levels or full-workflow outputs.
**
**  Format:     { beta, beta_cov } = ardlLongRun(modelOut);
**
**  Input:      modelOut   ardlOut, qardlOut, nardlOut, csardlOut, or the
**                         matching full-workflow output.
*/
proc (2) = ardlLongRun(modelOut);
    local beta, beta_cov;

    if isStructType(modelOut, "ardlOut");
        { beta, beta_cov } = _ardlLongRunARDL(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "qardlOut");
        { beta, beta_cov } = _ardlLongRunQARDL(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "nardlOut");
        { beta, beta_cov } = _ardlLongRunNARDL(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "csardlOut");
        { beta, beta_cov } = _ardlLongRunCSARDL(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "ardlFullOut");
        { beta, beta_cov } = _ardlLongRunARDLFull(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "qardlFullOut");
        { beta, beta_cov } = _ardlLongRunQARDLFull(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "nardlFullOut");
        { beta, beta_cov } = _ardlLongRunNARDLFull(modelOut);
        retp(beta, beta_cov);
    elseif isStructType(modelOut, "csardlFullOut");
        { beta, beta_cov } = _ardlLongRunCSARDLFull(modelOut);
        retp(beta, beta_cov);
    endif;

    errorlog "ardlLongRun: unsupported model output structure";
    end;
endp;

proc (2) = _ardlLongRunARDL(struct ardlOut arOut);
    retp(arOut.bigbt, arOut.bigbt_cov);
endp;

proc (2) = _ardlLongRunQARDL(struct qardlOut qaOut);
    retp(qaOut.bigbt, qaOut.bigbt_cov);
endp;

proc (2) = _ardlLongRunNARDL(struct nardlOut naOut);
    retp(naOut.bigbt, naOut.bigbt_cov);
endp;

proc (2) = _ardlLongRunCSARDL(struct csardlOut csaOut);
    retp(csaOut.bigbt, csaOut.bigbt_cov);
endp;

proc (2) = _ardlLongRunARDLFull(struct ardlFullOut out);
    retp(out.ar.bigbt, out.ar.bigbt_cov);
endp;

proc (2) = _ardlLongRunQARDLFull(struct qardlFullOut out);
    retp(out.qa.bigbt, out.qa.bigbt_cov);
endp;

proc (2) = _ardlLongRunNARDLFull(struct nardlFullOut out);
    retp(out.na.bigbt, out.na.bigbt_cov);
endp;

proc (2) = _ardlLongRunCSARDLFull(struct csardlFullOut out);
    retp(out.csa.bigbt, out.csa.bigbt_cov);
endp;

/*
**> saveARDLTable
**
**  Purpose:    Save a publication-style coefficient table for an ARDL-family
**              output structure. Dispatches on levels, ECM, and full-workflow
**              output structures where coefficient information is available.
**
**  Format:     saveARDLTable(modelOut, fpath);
**              saveARDLTable(modelOut, fpath, table_format, precision, stars, ci_level);
**
**  Input:      modelOut    ARDL-family output structure.
**              fpath       Output file path.
**              table_format      "markdown", "latex", or "csv".
**              precision   Decimal places for numeric entries.
**              stars       1 to include significance-code column, 0 to omit.
**              ci_level    Confidence level for CI columns. Use 0 to omit.
*/
proc (0) = saveARDLTable(modelOut, fpath, table_format = "markdown", precision = 6, stars = 1, ci_level = 0.95);
    if isStructType(modelOut, "ardlOut");
        call _saveARDLTableARDL(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "qardlOut");
        call _saveARDLTableQARDL(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "qardlECMOut");
        call _saveARDLTableQARDLECM(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "nardlOut");
        call _saveARDLTableNARDL(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "nardlECMOut");
        call _saveARDLTableNARDLECM(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "csardlOut");
        call _saveARDLTableCSARDL(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "csardlECMOut");
        call _saveARDLTableCSARDLECM(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "ardlFullOut");
        call _saveARDLTableARDLFull(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "qardlFullOut");
        call _saveARDLTableQARDLFull(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "nardlFullOut");
        call _saveARDLTableNARDLFull(modelOut, fpath, table_format, precision, stars, ci_level);
    elseif isStructType(modelOut, "csardlFullOut");
        call _saveARDLTableCSARDLFull(modelOut, fpath, table_format, precision, stars, ci_level);
    else;
        errorlog "saveARDLTable: unsupported model output structure";
        end;
    endif;
endp;

/*
**> saveARDLMarkdown
**
**  Purpose:    Save an ARDL-family coefficient table in Markdown format.
*/
proc (0) = saveARDLMarkdown(modelOut, fpath, precision = 6, stars = 1, ci_level = 0.95);
    call saveARDLTable(modelOut, fpath, "markdown", precision, stars, ci_level);
endp;

/*
**> saveARDLLaTeX
**
**  Purpose:    Save an ARDL-family coefficient table in LaTeX tabular format.
*/
proc (0) = saveARDLLaTeX(modelOut, fpath, precision = 6, stars = 1, ci_level = 0.95);
    call saveARDLTable(modelOut, fpath, "latex", precision, stars, ci_level);
endp;

proc (0) = _saveARDLTableARDLFull(struct ardlFullOut out, fpath, table_format, precision, stars, ci_level);
    call _saveARDLTableARDL(out.ar, fpath, table_format, precision, stars, ci_level);
endp;

proc (0) = _saveARDLTableQARDLFull(struct qardlFullOut out, fpath, table_format, precision, stars, ci_level);
    call _saveARDLTableQARDL(out.qa, fpath, table_format, precision, stars, ci_level);
endp;

proc (0) = _saveARDLTableNARDLFull(struct nardlFullOut out, fpath, table_format, precision, stars, ci_level);
    call _saveARDLTableNARDL(out.na, fpath, table_format, precision, stars, ci_level);
endp;

proc (0) = _saveARDLTableCSARDLFull(struct csardlFullOut out, fpath, table_format, precision, stars, ci_level);
    call _saveARDLTableCSARDL(out.csa, fpath, table_format, precision, stars, ci_level);
endp;

proc (0) = _saveARDLTableARDL(struct ardlOut arOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ii;
    local se_beta, se_phi, z_beta, z_phi, pv_beta, pv_phi;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    se_beta = sqrt(diag(arOut.bigbt_cov));
    se_phi = sqrt(diag(arOut.phi_cov));
    z_beta = arOut.bigbt ./ se_beta;
    z_phi = arOut.phi ./ se_phi;
    pv_beta = 2*cdfnc(abs(z_beta));
    pv_phi = 2*cdfnc(abs(z_phi));

    ii = 1;
    do until ii > arOut.k;
        call _ardlTableWriteRow(fid, fmt, arOut.model_family, "", "beta_" $+ arOut.xvars[ii],
                                arOut.bigbt[ii], se_beta[ii], z_beta[ii], pv_beta[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    ii = 1;
    do until ii > rows(arOut.phi);
        call _ardlTableWriteRow(fid, fmt, arOut.model_family, "", "phi_l" $+ ntos(ii),
                                arOut.phi[ii], se_phi[ii], z_phi[ii], pv_phi[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    call _ardlTableWriteRow(fid, fmt, arOut.model_family, "", "alpha",
                            arOut.alpha[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);
    call _ardlTableWriteRow(fid, fmt, arOut.model_family, "", "rho",
                            arOut.rho[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableQARDL(struct qardlOut qaOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ss, k, p, ii, jj, idx, tau_label;
    local se_bt, se_phi, se_gam, z_bt, z_phi, z_gam, pv_bt, pv_phi, pv_gam;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    ss = rows(qaOut.tau);
    k = qaOut.k;
    p = rows(qaOut.phi) / ss;

    se_bt = sqrt(diag(qaOut.bigbt_cov));
    se_phi = sqrt(diag(qaOut.phi_cov));
    se_gam = sqrt(diag(qaOut.gamma_cov));
    z_bt = qaOut.bigbt ./ se_bt;
    z_phi = qaOut.phi ./ se_phi;
    z_gam = qaOut.gamma ./ se_gam;
    pv_bt = 2*cdfnc(abs(z_bt));
    pv_phi = 2*cdfnc(abs(z_phi));
    pv_gam = 2*cdfnc(abs(z_gam));

    jj = 1;
    do until jj > ss;
        tau_label = _ardlFmtNum(qaOut.tau[jj], precision);

        ii = 1;
        do until ii > k;
            idx = (jj-1)*k + ii;
            call _ardlTableWriteRow(fid, fmt, qaOut.model_family, tau_label, "beta_" $+ qaOut.xvars[ii],
                                    qaOut.bigbt[idx], se_bt[idx], z_bt[idx], pv_bt[idx],
                                    include_stars, include_ci, zcrit, precision);
            ii = ii + 1;
        endo;

        ii = 1;
        do until ii > k;
            idx = (jj-1)*k + ii;
            call _ardlTableWriteRow(fid, fmt, qaOut.model_family, tau_label, "gamma_" $+ qaOut.xvars[ii],
                                    qaOut.gamma[idx], se_gam[idx], z_gam[idx], pv_gam[idx],
                                    include_stars, include_ci, zcrit, precision);
            ii = ii + 1;
        endo;

        ii = 1;
        do until ii > p;
            idx = (jj-1)*p + ii;
            call _ardlTableWriteRow(fid, fmt, qaOut.model_family, tau_label, "phi_l" $+ ntos(ii),
                                    qaOut.phi[idx], se_phi[idx], z_phi[idx], pv_phi[idx],
                                    include_stars, include_ci, zcrit, precision);
            ii = ii + 1;
        endo;

        call _ardlTableWriteRow(fid, fmt, qaOut.model_family, tau_label, "alpha",
                                qaOut.alpha[jj], error(0), error(0), error(0),
                                include_stars, include_ci, zcrit, precision);
        call _ardlTableWriteRow(fid, fmt, qaOut.model_family, tau_label, "rho",
                                qaOut.rho[jj], error(0), error(0), error(0),
                                include_stars, include_ci, zcrit, precision);
        jj = jj + 1;
    endo;

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableQARDLECM(struct qardlECMOut qECMOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ss, ii, jj, tau_label;
    local se_alpha, se_rho, z_alpha, z_rho, pv_alpha, pv_rho;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    ss = rows(qECMOut.tau);
    se_alpha = sqrt(diag(qECMOut.alpha_cov));
    se_rho = sqrt(diag(qECMOut.rho_cov));
    z_alpha = qECMOut.alpha ./ se_alpha;
    z_rho = qECMOut.rho ./ se_rho;
    pv_alpha = 2*cdfnc(abs(z_alpha));
    pv_rho = 2*cdfnc(abs(z_rho));

    ii = 1;
    do until ii > qECMOut.k;
        call _ardlTableWriteRow(fid, fmt, qECMOut.model_family, "", "beta_lr_" $+ qECMOut.xvars[ii],
                                qECMOut.beta_lr[ii], error(0), error(0), error(0),
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    jj = 1;
    do until jj > ss;
        tau_label = _ardlFmtNum(qECMOut.tau[jj], precision);
        call _ardlTableWriteRow(fid, fmt, qECMOut.model_family, tau_label, "alpha",
                                qECMOut.alpha[jj], se_alpha[jj], z_alpha[jj], pv_alpha[jj],
                                include_stars, include_ci, zcrit, precision);
        call _ardlTableWriteRow(fid, fmt, qECMOut.model_family, tau_label, "rho",
                                qECMOut.rho[jj], se_rho[jj], z_rho[jj], pv_rho[jj],
                                include_stars, include_ci, zcrit, precision);
        jj = jj + 1;
    endo;

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableNARDL(struct nardlOut naOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ii;
    local se_beta, se_phi, z_beta, z_phi, pv_beta, pv_phi;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    se_beta = sqrt(diag(naOut.bigbt_cov));
    se_phi = sqrt(diag(naOut.phi_cov));
    z_beta = naOut.bigbt ./ se_beta;
    z_phi = naOut.phi ./ se_phi;
    pv_beta = 2*cdfnc(abs(z_beta));
    pv_phi = 2*cdfnc(abs(z_phi));

    ii = 1;
    do until ii > naOut.k;
        call _ardlTableWriteRow(fid, fmt, naOut.model_family, "", "beta_pos_" $+ naOut.xvars[ii],
                                naOut.beta_pos[ii], se_beta[ii], z_beta[ii], pv_beta[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    ii = 1;
    do until ii > naOut.k;
        call _ardlTableWriteRow(fid, fmt, naOut.model_family, "", "beta_neg_" $+ naOut.xvars[ii],
                                naOut.beta_neg[ii], se_beta[naOut.k+ii],
                                z_beta[naOut.k+ii], pv_beta[naOut.k+ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    ii = 1;
    do until ii > rows(naOut.phi);
        call _ardlTableWriteRow(fid, fmt, naOut.model_family, "", "phi_l" $+ ntos(ii),
                                naOut.phi[ii], se_phi[ii], z_phi[ii], pv_phi[ii],
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    call _ardlTableWriteRow(fid, fmt, naOut.model_family, "", "alpha",
                            naOut.alpha[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);
    call _ardlTableWriteRow(fid, fmt, naOut.model_family, "", "rho",
                            naOut.rho[1], error(0), error(0), error(0),
                            include_stars, include_ci, zcrit, precision);

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableNARDLECM(struct nardlECMOut nECMOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ii;
    local se_alpha, se_rho, z_alpha, z_rho, pv_alpha, pv_rho;

    { fid, fmt, include_stars, include_ci, zcrit } = _ardlTableOpen(fpath, table_format, precision, stars, ci_level, "saveARDLTable");

    call _ardlTableBegin(fid, fmt, include_stars, include_ci);

    ii = 1;
    do until ii > nECMOut.k;
        call _ardlTableWriteRow(fid, fmt, nECMOut.model_family, "", "beta_pos_" $+ nECMOut.xvars[ii],
                                nECMOut.beta_pos[ii], error(0), error(0), error(0),
                                include_stars, include_ci, zcrit, precision);
        call _ardlTableWriteRow(fid, fmt, nECMOut.model_family, "", "beta_neg_" $+ nECMOut.xvars[ii],
                                nECMOut.beta_neg[ii], error(0), error(0), error(0),
                                include_stars, include_ci, zcrit, precision);
        ii = ii + 1;
    endo;

    se_alpha = sqrt(nECMOut.alpha_cov[1, 1]);
    se_rho = sqrt(nECMOut.rho_cov[1, 1]);
    z_alpha = nECMOut.alpha[1] / se_alpha;
    z_rho = nECMOut.rho[1] / se_rho;
    pv_alpha = 2*cdfnc(abs(z_alpha));
    pv_rho = 2*cdfnc(abs(z_rho));

    call _ardlTableWriteRow(fid, fmt, nECMOut.model_family, "", "alpha",
                            nECMOut.alpha[1], se_alpha, z_alpha, pv_alpha,
                            include_stars, include_ci, zcrit, precision);
    call _ardlTableWriteRow(fid, fmt, nECMOut.model_family, "", "rho",
                            nECMOut.rho[1], se_rho, z_rho, pv_rho,
                            include_stars, include_ci, zcrit, precision);

    call _ardlTableEnd(fid, fmt);
endp;

proc (0) = _saveARDLTableCSARDL(struct csardlOut csaOut, fpath, table_format, precision, stars, ci_level);
    local fid, fmt, include_stars, include_ci, zcrit, ii;
