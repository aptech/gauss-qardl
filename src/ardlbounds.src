/*
**> ardlbounds
**
**  Purpose:    Pesaran, Shin & Smith (2001) ARDL bounds cointegration test.
**              Compatibility wrapper for Case III: unrestricted intercept,
**              no trend.
**
**  Format:     { Fstat, cv } = ardlbounds(data, ppp, qqq);
*/
proc (2) = ardlbounds(data, ppp, qqq);
    local Fstat, tstat, cv, case_id, q_restrict;

    { Fstat, tstat, cv, case_id, q_restrict } = ardlboundsCase(data, ppp, qqq, 3);

    retp(Fstat, cv);
endp;

/*
**> ardlboundsCase
**
**  Purpose:    ARDL bounds test with deterministic-case selection and the
**              associated t-statistic for the lagged dependent level.
**
**  Format:     { Fstat, tstat, cv, case_id, q_restrict } =
**                  ardlboundsCase(data, ppp, qqq, case_id);
**
**  Input:      case_id     PSS deterministic case:
**                          1 = no intercept, no trend.
**                          2 = restricted intercept, no trend.
**                          3 = unrestricted intercept, no trend.
**                          4 = unrestricted intercept, restricted trend.
**                          5 = unrestricted intercept, unrestricted trend.
**
**  Output:     Fstat       OLS F-statistic for the relevant levels restriction.
**
**              tstat       t-statistic for the lagged dependent level.
**
**              cv          PSS asymptotic F critical values where tabulated in
**                          this package. Currently populated for Case III.
**                          Use ardlboundsCaseSim for simulation-based critical
**                          values for Cases I-V, finite samples, or k > 10.
**
**              case_id     Deterministic case used.
**
**              q_restrict  Number of restrictions in the F-test.
*/
proc (5) = ardlboundsCase(data, ppp, qqq, case_id);
    local nn, k0, jj, T0, yy, xx, ee, dy;
    local y_lag, x_lag, dy_lags, dx, trend, ONEX, Y, ONEX_R;
    local N, K_total, det_cols, level_start, level_end, q_restrict;
    local bt_ols, cov_ols, sigma2, RSS_U, RSS_R, Fstat, tstat, cv;
    local keep_cols, drop_start, drop_end, bt_R;

    call _qardlValidateEstimatorInputs(data, ppp, qqq, { 0.5 }, "ardlboundsCase");
    call _ardlboundsValidateCase(case_id);

    nn = rows(data);
    k0 = cols(data) - 1;

    yy = data[., 1];
    xx = data[., 2:cols(data)];

    ee = xx[2:nn, .] - xx[1:(nn-1), .];
    ee = zeros(1, k0)|ee;

    T0 = maxc(ppp|qqq);
    dy = yy[2:nn] - yy[1:(nn-1)];

    y_lag = yy[T0:(nn-1)];
    x_lag = xx[T0:(nn-1), .];
    N = rows(y_lag);

    if ppp > 1;
        dy_lags = zeros(N, ppp-1);
        jj = 1;
        do until jj > ppp-1;
            dy_lags[., jj] = dy[(T0-jj):(nn-1-jj)];
            jj = jj + 1;
        endo;
    endif;

    if qqq > 0;
        dx = zeros(N, qqq*k0);
        jj = 0;
        do until jj > qqq-1;
            dx[., (jj*k0+1):((jj+1)*k0)] = ee[(T0+1-jj):(nn-jj), .];
            jj = jj + 1;
        endo;
    endif;

    trend = seqa(T0+1, 1, N);

    if case_id == 1;
        ONEX = y_lag~x_lag;
        det_cols = 0;
    elseif case_id == 2 or case_id == 3;
        ONEX = ones(N, 1)~y_lag~x_lag;
        det_cols = 1;
    else;
        ONEX = ones(N, 1)~trend~y_lag~x_lag;
        det_cols = 2;
    endif;

    if ppp > 1;
        ONEX = ONEX~dy_lags;
    endif;
    if qqq > 0;
        ONEX = ONEX~dx;
    endif;

    Y = dy[T0:(nn-1)];
    K_total = cols(ONEX);
    call _qardlCheckFullColumnRank(ONEX, "ardlboundsCase", "unrestricted bounds-test design matrix");

    bt_ols = _qardlSafeInv(ONEX'*ONEX, "ardlboundsCase", "unrestricted bounds-test moment matrix")*ONEX'*Y;
    RSS_U = sumc((Y - ONEX*bt_ols).^2);
    sigma2 = RSS_U / (N - K_total);
    cov_ols = sigma2*_qardlSafeInv(ONEX'*ONEX, "ardlboundsCase", "unrestricted bounds-test moment matrix");

    level_start = det_cols + 1;
    level_end = det_cols + k0 + 1;

    if case_id == 2;
        drop_start = 1;
        drop_end = level_end;
    elseif case_id == 4;
        drop_start = 2;
        drop_end = level_end;
    else;
        drop_start = level_start;
        drop_end = level_end;
    endif;

    q_restrict = drop_end - drop_start + 1;

    if drop_start == 1;
        ONEX_R = ONEX[., drop_end+1:K_total];
    elseif drop_end == K_total;
        ONEX_R = ONEX[., 1:drop_start-1];
    else;
        ONEX_R = ONEX[., 1:drop_start-1]~ONEX[., drop_end+1:K_total];
    endif;

    call _qardlCheckFullColumnRank(ONEX_R, "ardlboundsCase", "restricted bounds-test design matrix");
    bt_R = _qardlSafeInv(ONEX_R'*ONEX_R, "ardlboundsCase", "restricted bounds-test moment matrix")*ONEX_R'*Y;
    RSS_R = sumc((Y - ONEX_R*bt_R).^2);

    Fstat = ((RSS_R - RSS_U) / q_restrict) / (RSS_U / (N - K_total));
    tstat = bt_ols[level_start] / sqrt(cov_ols[level_start, level_start]);

    cv = _ardlboundsCaseCriticalValues(k0, case_id);

    retp(Fstat, tstat, cv, case_id, q_restrict);
endp;

/*
**> ardlboundsCaseSim
**
**  Purpose:    ARDL bounds test with simulation-based finite-sample critical
**              values for PSS deterministic Cases I-V.
**
**  Format:     { Fstat, tstat, cv, case_id, q_restrict } =
**                  ardlboundsCaseSim(data, ppp, qqq, case_id, reps, seed);
**
**  Notes:      cv rows are 10%, 5%, and 1%; columns are I(0), I(1).
**              Set T = rows(data) through the supplied sample. Use a larger
**              reps value for applied inference.
*/
proc (5) = ardlboundsCaseSim(data, ppp, qqq, case_id, reps = 40000, seed = 0);
    local Fstat, tstat, cv_table, cv_sim, q_restrict, k0, Tsim;

    { Fstat, tstat, cv_table, case_id, q_restrict } = ardlboundsCase(data, ppp, qqq, case_id);
    k0 = cols(data) - 1;
    Tsim = rows(data);
    cv_sim = ardlboundsCaseSimCV(k0, case_id, Tsim, reps, seed);

    retp(Fstat, tstat, cv_sim, case_id, q_restrict);
endp;

/*
**> ardlboundsCaseCV
**
**  Purpose:    Return bundled PSS Case III F critical values when available,
**              or simulation-based F critical values when reps > 0.
*/
proc (1) = ardlboundsCaseCV(k0, case_id, Tsim = 1000, reps = 0, seed = 0);
    call _ardlboundsValidateCase(case_id);
    call _ardlboundsValidateCVInputs(k0, Tsim, reps, "ardlboundsCaseCV");

    if reps > 0;
        retp(ardlboundsCaseSimCV(k0, case_id, Tsim, reps, seed));
    endif;

    retp(_ardlboundsCaseCriticalValues(k0, case_id));
endp;

/*
**> ardlboundsCaseSimCV
**
**  Purpose:    Simulate PSS-style F critical-value bounds for Cases I-V.
*/
proc (1) = ardlboundsCaseSimCV(k0, case_id, Tsim = 1000, reps = 40000, seed = 0);
    local f_i0, f_i1, rr, y, dy_sim, y_lag, x, x_i1, x_lag_i0, x_lag_i1, trend;
    local cv, probs;

    call _ardlboundsValidateCase(case_id);
    call _ardlboundsValidateCVInputs(k0, Tsim, reps, "ardlboundsCaseSimCV");
    call _qardlValidateBootstrapSeed(seed, "ardlboundsCaseSimCV");

    if seed > 0;
        rndseed seed;
    endif;

    f_i0 = zeros(reps, 1);
    f_i1 = zeros(reps, 1);
    trend = seqa(1, 1, Tsim-1);

    rr = 1;
    do until rr > reps;
        y = cumsumc(rndn(Tsim, 1));
        dy_sim = y[2:Tsim] - y[1:Tsim-1];
        y_lag = y[1:Tsim-1];

        if k0 > 0;
            x = rndn(Tsim, k0);
            x_i1 = cumsumc(x);
            x_lag_i0 = x[1:Tsim-1, .];
            x_lag_i1 = x_i1[1:Tsim-1, .];
        else;
            x_lag_i0 = error(0);
            x_lag_i1 = error(0);
        endif;

        f_i0[rr] = _ardlboundsSimFstat(dy_sim, y_lag, x_lag_i0, trend, case_id, k0);
        f_i1[rr] = _ardlboundsSimFstat(dy_sim, y_lag, x_lag_i1, trend, case_id, k0);
        rr = rr + 1;
    endo;

    probs = { 0.90, 0.95, 0.99 };
    cv = zeros(3, 2);
    rr = 1;
    do until rr > 3;
        cv[rr, 1] = quantile(f_i0, probs[rr]);
        cv[rr, 2] = quantile(f_i1, probs[rr]);
        rr = rr + 1;
    endo;

    retp(cv);
endp;

/*
**> ardlbounds_print
**
**  Purpose:    Print a formatted summary of ardlbounds() output.
*/
proc (0) = ardlbounds_print(Fstat, cv, k);
    call ardlboundsCase_print(Fstat, error(0), cv, k, 3);
endp;

/*
**> ardlboundsCase_print
**
**  Purpose:    Print a formatted summary of ardlboundsCase() output.
*/
proc (0) = ardlboundsCase_print(Fstat, tstat, cv, k, case_id);
    print "=================================================================";
    print "  ARDL Bounds Test (Pesaran, Shin & Smith 2001)";
    print "=================================================================";
    print "  Case: " $+ ftos(case_id, "%g", 1, 0) $+ " - " $+ _ardlboundsCaseLabel(case_id);
    print "  Number of regressors k = " $+ ftos(k, "%g", 1, 0);
    print "";
    print "  F-statistic:  " $+ ftos(Fstat, "%*.*lf", 1, 4);
    if not scalmiss(tstat);
        print "  t-statistic:  " $+ ftos(tstat, "%*.*lf", 1, 4);
    endif;
    print "";

    if scalmiss(cv[1, 1]);
        print "  Critical value bounds: not tabulated in this package for this case.";
    else;
        print "  Critical value bounds (I(0) lower / I(1) upper):";
        print "    10%: " $+ ftos(cv[1,1], "%*.*lf", 1, 2) $+ " / " $+ ftos(cv[1,2], "%*.*lf", 1, 2);
        print "     5%: " $+ ftos(cv[2,1], "%*.*lf", 1, 2) $+ " / " $+ ftos(cv[2,2], "%*.*lf", 1, 2);
        print "     1%: " $+ ftos(cv[3,1], "%*.*lf", 1, 2) $+ " / " $+ ftos(cv[3,2], "%*.*lf", 1, 2);
        print "";
        if Fstat > cv[2, 2];
            print "  Result: REJECT H0 at 5% (F > I(1) upper bound) => cointegration";
        elseif Fstat < cv[2, 1];
            print "  Result: FAIL TO REJECT H0 at 5% (F < I(0) lower bound)";
        else;
            print "  Result: INCONCLUSIVE at 5% (F between I(0) and I(1) bounds)";
        endif;
    endif;
    print "=================================================================";
endp;

proc (0) = _ardlboundsValidateCase(case_id);
    if rows(case_id) * cols(case_id) /= 1 or round(case_id) /= case_id or case_id < 1 or case_id > 5;
        errorlog "ardlboundsCase: case_id must be an integer from 1 through 5";
        end;
    endif;
endp;

proc (1) = _ardlboundsCaseLabel(case_id);
    if case_id == 1;
        retp("no intercept, no trend");
    elseif case_id == 2;
        retp("restricted intercept, no trend");
    elseif case_id == 3;
        retp("unrestricted intercept, no trend");
    elseif case_id == 4;
        retp("unrestricted intercept, restricted trend");
    else;
        retp("unrestricted intercept, unrestricted trend");
    endif;
endp;

proc (1) = _ardlboundsSimFstat(Y, y_lag, x_lag, trend, case_id, k0);
    local N, XU, XR, bt_U, bt_R, RSS_U, RSS_R, q_restrict, K_total;

    N = rows(Y);

    if case_id == 1;
        XU = y_lag;
        if k0 > 0;
            XU = XU~x_lag;
        endif;
        RSS_R = sumc(Y.^2);
        q_restrict = k0 + 1;
    elseif case_id == 2;
        XU = ones(N, 1)~y_lag;
        if k0 > 0;
            XU = XU~x_lag;
        endif;
        RSS_R = sumc(Y.^2);
        q_restrict = k0 + 2;
    elseif case_id == 3;
        XU = ones(N, 1)~y_lag;
        if k0 > 0;
            XU = XU~x_lag;
        endif;
        XR = ones(N, 1);
        bt_R = inv(XR'*XR)*XR'*Y;
        RSS_R = sumc((Y - XR*bt_R).^2);
        q_restrict = k0 + 1;
    elseif case_id == 4;
        XU = ones(N, 1)~trend~y_lag;
        if k0 > 0;
            XU = XU~x_lag;
        endif;
        XR = ones(N, 1);
        bt_R = inv(XR'*XR)*XR'*Y;
        RSS_R = sumc((Y - XR*bt_R).^2);
        q_restrict = k0 + 2;
    else;
        XU = ones(N, 1)~trend~y_lag;
        if k0 > 0;
            XU = XU~x_lag;
        endif;
        XR = ones(N, 1)~trend;
        bt_R = inv(XR'*XR)*XR'*Y;
        RSS_R = sumc((Y - XR*bt_R).^2);
        q_restrict = k0 + 1;
    endif;

    K_total = cols(XU);
    bt_U = inv(XU'*XU)*XU'*Y;
    RSS_U = sumc((Y - XU*bt_U).^2);

    retp(((RSS_R - RSS_U) / q_restrict) / (RSS_U / (N - K_total)));
endp;

proc (0) = _ardlboundsValidateCVInputs(k0, Tsim, reps, caller);
    if rows(k0)*cols(k0) /= 1 or k0 < 0 or round(k0) /= k0;
        errorlog caller $+ ": k must be a non-negative integer";
        end;
    endif;

    if rows(Tsim)*cols(Tsim) /= 1 or Tsim < 20 or round(Tsim) /= Tsim;
        errorlog caller $+ ": T must be an integer of at least 20";
        end;
    endif;

    if rows(reps)*cols(reps) /= 1 or reps < 0 or round(reps) /= reps;
        errorlog caller $+ ": reps must be a non-negative integer";
        end;
    endif;

    if reps > 0 and reps < 100;
        errorlog caller $+ ": reps must be at least 100 for simulation-based critical values";
        end;
    endif;
endp;

proc (1) = _ardlboundsCaseCriticalValues(k0, case_id);
    local cv, cv_table, k_idx, case_offset;

    cv_table = reshape(
        // Case I: no intercept, no trend.
        3.00~3.00 |
        4.20~4.20 |
        7.17~7.17 |
        2.44~3.28 |
        3.15~4.11 |
        4.81~6.02 |
        2.17~3.19 |
