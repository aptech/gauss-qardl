    if k0 <= 10;
        case_offset = (case_id - 1)*33;
        k_idx = case_offset + k0*3 + 1;
        cv = cv_table[k_idx:k_idx+2, .];
    else;
        cv = error(0)*ones(3, 2);
        print "ardlboundsCase: WARNING - k > 10, bundled asymptotic PSS critical values not tabulated; use ardlboundsCaseSimCV.";
    endif;

    retp(cv);
endp;
