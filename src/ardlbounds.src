        2.14~3.30 |
        2.65~3.97 |
        1.83~2.94 |
        2.06~3.24 |
        2.54~3.86 |
        // Case IV: unrestricted intercept, restricted trend.
        5.37~5.37 |
        6.29~6.29 |
        8.26~8.26 |
        4.05~4.49 |
        4.68~5.15 |
        6.10~6.73 |
        3.38~4.02 |
