        4.94~5.58 |
        2.63~3.35 |
        3.10~3.87 |
        4.13~5.00 |
        2.37~3.20 |
        2.79~3.67 |
        3.65~4.66 |
        2.20~3.09 |
        2.56~3.49 |
        3.29~4.37 |
        2.08~3.00 |
        2.39~3.38 |
        3.06~4.15 |
        1.99~2.94 |
        2.27~3.28 |
        2.88~3.99 |
        1.92~2.89 |
        2.17~3.21 |
        2.73~3.90 |
        1.85~2.85 |
        2.11~3.15 |
        2.62~3.77 |
        1.80~2.80 |
        2.04~3.08 |
        2.50~3.68 |
        1.76~2.77 |
        1.98~3.04 |
        2.41~3.61 |
        // Case III: unrestricted intercept, no trend.
        6.58~6.58 |
